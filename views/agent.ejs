<div class="fade-in">
  <style>
    .chat-wrapper {
      display: flex;
      flex-direction: column;
      height: calc(100vh - var(--header-height) - 32px);
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    
    .chat-header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(255, 255, 255, 0.01);
    }
    .chat-header-title {
      font-size: 15px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text-primary);
    }
    .chat-header-title i {
      color: var(--accent-blue);
      font-size: 20px;
    }
    .chat-header-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .agent-select {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      color: var(--text-primary);
      border-radius: var(--radius-sm);
      padding: 8px 10px;
      font-size: 12px;
      outline: none;
      min-width: 150px;
    }
    .agent-select:focus {
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 2px rgba(var(--accent-rgb), 0.15);
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid transparent;
      transition: var(--transition);
    }

    .status-badge.ready {
      color: var(--success);
      background: rgba(40, 167, 69, 0.08);
      border-color: rgba(40, 167, 69, 0.16);
    }

    .status-badge.not-ready {
      color: var(--danger);
      background: rgba(220, 53, 69, 0.08);
      border-color: rgba(220, 53, 69, 0.16);
    }

    .status-badge.processing {
      color: #b45309;
      background: rgba(245, 158, 11, 0.12);
      border-color: rgba(245, 158, 11, 0.24);
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: currentColor;
      box-shadow: 0 0 0 2px rgba(255,255,255,0.2);
      flex-shrink: 0;
    }
    
    .chat-messages {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
      background: rgba(0, 0, 0, 0.1);
    }
    body.light-mode .chat-messages {
      background: rgba(0, 0, 0, 0.02);
    }
    
    .message {
      display: flex;
      gap: 12px;
      max-width: 90%;
      animation: msg-slide 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes msg-slide {
      from { 
        opacity: 0; 
        transform: translateY(16px);
      }
      to { 
        opacity: 1; 
        transform: translateY(0);
      }
    }
    .message.user {
      align-self: flex-end;
      flex-direction: row-reverse;
    }
    .message.agent {
      align-self: flex-start;
    }
    
    .message-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      font-weight: 600;
    }
    .message.user .message-avatar {
      background: linear-gradient(135deg, var(--accent-blue), rgba(var(--accent-rgb), 0.7));
      color: white;
      border: 2px solid rgba(var(--accent-rgb), 0.3);
    }
    .message.agent .message-avatar {
      background: linear-gradient(135deg, var(--accent-cyan), rgba(6, 182, 212, 0.7));
      color: white;
      border: 2px solid rgba(6, 182, 212, 0.3);
    }
    
    .message-bubble {
      padding: 12px 16px;
      border-radius: var(--radius-md);
      font-size: 13px;
      line-height: 1.6;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    
    /* Code blocks */
    .message-bubble code {
      background: rgba(0, 0, 0, 0.1);
      padding: 2px 6px;
      border-radius: 3px;
      font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
      font-size: 12px;
    }
    body.light-mode .message-bubble code {
      background: rgba(0, 0, 0, 0.05);
    }
    
    .message-bubble pre {
      background: rgba(0, 0, 0, 0.15);
      border: 1px solid rgba(0, 0, 0, 0.1);
      padding: 12px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 12px 0;
      position: relative;
    }
    body.light-mode .message-bubble pre {
      background: #f5f5f5;
      border-color: #e5e5e5;
    }
    
    .message-bubble pre code {
      background: none;
      padding: 0;
      color: inherit;
      font-size: 12px;
    }
    
    .code-block-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(0, 0, 0, 0.2);
      padding: 8px 12px;
      border-radius: 4px 4px 0 0;
      margin: -12px -12px 12px -12px;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 600;
      font-family: monospace;
    }
    body.light-mode .code-block-header {
      background: #efefef;
      color: #666;
    }
    
    .copy-code-btn {
      background: rgba(255, 255, 255, 0.15);
      border: none;
      color: white;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 11px;
      cursor: pointer;
      transition: all 0.2s;
      font-weight: 500;
    }
    body.light-mode .copy-code-btn {
      color: #333;
      background: rgba(0, 0, 0, 0.08);
    }
    .copy-code-btn:hover {
      background: rgba(255, 255, 255, 0.25);
    }
    body.light-mode .copy-code-btn:hover {
      background: rgba(0, 0, 0, 0.12);
    }
    
    /* Markdown elements */
    .message-bubble h1, .message-bubble h2, .message-bubble h3 {
      margin: 16px 0 8px 0;
      font-weight: 700;
      line-height: 1.3;
    }
    .message-bubble h1 {
      font-size: 16px;
      border-bottom: 2px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 8px;
    }
    .message-bubble h2 {
      font-size: 14px;
      color: var(--accent-blue);
    }
    .message-bubble h3 {
      font-size: 13px;
    }
    
    .message-bubble blockquote {
      border-left: 4px solid var(--accent-blue);
      padding-left: 12px;
      margin: 12px 0;
      color: var(--text-secondary);
      font-style: italic;
    }
    
    .message-bubble ul, .message-bubble ol {
      margin: 12px 0;
      padding-left: 24px;
    }
    .message-bubble li {
      margin: 6px 0;
    }
    
    .message-bubble strong {
      font-weight: 700;
      color: var(--accent-blue);
    }
    .message-bubble em {
      font-style: italic;
    }
    
    .message-bubble a {
      color: var(--accent-blue);
      text-decoration: none;
      font-weight: 500;
      border-bottom: 1px solid rgba(var(--accent-rgb), 0.3);
      transition: all 0.2s;
    }
    .message-bubble a:hover {
      border-bottom-color: var(--accent-blue);
      opacity: 0.8;
    }
    
    .message-bubble p {
      margin: 8px 0;
    }
    .message-bubble p:first-child {
      margin-top: 0;
    }
    .message-bubble p:last-child {
      margin-bottom: 0;
    }
    
    .alert {
      padding: 12px 14px;
      border-radius: var(--radius-md);
      border: 1px solid;
      margin: 8px 0;
    }
    .alert-error {
      background: rgba(220, 53, 69, 0.1);
      border-color: rgba(220, 53, 69, 0.3);
      color: #dc3545;
    }
    .alert-success {
      background: rgba(40, 167, 69, 0.1);
      border-color: rgba(40, 167, 69, 0.3);
      color: #28a745;
    }
    .alert-info {
      background: rgba(23, 162, 184, 0.1);
      border-color: rgba(23, 162, 184, 0.3);
      color: #17a2b8;
    }
    .message.user .message-bubble {
      background: linear-gradient(135deg, var(--accent-blue), rgba(var(--accent-rgb), 0.8));
      color: white;
      font-weight: 500;
      border-top-right-radius: 3px;
      box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.2);
    }
    .message.agent .message-bubble {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      color: var(--text-primary);
      border-top-left-radius: 3px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    }
    
    .message-bubble table {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0;
      font-size: 12px;
    }
    .message-bubble th, .message-bubble td {
      border: 1px solid var(--border-light);
      padding: 8px 10px;
      text-align: left;
    }
    .message-bubble th {
      background: rgba(255, 255, 255, 0.05);
      font-weight: 600;
    }
    body.light-mode .message-bubble th {
      background: rgba(0, 0, 0, 0.03);
    }
    
    .quick-prompts {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.005);
    }
    .prompt-btn {
      background: rgba(var(--accent-rgb), 0.05);
      border: 1px solid var(--border);
      color: var(--text-secondary);
      padding: 8px 14px;
      border-radius: 20px;
      font-size: 12px;
      cursor: pointer;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .prompt-btn:hover {
      background: rgba(var(--accent-rgb), 0.15);
      border-color: var(--accent-blue);
      color: var(--text-primary);
      transform: translateY(-1px);
    }
    
    .chat-input-area {
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 10px;
      background: rgba(255, 255, 255, 0.003);
    }
    .chat-input {
      flex: 1;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      color: var(--text-primary);
      padding: 11px 14px;
      border-radius: var(--radius-sm);
      font-size: 13px;
      outline: none;
      transition: var(--transition);
    }
    .chat-input::placeholder {
      color: var(--text-muted);
    }
    .chat-input:focus {
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.1);
      background: var(--bg-secondary);
    }
    
    /* Typing Loader */
    .typing-loader {
      display: flex;
      gap: 6px;
      padding: 6px 0;
      align-items: center;
      height: 28px;
    }
    .typing-dot {
      width: 8px;
      height: 8px;
      background: var(--text-muted);
      border-radius: 50%;
      animation: typing-bounce 1.4s infinite ease-in-out both;
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.2);
    }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes typing-bounce {
      0%, 80%, 100% { 
        transform: scale(0.8);
        opacity: 0.5;
      }
      40% { 
        transform: scale(1.2);
        opacity: 1;
      }
    }
    
    /* Loading indicator */
    .loading-spinner {
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-top-color: var(--accent-blue);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-right: 8px;
      vertical-align: middle;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    @media (max-width: 768px) {
      .message {
        max-width: 95%;
      }
      .chat-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
      }
      .chat-header-actions {
        width: 100%;
        justify-content: stretch;
        gap: 8px;
      }
      .agent-select {
        flex: 1;
        min-width: 0;
      }
      .quick-prompts {
        overflow-x: auto;
        padding: 10px 12px;
      }
      .prompt-btn {
        font-size: 11px;
        padding: 6px 12px;
      }
      .chat-input-area {
        padding: 12px;
        gap: 8px;
      }
      .chat-input {
        padding: 10px 12px;
        font-size: 14px;
      }
    }
  </style>

  <div class="chat-wrapper">
    <div class="chat-header">
      <div class="chat-header-title">
        <i class="bi bi-robot"></i>
        <div>
          <span>Asisten AI Sensus Ekonomi 2026</span>
          <p style="margin: 2px 0 0 0; font-size: 10px; font-weight: 500; color: var(--text-muted);">Menganalisis data dari SQLite database secara real-time</p>
        </div>
      </div>
      <div class="chat-header-actions">
        <button class="btn btn-secondary btn-sm" onclick="clearChatHistory()" style="padding: 6px 10px; font-size: 11px; height: 32px; display: inline-flex; align-items: center; gap: 4px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); cursor: pointer;" title="Hapus riwayat obrolan">
          <i class="bi bi-trash"></i> Bersihkan
        </button>
        <select id="agentProvider" class="agent-select" aria-label="Pilih provider AI">
          <option value="gemini" <%= provider === 'gemini' ? 'selected' : '' %> <%= hasGeminiKey ? '' : 'disabled' %>>Gemini</option>
          <option value="openai" <%= provider === 'openai' ? 'selected' : '' %> <%= hasOpenAIKey ? '' : 'disabled' %>>OpenAI</option>
          <option value="openrouter" <%= provider === 'openrouter' ? 'selected' : '' %> <%= hasOpenRouterKey ? '' : 'disabled' %>>OpenRouter</option>
        </select>
        <select id="agentModel" class="agent-select" aria-label="Pilih model AI"></select>
        <span id="agentStatus" class="status-badge not-ready"><span class="status-dot"></span><span class="status-text">Memeriksa status...</span></span>
      </div>
    </div>
    
    <div class="chat-messages" id="chatMessages">
      <!-- Welcome Message -->
      <div class="message agent">
        <div class="message-avatar"><i class="bi bi-robot"></i></div>
        <div class="message-bubble">
          <h2>👋 Selamat Datang di Asisten AI</h2>
          Saya adalah Asisten AI Sensus Ekonomi 2026 yang siap membantu Anda dengan:
          <ul>
            <li><strong>Analisis Data Progres</strong> - Lihat statistik capaian realisasi muatan per PML/PCL</li>
            <li><strong>Evaluasi Kinerja</strong> - Identifikasi petugas dengan performa terendah dan masalah</li>
            <li><strong>Deteksi Anomali</strong> - Temukan data ganda, petugas tidak aktif, dan tingkat reject tinggi</li>
            <li><strong>Query Real-time</strong> - Tanyakan data apapun langsung dari database Sensus</li>
          </ul>
          <p>Ketik pertanyaan Anda di bawah untuk memulai! 🚀</p>
        </div>
      </div>
    </div>
    
    <!-- Input Form -->
    <form id="chatForm" class="chat-input-area" onsubmit="handleChatSubmit(event)">
      <input type="text" id="chatInput" class="chat-input" placeholder="Tulis pertanyaan mengenai data sensus Anda..." required autocomplete="off">
      <button type="submit" class="btn btn-primary" style="height: auto; padding: 0 20px;"><i class="bi bi-send-fill"></i> Kirim</button>
    </form>
  </div>
</div>

<script>
  const chatHistory = [];
  const modelOptions = {
    gemini: <%- JSON.stringify(geminiModels || []) %>,
    openai: <%- JSON.stringify(openaiModels || []) %>,
    openrouter: <%- JSON.stringify(openrouterModels || []) %>
  };
  const selectedModels = {
    gemini: <%- JSON.stringify(selectedGeminiModel || 'gemini-2.5-flash') %>,
    openai: <%- JSON.stringify(selectedOpenAIModel || 'gpt-5.5') %>,
    openrouter: <%- JSON.stringify(selectedOpenRouterModel || 'meta-llama/llama-3.3-70b-instruct:free') %>
  };

  // FIX #1 — Guard global: pastikan hanya ada SATU request aktif dalam satu waktu.
  // Semua jalur entry (form submit, sendQuickPrompt, keyboard shortcut) diperiksa di sini.
  let _isProcessing = false;

  function refreshModelSelect() {
    const providerSelect = document.getElementById('agentProvider');
    const modelSelect = document.getElementById('agentModel');
    if (!providerSelect || !modelSelect) return;

    const provider = providerSelect.value;
    const models = modelOptions[provider] || [];
    modelSelect.innerHTML = '';
    models.forEach(model => {
      const option = document.createElement('option');
      option.value = model;
      option.textContent = model;
      option.selected = model === selectedModels[provider];
      modelSelect.appendChild(option);
    });

    if (modelSelect.options.length === 0) {
      const option = document.createElement('option');
      option.value = '';
      option.textContent = 'Model belum tersedia';
      modelSelect.appendChild(option);
      modelSelect.disabled = true;
    } else {
      modelSelect.disabled = false;
    }
    updateAgentStatus();
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function formatInline(text) {
    return escapeHtml(text)
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
      .replace(/&lt;br&gt;/g, '<br>');
  }
  
  function copyCodeToClipboard(btn) {
    const codeBlock = btn.closest('pre');
    const codeElement = codeBlock.querySelector('code');
    const text = codeElement.textContent;
    
    navigator.clipboard.writeText(text).then(() => {
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-check"></i> Tersalin!';
      btn.style.background = 'rgba(40, 167, 69, 0.3)';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
      }, 2000);
    }).catch(() => {
      btn.innerHTML = '<i class="bi bi-exclamation-circle"></i> Gagal salin';
    });
  }

  // Synchronous Markdown Renderer for instant, non-blocking UI updates
  function renderMarkdown(text) {
    const lines = String(text || '').split(/\r?\n/);
    const blocks = [];
    let i = 0;

    while (i < lines.length) {
      const line = lines[i];

      // Headers (# ## ###)
      if (/^#+\s+/.test(line)) {
        const level = line.match(/^#+/)[0].length;
        const content = line.replace(/^#+\s+/, '');
        blocks.push(`<h${level}>${formatInline(content)}</h${level}>`);
        i++; continue;
      }

      // Code blocks (```)
      if (line.trim().startsWith('```')) {
        const codeLanguage = line.trim().slice(3).trim() || 'code';
        i++;
        const codeLines = [];
        while (i < lines.length && !lines[i].trim().startsWith('```')) {
          codeLines.push(lines[i]);
          i++;
        }
        if (i < lines.length) i++;
        const codeContent = escapeHtml(codeLines.join('\n'));
        blocks.push(`<pre><div class="code-block-header"><span>${escapeHtml(codeLanguage)}</span><button class="copy-code-btn" onclick="copyCodeToClipboard(this)"><i class="bi bi-clipboard"></i> Copy</button></div><code>${codeContent}</code></pre>`);
        continue;
      }

      // Blockquotes (>)
      if (/^>\s+/.test(line)) {
        const quotes = [];
        while (i < lines.length && /^>\s+/.test(lines[i])) {
          quotes.push(lines[i].replace(/^>\s+/, ''));
          i++;
        }
        blocks.push(`<blockquote>${formatInline(quotes.join('<br>'))}</blockquote>`);
        continue;
      }

      // Tables
      if (/^\s*\|.+\|\s*$/.test(line) && i + 1 < lines.length && /^\s*\|[\s:-]+\|\s*$/.test(lines[i + 1])) {
        const headers = line.trim().slice(1, -1).split('|').map(c => c.trim());
        i += 2;
        const rows = [];
        while (i < lines.length && /^\s*\|.+\|\s*$/.test(lines[i])) {
          rows.push(lines[i].trim().slice(1, -1).split('|').map(c => c.trim()));
          i++;
        }
        blocks.push(`<table><thead><tr>${headers.map(h => `<th>${formatInline(h)}</th>`).join('')}</tr></thead><tbody>${rows.map(row => `<tr>${row.map(c => `<td>${formatInline(c)}</td>`).join('')}</tr>`).join('')}</tbody></table>`);
        continue;
      }

      // Unordered lists
      if (/^\s*[-*]\s+/.test(line)) {
        const items = [];
        while (i < lines.length && /^\s*[-*]\s+/.test(lines[i])) {
          items.push(lines[i].replace(/^\s*[-*]\s+/, ''));
          i++;
        }
        blocks.push(`<ul>${items.map(item => `<li>${formatInline(item)}</li>`).join('')}</ul>`);
        continue;
      }

      // Ordered lists
      if (/^\s*\d+\.\s+/.test(line)) {
        const items = [];
        while (i < lines.length && /^\s*\d+\.\s+/.test(lines[i])) {
          items.push(lines[i].replace(/^\s*\d+\.\s+/, ''));
          i++;
        }
        blocks.push(`<ol>${items.map(item => `<li>${formatInline(item)}</li>`).join('')}</ol>`);
        continue;
      }

      // Empty lines
      if (line.trim() === '') { i++; continue; }

      // Paragraphs
      const paragraph = [];
      while (
        i < lines.length &&
        lines[i].trim() !== '' &&
        !/^#+\s+/.test(lines[i]) &&
        !/^\s*\|.+\|\s*$/.test(lines[i]) &&
        !/^\s*[-*]\s+/.test(lines[i]) &&
        !/^\s*\d+\.\s+/.test(lines[i]) &&
        !/^>\s+/.test(lines[i]) &&
        !lines[i].trim().startsWith('```')
      ) {
        paragraph.push(lines[i]);
        i++;
      }
      if (paragraph.length > 0) {
        blocks.push(`<p>${formatInline(paragraph.join('<br>'))}</p>`);
      }
    }

    return blocks.join('');
  }

  const providerKeyStatus = {
    gemini: <%= hasGeminiKey ? 'true' : 'false' %>,
    openai: <%= hasOpenAIKey ? 'true' : 'false' %>,
    openrouter: <%= hasOpenRouterKey ? 'true' : 'false' %>
  };

  let agentStatusTimer = null;

  function updateAgentStatus() {
    const providerSelect = document.getElementById('agentProvider');
    const statusBadge = document.getElementById('agentStatus');
    if (!providerSelect || !statusBadge) return;

    const provider = providerSelect.value;
    const isReady = !!providerKeyStatus[provider];
    statusBadge.classList.remove('processing');
    statusBadge.classList.toggle('ready', isReady);
    statusBadge.classList.toggle('not-ready', !isReady);
    statusBadge.querySelector('.status-text').textContent = isReady
      ? `Ready (${provider.toUpperCase()})`
      : `Tidak siap (${provider.toUpperCase()})`;
  }

  function setAgentStatusProcessing() {
    const statusBadge = document.getElementById('agentStatus');
    if (!statusBadge) return;
    statusBadge.classList.remove('ready', 'not-ready');
    statusBadge.classList.add('processing');
    statusBadge.querySelector('.status-text').textContent = 'Sedang memproses...';
  }

  function startAgentWaitIndicator() {
    clearAgentWaitIndicator();
    setAgentStatusProcessing();
  }

  function clearAgentWaitIndicator() {
    if (agentStatusTimer) {
      clearTimeout(agentStatusTimer);
      agentStatusTimer = null;
    }
    updateAgentStatus();
  }

  // ─────────────────────────────────────────────────────────────────
  //  CHAT HISTORY PERSISTENCE (LocalStorage)
  // ─────────────────────────────────────────────────────────────────
  const HISTORY_STORAGE_KEY = 'se2026_agent_chat_history';

  function saveChatHistory() {
    try {
      localStorage.setItem(HISTORY_STORAGE_KEY, JSON.stringify(chatHistory));
    } catch (e) {
      console.error('Failed to save chat history:', e);
    }
  }

  function loadChatHistory() {
    try {
      const saved = localStorage.getItem(HISTORY_STORAGE_KEY);
      if (!saved) return;
      
      const parsed = JSON.parse(saved);
      if (!Array.isArray(parsed)) return;

      parsed.forEach(msg => {
        chatHistory.push(msg);
        if (msg.role === 'user') {
          appendMessage('user', msg.content, false);
        } else {
          appendMessage('agent', renderMarkdown(msg.content), true);
        }
      });
    } catch (e) {
      console.error('Failed to load chat history:', e);
    }
  }

  function clearChatHistory() {
    if (confirm('Apakah Anda yakin ingin menghapus seluruh riwayat obrolan?')) {
      localStorage.removeItem(HISTORY_STORAGE_KEY);
      chatHistory.length = 0;
      
      // Remove all chat messages except the first greeting message
      const container = document.getElementById('chatMessages');
      const messages = container.querySelectorAll('.message');
      for (let i = 1; i < messages.length; i++) {
        messages[i].remove();
      }
    }
  }

