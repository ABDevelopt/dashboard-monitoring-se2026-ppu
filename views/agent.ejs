  const defaultAnswer = `🤖 **Menganalisis database SQLite...**<br>Saya telah membaca skema tabel <code>subsls_master</code> and <code>progres</code>. Pertanyaan Anda berkaitan dengan analisis data sensus harian.<br><br>Untuk memberikan informasi real-time, saya dapat menjalankan query pembacaan data. Namun, saat ini fitur AI Agent berjalan dalam **Mode Simulasi (Preview)**.<br><br>**Menu yang Terdeteksi pada Database:**<br><ul><li>Jumlah SLS Terisi: <strong>1.042 SLS</strong></li><li>Jumlah Kecamatan: <strong>4 Kecamatan</strong> (Penajam, Waru, Babulu, Sepaku)</li></ul><br>Apabila integrasi Gemini API key telah selesai dikonfigurasi di file <code>.env</code> server, saya akan dapat menjawab kueri dinamis apa pun secara langsung dari SQLite.`;

  function appendMessage(sender, content, isHtml = false) {
    const container = document.getElementById('chatMessages');
    const msgDiv = document.createElement('div');
    msgDiv.className = `message ${sender}`;
    
    const avatar = document.createElement('div');
    avatar.className = 'message-avatar';
    avatar.innerHTML = sender === 'user' ? '<i class="bi bi-person"></i>' : '<i class="bi bi-robot"></i>';
    
    const bubble = document.createElement('div');
    bubble.className = 'message-bubble';
    
    if (isHtml) {
      bubble.innerHTML = content;
    } else {
      bubble.textContent = content;
    }
    
    msgDiv.appendChild(avatar);
    msgDiv.appendChild(bubble);
    container.appendChild(msgDiv);
    container.scrollTop = container.scrollHeight;
    return msgDiv;
  }

  // Synchronous append message helper to prevent thread paint delays
  function appendMessageAsync(sender, replyText) {
    const container = document.getElementById('chatMessages');
    const msgDiv = document.createElement('div');
    msgDiv.className = `message ${sender}`;

    const avatar = document.createElement('div');
    avatar.className = 'message-avatar';
    avatar.innerHTML = sender === 'user' ? '<i class="bi bi-person"></i>' : '<i class="bi bi-robot"></i>';

    const bubble = document.createElement('div');
    bubble.className = 'message-bubble';

    const html = renderMarkdown(replyText);
    bubble.innerHTML = html;

    msgDiv.appendChild(avatar);
    msgDiv.appendChild(bubble);
    container.appendChild(msgDiv);
    container.scrollTop = container.scrollHeight;

    return msgDiv;
  }

  function showTypingLoader() {
    const container = document.getElementById('chatMessages');
    const loaderDiv = document.createElement('div');
    loaderDiv.className = 'message agent temp-loader';
    
    const avatar = document.createElement('div');
    avatar.className = 'message-avatar';
    avatar.innerHTML = '<i class="bi bi-robot"></i>';
    
    const bubble = document.createElement('div');
    bubble.className = 'message-bubble';
    bubble.innerHTML = `
      <div class="typing-loader">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    `;
    
    loaderDiv.appendChild(avatar);
    loaderDiv.appendChild(bubble);
    container.appendChild(loaderDiv);
    container.scrollTop = container.scrollHeight;
    return loaderDiv;
  }

  // FIX #1 + #4 — handleChatSubmit dengan _isProcessing guard yang benar
  // Semua state (input, button, flag) dikelola lewat setUIBusy/setUIFree
  // untuk memastikan tidak ada celah double-request.
  function setUIBusy(input, submitBtn) {
    _isProcessing = true;
    input.disabled = true;
    submitBtn.disabled = true;
    // Disable semua quick-prompt buttons juga
    document.querySelectorAll('.prompt-btn').forEach(btn => btn.disabled = true);
  }

  function setUIFree(input, submitBtn) {
    _isProcessing = false;
    input.disabled = false;
    submitBtn.disabled = false;
    document.querySelectorAll('.prompt-btn').forEach(btn => btn.disabled = false);
    input.focus();
  }

  async function handleChatSubmit(e) {
    e.preventDefault();

    // FIX #1 — Guard: tolak submit jika masih ada request aktif
    if (_isProcessing) return;

    const input = document.getElementById('chatInput');
    const submitBtn = document.querySelector('#chatForm button[type="submit"]');
    const text = input.value.trim();
    if (!text) return;

    // Kunci UI segera sebelum operasi async apapun
    setUIBusy(input, submitBtn);

    appendMessage('user', text);
    chatHistory.push({ role: 'user', content: text });
    saveChatHistory();
    input.value = '';

    const loader = showTypingLoader();
    startAgentWaitIndicator();

    // FIX #2 — Timeout browser 125 000 ms (lebih lama dari server outer 120 000 ms)
    // agar server selalu selesai (atau timeout) lebih dulu, mencegah write ke koneksi mati.
    const controller = new AbortController();
    let timeoutFired = false;

    const browserTimeout = setTimeout(() => {
      timeoutFired = true;
      controller.abort();
      if (loader && loader.parentElement) loader.remove();
      appendMessage('agent', `<div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> <strong>Permintaan terlalu lama.</strong> Server sedang sibuk atau jaringan lambat. Coba lagi atau gunakan pertanyaan yang lebih spesifik.</div>`, true);
      clearAgentWaitIndicator();
      setUIFree(input, submitBtn);
    }, 125000);

    try {
      const res = await fetch('/agent/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        signal: controller.signal,
        body: JSON.stringify({
          message: text,
          history: chatHistory.slice(Math.max(0, chatHistory.length - 11), -1),
          provider: document.getElementById('agentProvider')?.value || 'gemini',
          model: document.getElementById('agentModel')?.value || ''
        })
      });

      clearTimeout(browserTimeout);

      // Jika timeout sudah tembak duluan, hentikan — UI sudah di-free oleh timeout handler
      if (timeoutFired) return;

      if (loader && loader.parentElement) loader.remove();

      let data;
      try {
        data = await res.json();
      } catch (jsonErr) {
        throw new Error('Respons server tidak valid.');
      }

      if (!res.ok || data.error) {
        throw new Error(data.error || 'Gagal memproses pesan.');
      }

      const reply = data.reply || 'Maaf, tidak ada jawaban dari agent.';

      // FIX #5 — Gunakan appendMessageAsync agar render tidak blokir UI thread
      await appendMessageAsync('agent', reply);
      chatHistory.push({ role: 'model', content: reply });
      saveChatHistory();

    } catch (err) {
      clearTimeout(browserTimeout);
      if (timeoutFired) return; // Sudah ditangani oleh timeout handler

      if (loader && loader.parentElement) loader.remove();

      if (err.name === 'AbortError') {
        // AbortError karena timeout sudah ditangani di atas — ini tidak seharusnya tercapai
        appendMessage('agent', `<div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> <strong>Permintaan dibatalkan karena waktu tunggu habis.</strong> Silakan coba lagi.</div>`, true);
      } else {
        appendMessage('agent', `<div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> <strong>Kesalahan:</strong> ${escapeHtml(err.message)}</div>`, true);
      }
    } finally {
      clearTimeout(browserTimeout);
      // Hapus loader jika masih ada — bisa terjadi jika exception terlempar sebelum loader.remove() di try
      if (loader && loader.parentElement) loader.remove();
      clearAgentWaitIndicator();
      // Bebaskan UI: panggil setUIFree SELALU kecuali timeout handler sudah menanganinya.
      // timeoutFired diset true HANYA di dalam setTimeout callback, jadi jika kita tiba
      // di sini karena alasan lain (error, success), _isProcessing masih true dan perlu dibebaskan.
      if (!timeoutFired) {
        setUIFree(input, submitBtn);
      }
    }
  }

  // FIX #3 — sendQuickPrompt: cek _isProcessing sebelum dispatch
  // dispatchEvent melewati attribute `disabled` pada elemen, jadi butuh guard manual ini.
  function sendQuickPrompt(promptText) {
    if (_isProcessing) return; // Tolak jika sedang ada request aktif
    const input = document.getElementById('chatInput');
    if (!input || input.disabled) return;
    input.value = promptText;
    document.getElementById('chatForm').dispatchEvent(new Event('submit'));
  }

  document.addEventListener('DOMContentLoaded', () => {
    const providerSelect = document.getElementById('agentProvider');
    const modelSelect = document.getElementById('agentModel');
    refreshModelSelect();
    updateAgentStatus();
    loadChatHistory();

    if (providerSelect) {
      providerSelect.addEventListener('change', () => {
        refreshModelSelect();
        updateAgentStatus();
      });
    }

    if (modelSelect) {
      modelSelect.addEventListener('change', () => {
        const provider = providerSelect ? providerSelect.value : 'gemini';
        selectedModels[provider] = modelSelect.value;
      });
    }
  });
</script>
