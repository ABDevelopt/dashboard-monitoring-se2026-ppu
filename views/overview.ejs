<div class="fade-in">
  <% if (!summary) { %>
    <!-- EMPTY STATE -->
    <div class="card empty-state text-center" style="padding: 80px 20px;">
      <img src="/logo-mark.png" alt="Emblem SE2026" style="width: 80px; height: 80px; margin-bottom: 20px; opacity: 0.85; object-fit: contain;">
      <h2 class="empty-state-title" style="font-size: 22px; margin-bottom: 12px;">Selamat Datang di Dashboard SE2026 PPU</h2>
      <p class="empty-state-text" style="font-size: 14px; max-width: 540px; margin: 0 auto 24px; color: var(--text-secondary);">
        Dashboard monitoring progres Sensus Ekonomi 2026 Kabupaten Penajam Paser Utara belum terisi data. Silakan upload file Excel rekapitulasi harian pertama Anda untuk memulai visualisasi monitoring.
      </p>
      <a href="/upload" class="btn btn-primary"><i class="bi bi-lightning-charge-fill"></i> Upload Data Rekap Pertama</a>
    </div>
  <% } else { %>
    
    <!-- KPI CARDS GRID -->
    <div class="stats-grid">
      
      <div class="stat-card blue">
        <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
        <div class="stat-label">Total SubSLS (Blok Sensus)</div>
        <div class="stat-value"><%= summary.total.toLocaleString('id-ID') %></div>
        <div class="stat-sub">Beban sensus seluruh PPU</div>
      </div>

      <div class="stat-card green">
        <div class="stat-icon" style="color: var(--accent-green);"><i class="bi bi-check-circle-fill"></i></div>
        <div class="stat-label">SubSLS Selesai</div>
        <div class="stat-value"><%= summary.selesai.toLocaleString('id-ID') %></div>
        <div class="stat-sub">Progres Muatan: <strong><%= ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) %>%</strong></div>
      </div>

      <div class="stat-card yellow">
        <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
        <div class="stat-label">SubSLS Tersisa</div>
        <div class="stat-value"><%= summary.belum.toLocaleString('id-ID') %></div>
        <div class="stat-sub">Muatan Tersisa: <strong><%= (((summary.muatan_total - summary.usaha_total) / summary.muatan_total) * 100).toFixed(2) %>%</strong></div>
      </div>

      <div class="stat-card red">
        <div class="stat-icon"><i class="bi bi-intersect"></i></div>
        <div class="stat-label">Usaha Ganda</div>
        <div class="stat-value"><%= (summary.usaha_ganda || 0).toLocaleString('id-ID') %></div>
        <div class="stat-sub">Usaha teridentifikasi ganda</div>
      </div>

      <div class="stat-card cyan">
        <div class="stat-icon"><i class="bi bi-building-fill"></i></div>
        <div class="stat-label">Total Usaha Ditemukan</div>
        <div class="stat-value"><%= summary.usaha_total.toLocaleString('id-ID') %></div>
        <div class="stat-sub">Ditemukan + Baru (+<%= summary.usaha_baru.toLocaleString('id-ID') %> baru)</div>
      </div>

      <div class="stat-card purple">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="stat-label">Total Keluarga Ditemukan</div>
        <div class="stat-value"><%= summary.keluarga_total.toLocaleString('id-ID') %></div>
        <div class="stat-sub">Ditemukan + Baru (+<%= summary.keluarga_baru.toLocaleString('id-ID') %> baru)</div>
      </div>

    </div>

    <!-- GRAFIK KHUSUS PROGRES PENCACAHAN MUATAN -->
    <div class="card" style="margin-top: 20px; position: relative; overflow: hidden; background: linear-gradient(135deg, var(--bg-card) 0%, rgba(var(--accent-rgb), 0.02) 100%); border: 1px solid var(--border); padding: 20px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
        <div style="display: flex; align-items: center; gap: 10px;">
          <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(var(--accent-rgb), 0.1); display: flex; align-items: center; justify-content: center; color: var(--accent-blue); font-size: 18px;">
            <i class="bi bi-speedometer2"></i>
          </div>
          <div>
            <h3 style="margin: 0; font-size: 15px; font-weight: 700; color: var(--text-primary);">Progres Realisasi Pencacahan Muatan (Beban Target Sensus)</h3>
            <p style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-muted);">Realisasi pencacahan usaha terdata dibandingkan dengan total target muatan prelist</p>
          </div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 20px; font-weight: 800; color: var(--accent-cyan);">
            <%= ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) %>%
          </div>
          <div style="font-size: 11px; color: var(--text-muted);">Capaian Muatan</div>
        </div>
      </div>

      <div style="background: var(--bg-progress-wrap); height: 32px; border-radius: 16px; overflow: hidden; position: relative; border: 1px solid var(--border); display: flex; align-items: center; padding: 0 4px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.15);">
        <% let totalPct = summary.muatan_total ? ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) : '0.00'; %>
        <div class="progress-bar" data-width="<%= totalPct %>" style="background: linear-gradient(90deg, var(--accent-blue) 0%, var(--accent-cyan) 100%); height: 24px; width: 0%; border-radius: 12px; transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; justify-content: flex-end; padding-right: 12px; box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.25);">
          <% if (parseFloat(totalPct) > 8) { %>
            <span style="font-size: 11px; font-weight: 800; color: #ffffff; text-shadow: 0 1px 2px rgba(0,0,0,0.5);"><%= totalPct %>%</span>
          <% } %>
        </div>
        <% if (parseFloat(totalPct) <= 8) { %>
          <span style="margin-left: 12px; font-size: 11px; font-weight: 800; color: var(--text-primary);"><%= totalPct %>%</span>
        <% } %>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
        <div style="display: flex; gap: 10px; align-items: center;">
          <div style="font-size: 24px; color: var(--accent-green);"><i class="bi bi-check-circle-fill"></i></div>
          <div>
            <div style="font-size: 11px; color: var(--text-muted);">Realisasi Terdata</div>
            <div style="font-size: 16px; font-weight: 700; color: var(--text-primary);">
              <%= summary.usaha_total.toLocaleString('id-ID') %> <span style="font-size: 12px; font-weight: 500; color: var(--text-secondary);">muatan usaha</span>
            </div>
          </div>
        </div>
        
        <div style="display: flex; gap: 10px; align-items: center;">
          <div style="font-size: 24px; color: var(--text-muted);"><i class="bi bi-flag-fill"></i></div>
          <div>
            <div style="font-size: 11px; color: var(--text-muted);">Beban Target Muatan</div>
            <div style="font-size: 16px; font-weight: 700; color: var(--text-primary);">
              <%= summary.muatan_total.toLocaleString('id-ID') %> <span style="font-size: 12px; font-weight: 500; color: var(--text-secondary);">muatan</span>
            </div>
          </div>
        </div>

        <div style="display: flex; gap: 10px; align-items: center;">
          <div style="font-size: 24px; color: var(--accent-yellow);"><i class="bi bi-hourglass-split"></i></div>
          <div>
            <div style="font-size: 11px; color: var(--text-muted);">Sisa Beban Muatan</div>
            <div style="font-size: 16px; font-weight: 700; color: var(--text-primary);">
              <%= (summary.muatan_total - summary.usaha_total).toLocaleString('id-ID') %> <span style="font-size: 12px; font-weight: 500; color: var(--text-secondary);">muatan</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- MAIN DASHBOARD CONTENT GRID -->
    <div class="overview-grid">
      
      <!-- LEFT: PROGRESS GAUGE & DETAILS -->
      <div class="card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-graph-up-arrow"></i> Progres Penyelesaian Sensus</div>
          <span class="badge badge-green"><%= ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) %>%</span>
        </div>

        <div style="display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 20px; align-items: center; padding: 10px 0;">
          
          <div class="progress-ring-wrap" style="height: 180px;">
            <canvas id="progressChart"></canvas>
            <div class="progress-ring-text">
              <div class="progress-ring-pct"><%= ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) %>%</div>
              <div class="progress-ring-label">Muatan</div>
            </div>
          </div>

          <div>
            <div class="summary-split">
              <div class="summary-item">
                <div class="summary-item-label text-green">Usaha Baru</div>
                <div class="summary-item-value">+<%= summary.usaha_baru.toLocaleString('id-ID') %></div>
                <div class="summary-item-sub">Usaha terdaftar baru</div>
              </div>
              <div class="summary-item">
                <div class="summary-item-label text-cyan">Keluarga Baru</div>
                <div class="summary-item-value">+<%= summary.keluarga_baru.toLocaleString('id-ID') %></div>
                <div class="summary-item-sub">Keluarga terdaftar baru</div>
              </div>
            </div>
            
            <div class="summary-split mt-4">
              <div class="summary-item">
                <div class="summary-item-label text-red">Usaha Tutup</div>
                <div class="summary-item-value"><%= summary.usaha_tutup.toLocaleString('id-ID') %></div>
                <div class="summary-item-sub">Usaha tutup / pindah</div>
              </div>
              <div class="summary-item">
                <div class="summary-item-label text-yellow">Meninggal</div>
                <div class="summary-item-value"><%= summary.meninggal.toLocaleString('id-ID') %></div>
                <div class="summary-item-sub">Anggota KK meninggal</div>
              </div>
            </div>
          </div>

        </div>
        
        <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-secondary);">
          <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 13px;">
            <span>Realisasi / Target Muatan:</span>
            <span class="fw-bold"><%= summary.usaha_total.toLocaleString('id-ID') %> / <%= summary.muatan_total.toLocaleString('id-ID') %> (<%= ((summary.usaha_total / summary.muatan_total) * 100).toFixed(2) %>%)</span>
          </div>
          <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
            <span>Usaha Tidak Ditemukan: <strong><%= summary.usaha_tidak_ditemukan.toLocaleString('id-ID') %></strong></span>
            <span>Keluarga Tidak Ditemukan: <strong><%= summary.keluarga_tidak_ditemukan.toLocaleString('id-ID') %></strong></span>
          </div>
        </div>
      </div>

      <!-- RIGHT: TREN HARIAN -->
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-calendar3"></i> Tren Progres Pengumpulan Data Harian</div>
        </div>
        <div style="height: 240px; position: relative;">
          <canvas id="trenChartCanvas"></canvas>
        </div>
      </div>

    </div>

    <!-- BOTTOM ROW: KECAMATAN DETAILS -->
    <div class="card mt-4">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-geo-alt"></i> Ringkasan Progres per Kecamatan</div>
        <a href="/kecamatan" class="btn btn-secondary btn-sm">Rincian Kecamatan <i class="bi bi-arrow-right-short"></i></a>
      </div>

      <div class="search-wrap mb-4" style="max-width: 240px; margin-bottom: 16px;">
        <input type="search" id="kecOverviewSearch" placeholder="Cari kecamatan...">
      </div>

      <div class="comparison-grid">
        
        <div class="table-wrap">
          <table id="kecOverviewTable">
            <thead>
              <tr>
                <th>Kecamatan</th>
                <th class="text-right">Total SubSLS</th>
                <th class="text-right">Selesai</th>
                <th class="text-right">Progres %</th>
                <th class="text-right">Beban Muatan</th>
                <th class="text-right">Usaha Total</th>
                <th class="text-right">Keluarga Total</th>
              </tr>
            </thead>
            <tbody>
              <% kecStats.forEach(k => { %>
                <% let kPct = k.total_muatan ? ((k.usaha_total / k.total_muatan) * 100).toFixed(2) : '0.00'; %>
                <tr>
                  <td class="td-primary"><a href="/kecamatan?kec=<%= encodeURIComponent(k.kecamatan) %>" style="color: inherit; text-decoration: none;"><i class="bi bi-geo-alt"></i> <%= k.kecamatan %></a></td>
                  <td class="text-right"><%= k.total_subsls %></td>
                  <td class="text-right fw-bold"><%= k.selesai %></td>
                  <td class="text-right">
                    <% if (kPct == 100) { %>
                      <span class="badge badge-green">100%</span>
                    <% } else if (parseFloat(kPct) < 25) { %>
                      <span class="badge badge-red"><%= kPct %>%</span>
                    <% } else { %>
                      <span class="badge badge-blue"><%= kPct %>%</span>
                    <% } %>
                  </td>
                  <td class="text-right"><%= k.total_muatan.toLocaleString('id-ID') %></td>
                  <td class="text-right fw-bold td-primary"><%= k.usaha_total.toLocaleString('id-ID') %></td>
                  <td class="text-right fw-bold"><%= k.keluarga_total.toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div style="height: 240px; position: relative;">
          <canvas id="kecBarChartCanvas"></canvas>
        </div>

      </div>
    </div>

    <!-- DETAILS HOUSING / RUMAH -->
    <div class="card mt-4">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-house-door"></i> Klasifikasi Tipe Bangunan Tinggal</div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px;">
        
        <div class="summary-item">
          <div class="summary-item-label">Rumah Tunggal</div>
          <div class="summary-item-value"><%= (summary.rumah_tunggal || 0).toLocaleString('id-ID') %></div>
          <div class="summary-item-sub">Bangunan mandiri tunggal</div>
        </div>

        <div class="summary-item">
          <div class="summary-item-label">Rumah Deret</div>
          <div class="summary-item-value"><%= (summary.rumah_deret || 0).toLocaleString('id-ID') %></div>
          <div class="summary-item-sub">Bangunan gandeng/berbaris</div>
        </div>

        <div class="summary-item">
          <div class="summary-item-label">Rumah Susun</div>
          <div class="summary-item-value"><%= (summary.rumah_susun || 0).toLocaleString('id-ID') %></div>
          <div class="summary-item-sub">Rusun sederhana</div>
        </div>

        <div class="summary-item">
          <div class="summary-item-label">Apartemen</div>
          <div class="summary-item-value"><%= (summary.apartemen || 0).toLocaleString('id-ID') %></div>
          <div class="summary-item-sub">Kondominium / apartemen</div>
        </div>

        <div class="summary-item">
          <div class="summary-item-label">Lainnya</div>
          <div class="summary-item-value"><%= (summary.lainnya || 0).toLocaleString('id-ID') %></div>
          <div class="summary-item-sub">Ruko, mes, kontainer, dll.</div>
        </div>

      </div>
    </div>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    <% if (summary) { %>
      // Initialize progress donut chart
      createDonutChart('progressChart', <%= summary.usaha_total %>, <%= summary.muatan_total %>, '#c2410c');

      // Initialize tren line chart
      const rawTrenData = <%- tren %>;
      createTrenChart('trenChartCanvas', rawTrenData);

      // Initialize kecamatan comparison bar chart
      const kecLabels = [];
      const kecSelesai = [];
      const kecTotal = [];
      <% kecStats.forEach(k => { %>
        kecLabels.push("<%= k.kecamatan %>");
        kecSelesai.push(<%= k.usaha_total %>);
        kecTotal.push(<%= k.total_muatan %>);
      <% }) %>

      createBarChart('kecBarChartCanvas', kecLabels, kecSelesai, kecTotal, 'Progres Per Kecamatan (Muatan)');

      // Initialize table sorting and searching
      makeTableSortable('kecOverviewTable');
      makeTableSearchable('kecOverviewSearch', 'kecOverviewTable');
    <% } %>
  });
</script>
