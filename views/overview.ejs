<%
  let activeTargetPct = 25;
  let targetMonthName = 'Juni';
  const currentMonth = new Date().getMonth(); // 5 = Juni, 6 = Juli
  if (currentMonth === 6) { // Juli
    activeTargetPct = 50;
    targetMonthName = 'Juli';
  }
%>
<div class="fade-in">
  <% if (!summary) { %>
    <!-- EMPTY STATE -->
    <div class="card empty-state text-center" style="padding: 80px 20px;">
      <img src="/logo-mark.png" alt="Emblem SE2026" class="logo-light" loading="eager" style="width: 80px; height: 80px; margin-bottom: 20px; opacity: 0.85; object-fit: contain;">
      <img src="/logo-mark-dark.png" alt="Emblem SE2026" class="logo-dark" fetchpriority="high" loading="eager" style="width: 80px; height: 80px; margin-bottom: 20px; opacity: 0.85; object-fit: contain;">
      <h2 class="empty-state-title" style="font-size: 22px; margin-bottom: 12px;">Selamat Datang di Dashboard SE2026 PPU</h2>
      <p class="empty-state-text" style="font-size: 14px; max-width: 540px; margin: 0 auto 24px; color: var(--text-secondary);">
        Dashboard monitoring progres Sensus Ekonomi 2026 Kabupaten Penajam Paser Utara belum terisi data. Silakan upload file Excel rekapitulasi harian pertama Anda untuk memulai visualisasi monitoring.
      </p>
      <a href="/upload" class="btn btn-primary"><i class="bi bi-lightning-charge-fill"></i> Upload Data Rekap Pertama</a>
    </div>
  <% } else { %>
    


    <!-- PROGRES REALISASI UTAMA & ASSIGNMENT -->
    <% if (settings.overview_fasih === '1' || settings.overview_muatan === '1') { %>
    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
      
      <!-- Progres Realisasi & Rincian Status Assignment FASIH -->
      <% if (settings.overview_fasih === '1') { %>
      <div class="card" style="margin: 0; position: relative; overflow: hidden; background: linear-gradient(135deg, var(--bg-card) 0%, rgba(139, 92, 246, 0.02) 100%); border: 1px solid var(--border); padding: 20px; display: flex; flex-direction: column; justify-content: space-between;">
        <div>
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
            <div style="display: flex; align-items: center; gap: 10px;">
              <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(139, 92, 246, 0.1); display: flex; align-items: center; justify-content: center; color: var(--accent-purple); font-size: 18px;">
                <i class="bi bi-phone"></i>
              </div>
              <div>
                <h3 style="margin: 0; font-size: 14px; font-weight: 700; color: var(--text-primary);">Assignment FASIH</h3>
                <p style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-muted);">Realisasi Approved vs Target FASIH</p>
              </div>
            </div>
            <div style="text-align: right;">
              <% let totalPengerjaan = (summary.submitted_total || 0) + (summary.approved_total || 0) + (summary.rejected_total || 0); %>
              <% let fasihPct = summary.target_fasih_total ? ((totalPengerjaan / summary.target_fasih_total) * 100).toFixed(2) : '0.00'; %>
              <div style="font-size: 18px; font-weight: 800; color: var(--accent-purple);"><%= fasihPct %>%</div>
              <div style="font-size: 12px; font-weight: 700; color: var(--text-primary); margin-top: 2px;"><%= totalPengerjaan.toLocaleString('id-ID') %> <span style="font-weight: 500; font-size: 10px; color: var(--text-muted);">/ <%= (summary.target_fasih_total || 0).toLocaleString('id-ID') %></span></div>
              <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;">Capaian FASIH</div>
            </div>
          </div>

          <div style="background: var(--bg-progress-wrap); height: 28px; border-radius: 14px; overflow: hidden; position: relative; border: 1px solid var(--border); display: flex; align-items: center; padding: 0 4px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.15);">
            <div class="progress-bar" data-width="<%= fasihPct %>" style="background: linear-gradient(90deg, #7c3aed 0%, #a78bfa 100%); height: 20px; width: 0%; border-radius: 10px; transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; justify-content: flex-end; padding-right: 12px; box-shadow: 0 2px 8px rgba(124, 58, 237, 0.25);">
              <% if (parseFloat(fasihPct) > 8) { %>
                <span style="font-size: 11px; font-weight: 800; color: #ffffff; text-shadow: 0 1px 2px rgba(0,0,0,0.5);"><%= fasihPct %>%</span>
              <% } %>
            </div>
            <% if (parseFloat(fasihPct) <= 8) { %>
              <span style="margin-left: 12px; font-size: 11px; font-weight: 800; color: var(--text-primary);"><%= fasihPct %>%</span>
            <% } %>
          </div>

          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); margin-bottom: 20px;">
            <div>
              <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Capaian</div>
              <div style="font-size: 14px; font-weight: 700; color: var(--text-primary);"><%= totalPengerjaan.toLocaleString('id-ID') %></div>
            </div>
            <div>
              <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Target</div>
              <div style="font-size: 14px; font-weight: 700; color: var(--text-primary);">
                <%= (summary.target_fasih_total || 0).toLocaleString('id-ID') %>
              </div>
            </div>
            <div>
              <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Sisa</div>
              <div style="font-size: 14px; font-weight: 700; color: var(--accent-yellow);"><%= Math.max(0, summary.target_fasih_total - totalPengerjaan).toLocaleString('id-ID') %></div>
            </div>
          </div>
        </div>

        <!-- Rincian Status Dokumen FASIH -->
        <div style="border-top: 1px dashed var(--border); padding-top: 16px;">
          <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.5px;"><i class="bi bi-info-circle-fill text-purple"></i> Rincian Status Dokumen FASIH</div>
          
          <%
            let draftPct = summary.target_fasih_total ? ((summary.draft_total || 0) / summary.target_fasih_total * 100).toFixed(1) : '0.0';
            let submittedPct = summary.target_fasih_total ? ((summary.submitted_total || 0) / summary.target_fasih_total * 100).toFixed(1) : '0.0';
            let approvedPct = summary.target_fasih_total ? ((summary.approved_total || 0) / summary.target_fasih_total * 100).toFixed(1) : '0.0';
            let rejectedPct = summary.target_fasih_total ? ((summary.rejected_total || 0) / summary.target_fasih_total * 100).toFixed(1) : '0.0';
          %>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
            
            <!-- DRAFT -->
            <div class="status-draft-bg" style="border-radius: var(--radius-sm); padding: 10px 12px; display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%;">
                <div>
                  <div style="font-size: 9px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">DRAFT</div>
                  <div style="font-size: 10px; color: var(--text-secondary); line-height: 1.2;">Belum Submit</div>
                </div>
                <div class="status-draft-text" style="font-size: 14px; font-weight: 800; text-align: right;">
                  <%= (summary.draft_total || 0).toLocaleString('id-ID') %>
                  <span style="display: block; font-size: 9px; font-weight: 600; color: var(--text-muted); margin-top: 1px;"><%= draftPct %>%</span>
                </div>
              </div>
              <div style="background: rgba(245, 158, 11, 0.08); height: 6px; border-radius: 3px; overflow: hidden; width: 100%;">
                <div class="progress-bar" data-width="<%= draftPct %>" style="background: var(--accent-yellow); height: 100%; width: 0%; border-radius: 3px; transition: width 1s ease;"></div>
              </div>
            </div>

            <!-- SUBMITTED BY PCL -->
            <div class="status-submit-bg" style="border-radius: var(--radius-sm); padding: 10px 12px; display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%;">
                <div>
                  <div style="font-size: 9px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">SUBMITTED</div>
                  <div style="font-size: 10px; color: var(--text-secondary); line-height: 1.2;">Oleh PCL</div>
                </div>
                <div class="status-submit-text" style="font-size: 14px; font-weight: 800; text-align: right;">
                  <%= (summary.submitted_total || 0).toLocaleString('id-ID') %>
                  <span style="display: block; font-size: 9px; font-weight: 600; color: var(--text-muted); margin-top: 1px;"><%= submittedPct %>%</span>
                </div>
              </div>
              <div style="background: rgba(59, 130, 246, 0.08); height: 6px; border-radius: 3px; overflow: hidden; width: 100%;">
                <div class="progress-bar" data-width="<%= submittedPct %>" style="background: var(--accent-blue); height: 100%; width: 0%; border-radius: 3px; transition: width 1s ease;"></div>
              </div>
            </div>

            <!-- APPROVED -->
            <div class="status-approve-bg" style="border-radius: var(--radius-sm); padding: 10px 12px; display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%;">
                <div>
                  <div style="font-size: 9px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">APPROVED</div>
                  <div style="font-size: 10px; color: var(--text-secondary); line-height: 1.2;">Diterima PML</div>
                </div>
                <div class="status-approve-text" style="font-size: 14px; font-weight: 800; text-align: right;">
                  <%= (summary.approved_total || 0).toLocaleString('id-ID') %>
                  <span style="display: block; font-size: 9px; font-weight: 600; color: var(--text-muted); margin-top: 1px;"><%= approvedPct %>%</span>
                </div>
              </div>
              <div style="background: rgba(16, 185, 129, 0.08); height: 6px; border-radius: 3px; overflow: hidden; width: 100%;">
                <div class="progress-bar" data-width="<%= approvedPct %>" style="background: var(--accent-green); height: 100%; width: 0%; border-radius: 3px; transition: width 1s ease;"></div>
              </div>
            </div>

            <!-- REJECTED -->
            <div class="status-reject-bg" style="border-radius: var(--radius-sm); padding: 10px 12px; display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%;">
                <div>
                  <div style="font-size: 9px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">REJECTED</div>
                  <div style="font-size: 10px; color: var(--text-secondary); line-height: 1.2;">Ditolak PML</div>
                </div>
                <div class="status-reject-text" style="font-size: 14px; font-weight: 800; text-align: right;">
                  <%= (summary.rejected_total || 0).toLocaleString('id-ID') %>
                  <span style="display: block; font-size: 9px; font-weight: 600; color: var(--text-muted); margin-top: 1px;"><%= rejectedPct %>%</span>
                </div>
              </div>
              <div style="background: rgba(239, 68, 68, 0.08); height: 6px; border-radius: 3px; overflow: hidden; width: 100%;">
                <div class="progress-bar" data-width="<%= rejectedPct %>" style="background: var(--accent-red); height: 100%; width: 0%; border-radius: 3px; transition: width 1s ease;"></div>
              </div>
            </div>

          </div>
        </div>
      </div>
      <% } %>

      <!-- Progres Realisasi Pencacahan Muatan (Perhatian Utama) -->
      <% if (settings.overview_muatan === '1') { %>
      <div class="card" style="margin: 0; position: relative; overflow: hidden; background: var(--bg-card); border: 1px solid var(--border); padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
          <div style="display: flex; align-items: center; gap: 10px;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(6, 182, 212, 0.15); display: flex; align-items: center; justify-content: center; color: var(--accent-cyan); font-size: 20px;">
              <i class="bi bi-speedometer2"></i>
            </div>
            <div>
              <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text-primary);">Progres Realisasi Pencacahan Muatan</h3>
              <p style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-muted);">Realisasi Usaha Total vs Target Muatan Prelist (Fokus Utama Monitoring)</p>
            </div>
          </div>
          <div style="text-align: right;">
            <% let totalPct = summary.muatan_total ? (( (summary.usaha_total + summary.keluarga_total) / summary.muatan_total ) * 100).toFixed(2) : '0.00'; %>
            <div style="font-size: 22px; font-weight: 900; color: var(--accent-cyan);"><%= totalPct %>%</div>
            <div style="font-size: 10px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Capaian Muatan</div>
          </div>
        </div>

        <div style="position: relative; height: 28px; margin-top: 14px; margin-bottom: 14px;">
          <!-- Track & Progress Bar -->
          <div style="background: var(--bg-progress-wrap); height: 28px; border-radius: 14px; overflow: hidden; position: absolute; top: 0; left: 0; right: 0; bottom: 0; border: 1px solid var(--border); display: flex; align-items: center; padding: 0 4px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.15);">
            <div class="progress-bar" data-width="<%= totalPct %>" style="background: linear-gradient(90deg, var(--accent-blue) 0%, var(--accent-cyan) 100%); height: 20px; width: 0%; border-radius: 10px; transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; justify-content: flex-end; padding-right: 12px; box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.25);">
              <% if (parseFloat(totalPct) > 8) { %>
                <span style="font-size: 11px; font-weight: 800; color: #ffffff; text-shadow: 0 1px 2px rgba(0,0,0,0.5);"><%= totalPct %>%</span>
              <% } %>
            </div>
            <% if (parseFloat(totalPct) <= 8) { %>
              <span style="margin-left: 12px; font-size: 11px; font-weight: 800; color: var(--text-primary);"><%= totalPct %>%</span>
            <% } %>
          </div>

          <!-- Marker 25% (Juni) -->
          <div style="position: absolute; left: 25%; top: -3px; height: 34px; border-left: 2px dashed <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--border)' %>; z-index: 2; pointer-events: none;">
            <span style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); font-size: 8px; font-weight: 900; color: <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Target Juni: 25%</span>
          </div>

          <!-- Marker 50% (Juli) -->
          <div style="position: absolute; left: 50%; top: -3px; height: 34px; border-left: 2px dashed <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--border)' %>; z-index: 2; pointer-events: none;">
            <span style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); font-size: 8px; font-weight: 900; color: <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Target Juli: 50%</span>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
          <div>
            <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Realisasi</div>
            <div style="font-size: 15px; font-weight: 800; color: var(--text-primary);"><%= summary.usaha_total.toLocaleString('id-ID') %></div>
          </div>
          <div>
            <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Target</div>
            <div style="font-size: 15px; font-weight: 800; color: var(--text-primary);"><%= summary.muatan_total.toLocaleString('id-ID') %></div>
          </div>
          <div>
            <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Sisa</div>
            <div style="font-size: 15px; font-weight: 800; color: var(--accent-yellow);"><%= (summary.muatan_total - (summary.usaha_total + summary.keluarga_total)).toLocaleString('id-ID') %></div>
          </div>
        </div>

        <!-- Rincian Tambahan Pencacahan Muatan (Dikelompokkan Usaha/Keluarga) -->
        <div style="border-top: 1px dashed var(--border); padding-top: 16px; margin-top: 16px;">
          <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.5px;"><i class="bi bi-info-circle-fill text-cyan"></i> Detail Perubahan & Temuan Lapangan</div>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr)); gap: 16px;">
            
            <!-- KELOMPOK USAHA -->
            <div style="background: var(--bg-summary); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 12px;">
              <div style="font-size: 11px; font-weight: 800; color: var(--accent-cyan); text-transform: uppercase; margin-bottom: 10px; letter-spacing: 0.5px;"><i class="bi bi-briefcase-fill"></i> Temuan Sektor Usaha</div>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                
                <!-- Usaha Baru -->
                <div style="background: rgba(16, 185, 129, 0.04); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">USAHA BARU</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Terdaftar baru</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-green);">+<%= summary.usaha_baru.toLocaleString('id-ID') %></div>
                </div>

                <!-- Usaha Tutup -->
                <div style="background: rgba(239, 68, 68, 0.04); border: 1px solid rgba(239, 68, 68, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">USAHA TUTUP</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Tutup/Pindah</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-red);"><%= summary.usaha_tutup.toLocaleString('id-ID') %></div>
                </div>

                <!-- Usaha Tidak Ditemukan -->
                <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">TDK DITEMUKAN</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Tidak ada fisik</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--text-primary);"><%= summary.usaha_tidak_ditemukan.toLocaleString('id-ID') %></div>
                </div>

                <!-- Usaha Ganda (Sinyal Kualitas Data) -->
                <div style="background: rgba(239, 68, 68, 0.04); border: 1px solid rgba(239, 68, 68, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">USAHA GANDA</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Teridentifikasi ganda</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-red);"><%= (summary.usaha_ganda || 0).toLocaleString('id-ID') %></div>
                </div>

              </div>
            </div>

            <!-- KELOMPOK KELUARGA -->
            <div style="background: var(--bg-summary); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 12px;">
              <div style="font-size: 11px; font-weight: 800; color: var(--accent-purple); text-transform: uppercase; margin-bottom: 10px; letter-spacing: 0.5px;"><i class="bi bi-people-fill"></i> Temuan Sektor Keluarga</div>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                
                <!-- Total Keluarga Ditemukan -->
                <div style="background: rgba(168, 85, 247, 0.04); border: 1px solid rgba(168, 85, 247, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">KK DITEMUKAN</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Total ditemukan</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-purple);"><%= summary.keluarga_total.toLocaleString('id-ID') %></div>
                </div>

                <!-- Keluarga Baru -->
                <div style="background: rgba(6, 182, 212, 0.04); border: 1px solid rgba(6, 182, 212, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">KELUARGA BARU</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Terdaftar baru</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-cyan);">+<%= summary.keluarga_baru.toLocaleString('id-ID') %></div>
                </div>

                <!-- Meninggal -->
                <div style="background: rgba(245, 158, 11, 0.04); border: 1px solid rgba(245, 158, 11, 0.15); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">MENINGGAL</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Anggota KK</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--accent-yellow);"><%= summary.meninggal.toLocaleString('id-ID') %></div>
                </div>

                <!-- Keluarga Tidak Ditemukan -->
                <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; gap: 4px;">
                  <div>
                    <div style="font-size: 8px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">TDK DITEMUKAN</div>
                    <div style="font-size: 9px; color: var(--text-secondary); line-height: 1.2;">Tidak ditemukan</div>
                  </div>
                  <div style="font-size: 13px; font-weight: 800; color: var(--text-primary);"><%= summary.keluarga_tidak_ditemukan.toLocaleString('id-ID') %></div>
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- TREN CHARTS GRID -->
    <% if (settings.overview_tren_muatan === '1' || settings.overview_tren_fasih === '1') { %>
    <div class="trend-charts-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 480px), 1fr)); gap: 20px; margin-top: 24px;">
      
      <!-- TREN HARIAN MUATAN -->
      <% if (settings.overview_tren_muatan === '1') { %>
      <div class="card" style="margin: 0;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-calendar3"></i> Tren Progres Pengumpulan Data (Muatan)</div>
        </div>
        <div style="height: 300px; position: relative;">
          <canvas id="trenChartCanvas"></canvas>
        </div>
      </div>
      <% } %>

      <!-- TREN HARIAN FASIH -->
      <% if (settings.overview_tren_fasih === '1') { %>
      <div class="card" style="margin: 0;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-phone"></i> Tren Progres Status Dokumen FASIH</div>
        </div>
        <div style="height: 300px; position: relative;">
          <canvas id="trenFasihChartCanvas"></canvas>
        </div>
      </div>
      <% } %>

    </div>
    <% } %>

    <!-- BOTTOM ROW: KECAMATAN DETAILS -->
    <% if (settings.overview_kecamatan === '1') { %>
    <div class="card mt-4">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-geo-alt"></i> Ringkasan Progres per Kecamatan</div>
        <a href="/kecamatan" class="btn btn-secondary btn-sm">Rincian Kecamatan <i class="bi bi-arrow-right-short"></i></a>
      </div>

      <div class="search-wrap mb-4" style="margin-bottom: 16px;">
        <input type="search" id="kecOverviewSearch" placeholder="Cari kecamatan..." aria-label="Cari nama kecamatan" style="width: 100%; max-width: 280px;">
      </div>

      <div class="comparison-grid">
        
        <div class="table-wrap">
          <!-- Desktop Table (visible on desktop only) -->
          <table id="kecOverviewTable" class="hide-sm">
            <thead>
              <tr>
                <th rowspan="2" scope="col">Kecamatan</th>
                <th colspan="2" class="text-center" scope="colgroup" style="border-bottom: 1px solid var(--border);">SubSLS</th>
                <th colspan="3" class="text-center bg-purple-soft" scope="colgroup" style="border-bottom: 1px solid var(--border);">Assignment FASIH</th>
                <th colspan="4" class="text-center bg-cyan-soft" scope="colgroup" style="border-bottom: 1px solid var(--border);">Beban Muatan</th>
              </tr>
              <tr>
                <th scope="col" class="text-right">Total</th>
                <th scope="col" class="text-right">Selesai</th>
                <th scope="col" class="text-right bg-purple-soft">Approved</th>
                <th scope="col" class="text-right bg-purple-soft">Target</th>
                <th scope="col" class="text-right bg-purple-soft">Progres %</th>
                <th scope="col" class="text-right bg-cyan-soft">Usaha Total</th>
                <th scope="col" class="text-right bg-cyan-soft">Target Muatan</th>
                <th scope="col" class="text-right bg-cyan-soft">Progres %</th>
                <th scope="col" class="text-right bg-cyan-soft">Keluarga Total</th>
              </tr>
            </thead>
            <tbody>
              <% kecStats.forEach(k => { %>
                <% let fasihPct = k.target_fasih_total ? ((( (k.submitted_total || 0) + (k.approved_total || 0) + (k.rejected_total || 0) ) / k.target_fasih_total) * 100).toFixed(2) : '0.00'; %>
                <% let muatanPct = k.total_muatan ? (( (k.usaha_total + k.keluarga_total) / k.total_muatan ) * 100).toFixed(2) : '0.00'; %>
                <tr>
                  <td class="td-primary" scope="row"><a href="/kecamatan?kec=<%= encodeURIComponent(k.kecamatan) %>" style="color: inherit; text-decoration: none;"><i class="bi bi-geo-alt"></i> <%= k.kecamatan %></a></td>
                  <td class="text-right" data-sort="<%= k.total_subsls %>"><%= k.total_subsls %></td>
                  <td class="text-right fw-bold" data-sort="<%= k.selesai %>"><%= k.selesai %></td>
                  <td class="text-right bg-purple-soft" data-sort="<%= k.approved_total || 0 %>"><%= (k.approved_total || 0).toLocaleString('id-ID') %></td>
                  <td class="text-right bg-purple-soft" data-sort="<%= k.target_fasih_total || 0 %>"><%= (k.target_fasih_total || 0).toLocaleString('id-ID') %></td>
                  <td class="text-right bg-purple-soft" data-sort="<%= parseFloat(fasihPct) %>">
                    <% if (parseFloat(fasihPct) >= 100) { %>
                      <span class="badge badge-green">100%</span>
                    <% } else if (parseFloat(fasihPct) < 25) { %>
                      <span class="badge badge-red"><%= fasihPct %>%</span>
                    <% } else { %>
                      <span class="badge badge-blue"><%= fasihPct %>%</span>
                    <% } %>
                  </td>
                  <td class="text-right fw-bold bg-cyan-soft" data-sort="<%= k.usaha_total %>"><%= k.usaha_total.toLocaleString('id-ID') %></td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= k.total_muatan %>"><%= k.total_muatan.toLocaleString('id-ID') %></td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= parseFloat(muatanPct) %>">
                    <% if (parseFloat(muatanPct) >= 100) { %>
                      <span class="badge badge-green">100%</span>
                    <% } else if (parseFloat(muatanPct) < activeTargetPct) { %>
                      <span class="badge badge-red"><%= muatanPct %>%</span>
                    <% } else { %>
                      <span class="badge badge-blue"><%= muatanPct %>%</span>
                    <% } %>
                  </td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= k.keluarga_total %>"><%= k.keluarga_total.toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <!-- Mobile Table (visible on mobile only) -->
          <table id="kecOverviewTableMobile" class="show-sm-table">
            <thead>
              <tr>
                <th scope="col">Kecamatan</th>
                <th class="text-right" scope="col">Total SLS</th>
                <th class="text-right" scope="col">Selesai</th>
                <th class="text-right bg-purple-soft" scope="col">FASIH %</th>
                <th class="text-right bg-cyan-soft" scope="col">Muatan %</th>
              </tr>
            </thead>
            <tbody>
              <% kecStats.forEach(k => { %>
                <% let fasihPct = k.target_fasih_total ? ((( (k.submitted_total || 0) + (k.approved_total || 0) + (k.rejected_total || 0) ) / k.target_fasih_total) * 100).toFixed(2) : '0.00'; %>
                <% let muatanPct = k.total_muatan ? (( (k.usaha_total + k.keluarga_total) / k.total_muatan ) * 100).toFixed(2) : '0.00'; %>
                <tr>
                  <td class="td-primary" scope="row"><a href="/kecamatan?kec=<%= encodeURIComponent(k.kecamatan) %>" style="color: inherit; text-decoration: none;"><i class="bi bi-geo-alt"></i> <%= k.kecamatan %></a></td>
                  <td class="text-right" data-sort="<%= k.total_subsls %>"><%= k.total_subsls %></td>
                  <td class="text-right fw-bold" data-sort="<%= k.selesai %>"><%= k.selesai %></td>
                  <td class="text-right bg-purple-soft" data-sort="<%= parseFloat(fasihPct) %>">
                    <% if (parseFloat(fasihPct) >= 100) { %>
                      <span class="badge badge-green">100%</span>
                    <% } else if (parseFloat(fasihPct) < 25) { %>
                      <span class="badge badge-red"><%= fasihPct %>%</span>
                    <% } else { %>
                      <span class="badge badge-blue"><%= fasihPct %>%</span>
                    <% } %>
                  </td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= parseFloat(muatanPct) %>">
                    <% if (parseFloat(muatanPct) >= 100) { %>
                      <span class="badge badge-green">100%</span>
                    <% } else if (parseFloat(muatanPct) < activeTargetPct) { %>
                      <span class="badge badge-red"><%= muatanPct %>%</span>
                    <% } else { %>
                      <span class="badge badge-blue"><%= muatanPct %>%</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div style="height: 280px; position: relative; margin-top: 16px;">
          <canvas id="kecBarChartCanvas"></canvas>
        </div>

      </div>
    </div>
    <% } %>

    <!-- DETAILS HOUSING / RUMAH -->
    <% if (settings.overview_bangunan === '1') { %>
    <div class="card mt-4">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-house-door"></i> Klasifikasi Tipe Bangunan Tinggal</div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 150px), 1fr)); gap: 12px;">

        <div class="bangunan-card">
          <div class="bangunan-img-wrap">
            <picture style="display: block;">
              <source srcset="/images/bangunan_tunggal.webp" type="image/webp">
              <img src="/images/bangunan_tunggal.png" alt="Rumah Tunggal" class="bangunan-img">
            </picture>
          </div>
          <div class="bangunan-label">Rumah Tunggal</div>
          <div class="bangunan-value"><%= (summary.rumah_tunggal || 0).toLocaleString('id-ID') %></div>
          <div class="bangunan-sub">Bangunan mandiri tunggal</div>
        </div>

        <div class="bangunan-card">
          <div class="bangunan-img-wrap">
            <picture style="display: block;">
              <source srcset="/images/bangunan_deret.webp" type="image/webp">
              <img src="/images/bangunan_deret.png" alt="Rumah Deret" class="bangunan-img">
            </picture>
          </div>
          <div class="bangunan-label">Rumah Deret</div>
          <div class="bangunan-value"><%= (summary.rumah_deret || 0).toLocaleString('id-ID') %></div>
          <div class="bangunan-sub">Bangunan gandeng/berbaris</div>
        </div>

        <div class="bangunan-card">
          <div class="bangunan-img-wrap">
            <picture style="display: block;">
              <source srcset="/images/bangunan_susun.webp" type="image/webp">
              <img src="/images/bangunan_susun.png" alt="Rumah Susun" class="bangunan-img">
            </picture>
          </div>
          <div class="bangunan-label">Rumah Susun</div>
          <div class="bangunan-value"><%= (summary.rumah_susun || 0).toLocaleString('id-ID') %></div>
          <div class="bangunan-sub">Rusun sederhana</div>
        </div>

        <div class="bangunan-card">
          <div class="bangunan-img-wrap">
            <picture style="display: block;">
              <source srcset="/images/bangunan_apartemen.webp" type="image/webp">
              <img src="/images/bangunan_apartemen.png" alt="Apartemen" class="bangunan-img">
            </picture>
          </div>
          <div class="bangunan-label">Apartemen</div>
          <div class="bangunan-value"><%= (summary.apartemen || 0).toLocaleString('id-ID') %></div>
          <div class="bangunan-sub">Kondominium / apartemen</div>
        </div>

        <div class="bangunan-card">
          <div class="bangunan-img-wrap">
            <picture style="display: block;">
              <source srcset="/images/bangunan_lainnya.webp" type="image/webp">
              <img src="/images/bangunan_lainnya.png" alt="Lainnya" class="bangunan-img">
            </picture>
          </div>
          <div class="bangunan-label">Lainnya</div>
          <div class="bangunan-value"><%= (summary.lainnya || 0).toLocaleString('id-ID') %></div>
          <div class="bangunan-sub">Ruko, mes, kontainer, dll.</div>
        </div>

      </div>
    </div>
    <% } %>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    <% if (summary) { %>
      const rawTrenData = <%- tren %>;
      
      // Initialize tren line chart
      <% if (settings.overview_tren_muatan === '1') { %>
      createTrenChart('trenChartCanvas', rawTrenData);
      <% } %>

      // Initialize FASIH assignment trend line chart
      <% if (settings.overview_tren_fasih === '1') { %>
      createFasihTrenChart('trenFasihChartCanvas', rawTrenData);
      <% } %>

      // Initialize kecamatan comparison bar chart
      <% if (settings.overview_kecamatan === '1') { %>
      const kecLabels = [];
      const kecSelesai = [];
      const kecTotal = [];
      <% kecStats.forEach(k => { %>
        kecLabels.push("<%= k.kecamatan %>");
        kecSelesai.push(<%= k.usaha_total %>);
        kecTotal.push(<%= k.total_muatan %>);
      <% }) %>

      createBarChart('kecBarChartCanvas', kecLabels, kecSelesai, kecTotal, 'Progres Per Kecamatan (Muatan)');

      // Initialize table sorting and searching
      makeTableSortable('kecOverviewTable');
      makeTableSearchable('kecOverviewSearch', 'kecOverviewTable');
      makeTableSortable('kecOverviewTableMobile');
      makeTableSearchable('kecOverviewSearch', 'kecOverviewTableMobile');
      <% } %>
    <% } %>
  });
</script>
