<div class="fade-in">
  <style>
    /* Premium switch styling */
    .settings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
      gap: 20px;
      margin-bottom: 24px;
    }
    .settings-group {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px;
      box-shadow: var(--shadow);
    }
    .settings-group-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .settings-group-title i {
      color: var(--accent-blue);
    }
    
    .switch-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.015);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      margin-bottom: 10px;
      transition: var(--transition);
    }
    body.light-mode .switch-item {
      background: rgba(0, 0, 0, 0.01);
    }
    .switch-item:hover {
      background: rgba(255, 255, 255, 0.035);
      border-color: var(--border-light);
    }
    body.light-mode .switch-item:hover {
      background: rgba(0, 0, 0, 0.02);
    }
    
    .switch-info {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .switch-icon {
      font-size: 18px;
      color: var(--accent-cyan);
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }
    .switch-label-text {
      font-weight: 600;
      font-size: 13px;
      color: var(--text-primary);
      cursor: pointer;
    }
    .switch-desc {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    /* Toggle switch checkbox design */
    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
      flex-shrink: 0;
    }
    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    .toggle-slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: var(--border-light);
      transition: .3s;
      border-radius: 24px;
    }
    .toggle-slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background-color: var(--text-primary);
      transition: .3s;
      border-radius: 50%;
    }
    .toggle-switch input:checked + .toggle-slider {
      background-color: var(--accent-blue);
    }
    .toggle-switch input:checked + .toggle-slider:before {
      transform: translateX(20px);
    }
    .settings-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
    }
    .settings-field label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-secondary);
    }
    .settings-field input,
    .settings-field select {
      width: 100%;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      color: var(--text-primary);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      font-size: 13px;
      outline: none;
      transition: var(--transition);
    }
    .settings-field input:focus,
    .settings-field select:focus {
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 2px rgba(var(--accent-rgb), 0.14);
    }
    .settings-hint {
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.45;
    }
  </style>

  <div class="card">
    <div class="card-header">
      <div class="card-title">
        <span><i class="bi bi-sliders"></i> Pengaturan Tampilan Dashboard &amp; Fitur</span>
      </div>
    </div>
    
    <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.5;">
      Atur visibilitas halaman pada menu navigasi dan aktifkan pembatasan akses langsung (route guard). Anda juga dapat menentukan widget mana saja yang tampil pada halaman Overview.
    </p>

    <form action="/admin/settings" method="POST">
      <div class="settings-grid">
        
        <!-- GROUP 1: MENU NAVIGASI & FITUR -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="bi bi-layout-sidebar-inset"></i> Menu Navigasi &amp; Halaman
          </div>
          
          <!-- Peta Progres -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-map"></i></span>
              <div style="min-width: 0;">
                <label for="page_map" class="switch-label-text">Peta Progres</label>
                <div class="switch-desc">Halaman visualisasi peta wilayah</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_map" name="page_map" value="1" <%= settings.page_map === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Early Warning -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-exclamation-octagon"></i></span>
              <div style="min-width: 0;">
                <label for="page_earlywarning" class="switch-label-text">Early Warning</label>
                <div class="switch-desc">Halaman peringatan dini pencapaian</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_earlywarning" name="page_earlywarning" value="1" <%= settings.page_earlywarning === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Deteksi Anomali -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-shield-exclamation"></i></span>
              <div style="min-width: 0;">
                <label for="page_deteksianomali" class="switch-label-text">Deteksi Anomali</label>
                <div class="switch-desc">Halaman kualitas dan anomali data</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_deteksianomali" name="page_deteksianomali" value="1" <%= settings.page_deteksianomali === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Performa Terbaik (Leaderboard) -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-trophy"></i></span>
              <div style="min-width: 0;">
                <label for="page_leaderboard" class="switch-label-text">Performa Terbaik</label>
                <div class="switch-desc">Leaderboard pencapaian tertinggi</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_leaderboard" name="page_leaderboard" value="1" <%= settings.page_leaderboard === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Performa Terendah -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-graph-down"></i></span>
              <div style="min-width: 0;">
                <label for="page_performatrendah" class="switch-label-text">Performa Terendah</label>
                <div class="switch-desc">Analisis petugas performa rendah</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_performatrendah" name="page_performatrendah" value="1" <%= settings.page_performatrendah === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Per Kecamatan -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-geo-alt"></i></span>
              <div style="min-width: 0;">
                <label for="page_kecamatan" class="switch-label-text">Per Kecamatan</label>
                <div class="switch-desc">Drilldown wilayah kecamatan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_kecamatan" name="page_kecamatan" value="1" <%= settings.page_kecamatan === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Per SubSLS -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-box-seam"></i></span>
              <div style="min-width: 0;">
                <label for="page_subsls" class="switch-label-text">Per SubSLS</label>
                <div class="switch-desc">Rincian status per satuan lokal</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_subsls" name="page_subsls" value="1" <%= settings.page_subsls === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Per Korlap -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-person-workspace"></i></span>
              <div style="min-width: 0;">
                <label for="page_korlap" class="switch-label-text">Per Korlap</label>
                <div class="switch-desc">Drilldown Koordinator Lapangan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_korlap" name="page_korlap" value="1" <%= settings.page_korlap === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Per PML -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-clipboard2-data"></i></span>
              <div style="min-width: 0;">
                <label for="page_pml" class="switch-label-text">Per PML</label>
                <div class="switch-desc">Drilldown Pengawas Lapangan PML</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_pml" name="page_pml" value="1" <%= settings.page_pml === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Per PCL -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-person-gear"></i></span>
              <div style="min-width: 0;">
                <label for="page_pcl" class="switch-label-text">Per PCL</label>
                <div class="switch-desc">Drilldown Petugas Pencacah PCL</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_pcl" name="page_pcl" value="1" <%= settings.page_pcl === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Export CSV -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-download"></i></span>
              <div style="min-width: 0;">
                <label for="page_export" class="switch-label-text">Export CSV</label>
                <div class="switch-desc">Ekspor data ke format CSV</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_export" name="page_export" value="1" <%= settings.page_export === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Asisten AI Chat -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-robot"></i></span>
              <div style="min-width: 0;">
                <label for="page_aiagent" class="switch-label-text">Asisten AI Chat</label>
                <div class="switch-desc">Fitur analisis &amp; tanya jawab AI</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="page_aiagent" name="page_aiagent" value="1" <%= settings.page_aiagent === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

        </div>

        <!-- GROUP 2: KONFIGURASI AI AGENT -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="bi bi-cpu"></i> Konfigurasi AI Agent
          </div>

          <div class="settings-field">
            <label for="agent_provider">Provider Aktif</label>
            <select id="agent_provider" name="agent_provider">
              <option value="gemini" <%= settings.agent_provider !== 'openai' ? 'selected' : '' %>>Google Gemini</option>
              <option value="openai" <%= settings.agent_provider === 'openai' ? 'selected' : '' %>>OpenAI</option>
            </select>
            <div class="settings-hint">Provider ini yang digunakan oleh chat agent di halaman /agent.</div>
          </div>

          <div class="settings-field">
            <label for="gemini_api_key">Gemini API Key</label>
            <input type="password" id="gemini_api_key" name="gemini_api_key" value="<%= settings.gemini_api_key || '' %>" autocomplete="off" placeholder="Masukkan Gemini API key">
          </div>

          <div class="settings-field">
            <label for="gemini_model">Gemini Model</label>
            <input type="text" id="gemini_model" name="gemini_model" value="<%= settings.gemini_model || 'gemini-2.5-flash' %>" placeholder="gemini-2.5-flash">
          </div>

          <div class="settings-field">
            <label for="openai_api_key">OpenAI API Key</label>
            <input type="password" id="openai_api_key" name="openai_api_key" value="<%= settings.openai_api_key || '' %>" autocomplete="off" placeholder="Masukkan OpenAI API key">
          </div>

          <div class="settings-field">
            <label for="openai_model">OpenAI Model</label>
            <input type="text" id="openai_model" name="openai_model" value="<%= settings.openai_model || 'gpt-5.5' %>" placeholder="gpt-5.5">
            <div class="settings-hint">Kosongkan API key provider yang tidak dipakai bila ingin memaksa mode simulasi.</div>
          </div>
        </div>

        <!-- GROUP 3: KONTEN OVERVIEW -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="bi bi-speedometer2"></i> Konten Dashboard Overview
          </div>

          <!-- Card Assignment FASIH -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon" style="color: var(--accent-purple);"><i class="bi bi-phone"></i></span>
              <div style="min-width: 0;">
                <label for="overview_fasih" class="switch-label-text">Widget Assignment FASIH</label>
                <div class="switch-desc">Realisasi Approved vs Target FASIH</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_fasih" name="overview_fasih" value="1" <%= settings.overview_fasih === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Card Progres Realisasi Pencacahan Muatan -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon" style="color: var(--accent-cyan);"><i class="bi bi-speedometer2"></i></span>
              <div style="min-width: 0;">
                <label for="overview_muatan" class="switch-label-text">Widget Realisasi Muatan</label>
                <div class="switch-desc">Realisasi Usaha vs Target Muatan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_muatan" name="overview_muatan" value="1" <%= settings.overview_muatan === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Tren Harian Muatan -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-graph-up-arrow"></i></span>
              <div style="min-width: 0;">
                <label for="overview_tren_muatan" class="switch-label-text">Grafik Tren Muatan</label>
                <div class="switch-desc">Garis tren pengumpulan data muatan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_tren_muatan" name="overview_tren_muatan" value="1" <%= settings.overview_tren_muatan === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Tren Harian FASIH -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon" style="color: var(--accent-purple);"><i class="bi bi-graph-up"></i></span>
              <div style="min-width: 0;">
                <label for="overview_tren_fasih" class="switch-label-text">Grafik Tren FASIH</label>
                <div class="switch-desc">Garis tren progres status FASIH</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_tren_fasih" name="overview_tren_fasih" value="1" <%= settings.overview_tren_fasih === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Ringkasan Progres per Kecamatan -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-geo-alt"></i></span>
              <div style="min-width: 0;">
                <label for="overview_kecamatan" class="switch-label-text">Ringkasan per Kecamatan</label>
                <div class="switch-desc">Tabel ringkasan &amp; chart kecamatan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_kecamatan" name="overview_kecamatan" value="1" <%= settings.overview_kecamatan === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <!-- Klasifikasi Tipe Bangunan Tinggal -->
          <div class="switch-item">
            <div class="switch-info">
              <span class="switch-icon"><i class="bi bi-house-door"></i></span>
              <div style="min-width: 0;">
                <label for="overview_bangunan" class="switch-label-text">Klasifikasi Tipe Bangunan</label>
                <div class="switch-desc">Klasifikasi bangunan tinggal lapangan</div>
              </div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="overview_bangunan" name="overview_bangunan" value="1" <%= settings.overview_bangunan === '1' ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>

        </div>

      </div>

      <div style="display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--border); padding-top: 20px;">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-save-fill"></i> Simpan Pengaturan
        </button>
      </div>
    </form>
  </div>
</div>
