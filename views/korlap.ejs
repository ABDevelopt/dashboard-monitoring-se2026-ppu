<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>

    <!-- TWO-COLUMN GRID FOR DRILLDOWN -->
    <div class="drilldown-grid mt-4">
      
      <!-- KORLAP LIST TABLE -->
      <div class="card" style="margin-bottom: 0;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-person-workspace"></i> Progres Kinerja per Korlap (Koordinator Lapangan)</div>
          <span class="badge badge-blue"><%= korlapStats.length %> Korlap</span>
        </div>

        <div class="search-wrap mb-4" style="max-width: 300px;">
          <input type="search" id="korlapSearch" placeholder="Cari nama Korlap...">
        </div>

        <% if (korlapStats && korlapStats.length > 0) { %>
          <div class="table-wrap" style="max-height: 600px; overflow-y: auto;">
            <table id="korlapTable">
              <thead>
                <tr>
                  <th>Nama Korlap</th>
                  <th class="text-right">Jumlah PML</th>
                  <th class="text-right">Jumlah PCL</th>
                  <th class="text-right">SubSLS</th>
                  <th class="text-right">Selesai</th>
                  <th class="text-right">Progres %</th>
                  <th class="text-right">Total Usaha</th>
                  <th class="text-right">Total Keluarga</th>
                </tr>
              </thead>
              <tbody>
                <% korlapStats.forEach(k => { %>
                  <% let completionPct = k.total_subsls ? Math.round((k.selesai / k.total_subsls) * 100) : 0; %>
                  <tr class="<%= filterKorlap === k.korlap ? 'active' : '' %>" style="<%= filterKorlap === k.korlap ? 'background: var(--bg-card-hover); font-weight: 500;' : '' %>">
                    <td class="td-primary">
                      <a href="/korlap?korlap=<%= encodeURIComponent(k.korlap) %>" style="color: inherit; text-decoration: none; display: block;">
                        <i class="bi bi-person-workspace"></i> <%= k.korlap %>
                      </a>
                    </td>
                    <td class="text-right" data-sort="<%= k.jumlah_pml %>"><%= k.jumlah_pml %> PML</td>
                    <td class="text-right" data-sort="<%= k.jumlah_pcl %>"><%= k.jumlah_pcl %> PCL</td>
                    <td class="text-right" data-sort="<%= k.total_subsls %>"><%= k.total_subsls %></td>
                    <td class="text-right fw-bold" data-sort="<%= k.selesai %>" style="<%= k.selesai === 0 ? 'color: var(--accent-red)' : '' %>"><%= k.selesai %></td>
                    <td class="text-right" data-sort="<%= completionPct %>">
                      <% if (completionPct === 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (completionPct === 0) { %>
                        <span class="badge badge-red">0%</span>
                      <% } else if (completionPct < 25) { %>
                        <span class="badge badge-yellow"><%= completionPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= completionPct %>%</span>
                      <% } %>
                    </td>
                    <td class="text-right fw-bold td-primary" data-sort="<%= k.usaha_total %>"><%= k.usaha_total.toLocaleString('id-ID') %></td>
                    <td class="text-right fw-bold" data-sort="<%= k.keluarga_total %>"><%= k.keluarga_total.toLocaleString('id-ID') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="no-data">Tidak ada Korlap yang cocok.</div>
        <% } %>
      </div>

      <!-- KORLAP'S PML TEAM DETAILS -->
      <div>
        <% if (filterKorlap) { %>
          <div class="card" style="margin-bottom: 0; position: sticky; top: 80px;">
            <div class="card-header">
              <div class="card-title"><i class="bi bi-clipboard2-data"></i> Anggota Tim PML: <%= filterKorlap %></div>
              <a href="/korlap" class="btn btn-secondary btn-xs"><i class="bi bi-x-lg"></i> Tutup</a>
            </div>

            <% if (detailData && detailData.length > 0) { %>
              <div class="mb-4">
                <% 
                  let totalBeban = detailData.reduce((acc, c) => acc + c.total_subsls, 0);
                  let totalSelesai = detailData.reduce((acc, c) => acc + c.selesai, 0);
                  let totalPct = totalBeban ? ((totalSelesai / totalBeban) * 100).toFixed(1) : 0;
                %>
                <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px;">
                  <span>Progres Tim Korlap</span>
                  <span class="fw-bold"><%= totalSelesai %> / <%= totalBeban %> selesai (<%= totalPct %>%)</span>
                </div>
                <div class="progress-bar-wrap">
                  <div class="progress-bar <%= totalPct == 100 ? 'green' : (totalPct < 25 ? 'red' : 'blue') %>" data-width="<%= totalPct %>" style="width: 0%;"></div>
                </div>
              </div>

              <div class="search-wrap mb-4" style="max-width: 100%; margin-bottom: 12px;">
                <input type="search" id="detailPmlSearch" placeholder="Cari nama PML dalam tim...">
              </div>

              <div id="detailPmlList" style="max-height: 420px; overflow-y: auto; padding-right: 4px;">
                <% detailData.forEach(item => { %>
                  <% let itemPct = item.total_subsls ? Math.round((item.selesai / item.total_subsls) * 100) : 0; %>
                  <div class="detail-item">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                      <a href="/pml?pml=<%= encodeURIComponent(item.pml) %>" class="fw-bold" style="color: var(--accent-cyan); text-decoration: none;">
                        <i class="bi bi-clipboard2-data"></i> <%= item.pml %>
                      </a>
                      <% if (itemPct === 100) { %>
                        <span class="badge badge-green btn-xs">100%</span>
                      <% } else if (itemPct === 0) { %>
                        <span class="badge badge-red btn-xs">0%</span>
                      <% } else { %>
                        <span class="badge badge-blue btn-xs"><%= itemPct %>%</span>
                      <% } %>
                    </div>
                    <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">
                      SubSLS: <strong><%= item.selesai %> / <%= item.total_subsls %></strong> Selesai · PCL: <strong><%= item.jumlah_pcl %> Orang</strong>
                    </div>
                    <div style="display: flex; gap: 8px; margin-top: 6px; font-size: 11px;">
                      <span style="background: rgba(16,185,129,0.1); padding: 2px 8px; border-radius: 4px; color: var(--accent-green);"><i class="bi bi-building"></i> <%= item.usaha_total %> Usaha</span>
                      <span style="background: rgba(6,182,212,0.1); padding: 2px 8px; border-radius: 4px; color: var(--accent-cyan);"><i class="bi bi-people"></i> <%= item.keluarga_total %> Keluarga</span>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="no-data">Tidak ada detail PML.</div>
            <% } %>
          </div>
        <% } else { %>
          <div class="card empty-state text-center" style="height: 100%; min-height: 300px; display: flex; flex-direction: column; justify-content: center; border-style: dashed;">
            <div class="empty-state-icon"><i class="bi bi-arrow-left-circle"></i></div>
            <div class="empty-state-title">Pilih Korlap</div>
            <div class="empty-state-text">Klik nama Korlap di tabel sebelah kiri untuk melihat rincian PML yang diawasi beserta progres kinerjanya.</div>
          </div>
        <% } %>
      </div>

    </div>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    makeTableSortable('korlapTable');
    makeTableSearchable('korlapSearch', 'korlapTable');
    <% if (filterKorlap) { %>
      makeListSearchable('detailPmlSearch', 'detailPmlList', '.detail-item');
    <% } %>
  });
</script>
