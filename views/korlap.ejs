<%
  let activeTargetPct = 25;
  let targetMonthName = 'Juni';
  const currentMonth = new Date().getMonth(); // 5 = Juni, 6 = Juli
  if (currentMonth === 6) { // Juli
    activeTargetPct = 50;
    targetMonthName = 'Juli';
  }
%>
<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>

    <!-- TWO-COLUMN GRID FOR DRILLDOWN -->
    <div class="drilldown-grid mt-4">
      
      <!-- KORLAP LIST TABLE -->
      <div class="card" style="margin-bottom: 0;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-person-workspace"></i> Progres Kinerja per Korlap (Koordinator Lapangan)</div>
          <span class="badge badge-blue"><%= korlapStats.length %> Korlap</span>
        </div>

        <div class="search-wrap mb-4">
          <input type="search" id="korlapSearch" placeholder="Cari nama Korlap..." aria-label="Cari nama Koordinator Lapangan Korlap" style="width: 100%; max-width: 280px;">
        </div>

        <% if (korlapStats && korlapStats.length > 0) { %>
          <div class="table-wrap" style="max-height: 600px; overflow-y: auto; overflow-x: auto;">
            <table id="korlapTable">
              <thead class="hide-sm">
                <tr>
                  <th rowspan="2">Nama Korlap</th>
                  <th rowspan="2" class="text-right">Jumlah PML</th>
                  <th rowspan="2" class="text-right">Jumlah PCL</th>
                  <th colspan="2" class="text-center" style="border-bottom: 1px solid var(--border);">SubSLS</th>
                  <th colspan="3" class="text-center bg-purple-soft" style="border-bottom: 1px solid var(--border);">Assignment FASIH</th>
                  <th colspan="3" class="text-center bg-cyan-soft" style="border-bottom: 1px solid var(--border);">Beban Muatan</th>
                </tr>
                <tr>
                  <th class="text-right">Total</th>
                  <th class="text-right">Selesai</th>
                  <th class="text-right bg-purple-soft">Approved</th>
                  <th class="text-right bg-purple-soft">Target</th>
                  <th class="text-right bg-purple-soft">Progres %</th>
                  <th class="text-right bg-cyan-soft">Usaha Total</th>
                  <th class="text-right bg-cyan-soft">Target Muatan</th>
                  <th class="text-right bg-cyan-soft">Progres %</th>
                </tr>
              </thead>
              <thead class="show-sm-table-header">
                <tr>
                  <th>Nama Korlap</th>
                  <th class="text-right">Selesai</th>
                  <th class="text-right bg-purple-soft">FASIH %</th>
                  <th class="text-right bg-cyan-soft">Muatan %</th>
                </tr>
              </thead>
              <tbody>
                <% korlapStats.forEach(k => { %>
                  <% let fasihPct = k.target_fasih_total ? ((( (k.submitted_total || 0) + (k.approved_total || 0) + (k.rejected_total || 0) ) / k.target_fasih_total) * 100).toFixed(2) : '0.00'; %>
                  <% let muatanPct = k.total_muatan ? (( (k.usaha_total + k.keluarga_total) / k.total_muatan ) * 100).toFixed(2) : '0.00'; %>
                  <tr class="<%= filterKorlap === k.korlap ? 'active' : '' %>" style="<%= filterKorlap === k.korlap ? 'background: var(--bg-card-hover); font-weight: 500;' : '' %>">
                    <td class="td-primary">
                      <a href="/korlap?korlap=<%= encodeURIComponent(k.korlap) %>" style="color: inherit; text-decoration: none; display: block;">
                        <i class="bi bi-person-workspace"></i> <%= k.korlap %>
                      </a>
                    </td>
                    <td class="text-right hide-sm" data-sort="<%= k.jumlah_pml %>"><%= k.jumlah_pml %> PML</td>
                    <td class="text-right hide-sm" data-sort="<%= k.jumlah_pcl %>"><%= k.jumlah_pcl %> PCL</td>
                    <td class="text-right hide-sm" data-sort="<%= k.total_subsls %>"><%= k.total_subsls %></td>
                    <td class="text-right fw-bold" data-sort="<%= k.selesai %>" style="<%= k.selesai === 0 ? 'color: var(--accent-red)' : '' %>"><%= k.selesai %></td>
                    <td class="text-right bg-purple-soft hide-sm" data-sort="<%= k.approved_total %>"><%= (k.approved_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-purple-soft hide-sm" data-sort="<%= k.target_fasih_total %>"><%= (k.target_fasih_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-purple-soft" data-sort="<%= parseFloat(fasihPct) %>">
                      <% if (parseFloat(fasihPct) >= 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (parseFloat(fasihPct) < 25) { %>
                        <span class="badge badge-red"><%= fasihPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= fasihPct %>%</span>
                      <% } %>
                    </td>
                    <td class="text-right fw-bold bg-cyan-soft hide-sm" data-sort="<%= k.usaha_total %>"><%= k.usaha_total.toLocaleString('id-ID') %></td>
                    <td class="text-right bg-cyan-soft hide-sm" data-sort="<%= k.total_muatan %>"><%= k.total_muatan.toLocaleString('id-ID') %></td>
                    <td class="text-right bg-cyan-soft" data-sort="<%= parseFloat(muatanPct) %>">
                      <% if (parseFloat(muatanPct) >= 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (parseFloat(muatanPct) < activeTargetPct) { %>
                        <span class="badge badge-red"><%= muatanPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= muatanPct %>%</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="no-data">Tidak ada Korlap yang cocok.</div>
        <% } %>
      </div>

      <!-- KORLAP'S PML TEAM DETAILS -->
      <div id="korlapDetailContainer">
        <% if (filterKorlap) { %>
          <div class="card" style="margin-bottom: 0; position: sticky; top: 80px;">
            <div class="card-header">
              <div class="card-title"><i class="bi bi-clipboard2-data"></i> Anggota Tim PML: <%= filterKorlap %></div>
              <a href="/korlap" class="btn btn-secondary btn-xs"><i class="bi bi-x-lg"></i> Tutup</a>
            </div>

            <% if (detailData && detailData.length > 0) { %>
              <div class="mb-4">
                <% 
                  let totalBeban = detailData.reduce((acc, c) => acc + c.total_muatan, 0);
                  let totalUsaha = detailData.reduce((acc, c) => acc + c.usaha_total, 0);
                  let totalPct = totalBeban ? ((totalUsaha / totalBeban) * 100).toFixed(2) : '0.00';

                  let totalFasihTgt = detailData.reduce((acc, c) => acc + (c.target_fasih_total || 0), 0);
                  let totalFasihDone = detailData.reduce((acc, c) => acc + (c.submitted_total || 0) + (c.approved_total || 0) + (c.rejected_total || 0), 0);
                  let totalFasihPct = totalFasihTgt ? ((totalFasihDone / totalFasihTgt) * 100).toFixed(2) : '0.00';
                %>
                <!-- Progress Muatan -->
                <div style="margin-bottom: 12px;">
                  <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px; color: var(--text-secondary);">
                    <span><i class="bi bi-briefcase"></i> Progres Muatan Tim</span>
                    <span class="fw-bold"><%= totalUsaha.toLocaleString('id-ID') %> / <%= totalBeban.toLocaleString('id-ID') %> (<%= totalPct %>%)</span>
                  </div>
                  <div class="progress-bar-target-wrap" style="position: relative; height: 6px; margin-top: 16px; margin-bottom: 8px;">
                    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: var(--bg-progress-wrap); border-radius: 99px; overflow: hidden;">
                      <div class="progress-bar <%= parseFloat(totalPct) >= 100 ? 'green' : (parseFloat(totalPct) < activeTargetPct ? 'red' : 'blue') %>" data-width="<%= totalPct %>" style="width: 0%; height: 100%; border-radius: 99px;"></div>
                    </div>
                    
                    <!-- Marker 25% (Juni) -->
                    <div style="position: absolute; left: 25%; top: -3px; height: 12px; border-left: 1px dashed <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; opacity: <%= activeTargetPct === 25 ? '1' : '0.5' %>; z-index: 2; pointer-events: none;">
                      <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-size: 7px; font-weight: 800; color: <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Jun: 25%</span>
                    </div>

                    <!-- Marker 50% (Juli) -->
                    <div style="position: absolute; left: 50%; top: -3px; height: 12px; border-left: 1px dashed <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; opacity: <%= activeTargetPct === 50 ? '1' : '0.5' %>; z-index: 2; pointer-events: none;">
                      <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-size: 7px; font-weight: 800; color: <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Jul: 50%</span>
                    </div>
                  </div>
                </div>
                <!-- Progress FASIH -->
                <div style="margin-bottom: 16px;">
                  <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px; color: var(--text-secondary);">
                    <span><i class="bi bi-phone"></i> Progres FASIH Tim (Submit + Approve + Reject)</span>
                    <span class="fw-bold"><%= totalFasihDone.toLocaleString('id-ID') %> / <%= totalFasihTgt.toLocaleString('id-ID') %> (<%= totalFasihPct %>%)</span>
                  </div>
                  <div class="progress-bar-wrap" style="height: 6px;">
                    <div class="progress-bar <%= parseFloat(totalFasihPct) >= 100 ? 'green' : (parseFloat(totalFasihPct) < 25 ? 'red' : 'purple') %>" data-width="<%= totalFasihPct %>" style="width: 0%;"></div>
                  </div>
                </div>
              </div>

              <div class="search-wrap mb-4" style="max-width: 100%; margin-bottom: 12px;">
                <input type="search" id="detailPmlSearch" placeholder="Cari nama PML dalam tim..." aria-label="Cari nama Pengawas PML dalam tim">
              </div>

              <div id="detailPmlList" style="max-height: 420px; overflow-y: auto; padding-right: 4px;">
                <% detailData.forEach(item => { %>
                  <% let itemPct = item.total_muatan ? (( (item.usaha_total + item.keluarga_total) / item.total_muatan ) * 100).toFixed(2) : '0.00'; %>
                  <div class="detail-item">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                      <a href="/pml?pml=<%= encodeURIComponent(item.pml) %>" class="fw-bold" style="color: var(--accent-cyan); text-decoration: none;">
                        <i class="bi bi-clipboard2-data"></i> <%= item.pml %>
                      </a>
                      <% if (parseFloat(itemPct) >= 100) { %>
                        <span class="badge badge-green btn-xs">100%</span>
                      <% } else if (parseFloat(itemPct) <= 0) { %>
                        <span class="badge badge-red btn-xs">0%</span>
                      <% } else { %>
                        <span class="badge badge-blue btn-xs"><%= itemPct %>%</span>
                      <% } %>
                    </div>
                    <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">
                      SubSLS Selesai: <strong><%= item.selesai %> / <%= item.total_subsls %></strong> · Petugas: <strong><%= item.jumlah_pcl %> PCL</strong>
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; font-size: 10px;">
                      <span style="background: rgba(6, 182, 212, 0.08); padding: 2px 6px; border-radius: 4px; color: var(--accent-cyan);">
                        Muatan: <strong><%= item.usaha_total + item.keluarga_total %></strong> / <%= item.total_muatan %>
                      </span>
                      <span style="background: rgba(139, 92, 246, 0.08); padding: 2px 6px; border-radius: 4px; color: var(--accent-purple);">
                        <% let itemFasihDone = (item.submitted_total || 0) + (item.approved_total || 0) + (item.rejected_total || 0); %>
                        FASIH Progres: <strong><%= itemFasihDone %></strong> / <%= item.target_fasih_total %>
                      </span>
                      <span style="background: rgba(100, 116, 139, 0.08); padding: 2px 6px; border-radius: 4px; color: var(--text-muted);">
                        Dft: <%= item.draft_total %> · Sub: <%= item.submitted_total %> · App: <%= item.approved_total %> · Rej: <%= item.rejected_total %>
                      </span>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="no-data">Tidak ada detail PML.</div>
            <% } %>
          </div>
        <% } else { %>
          <div class="card empty-state text-center" style="height: 100%; min-height: 300px; display: flex; flex-direction: column; justify-content: center; border-style: dashed;">
            <div class="empty-state-icon"><i class="bi bi-arrow-left-circle"></i></div>
            <div class="empty-state-title">Pilih Korlap</div>
            <div class="empty-state-text">Klik nama Korlap di tabel sebelah kiri untuk melihat rincian PML yang diawasi beserta progres kinerjanya.</div>
          </div>
        <% } %>
      </div>

    </div>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    makeTableSortable('korlapTable');
    makeTableSearchable('korlapSearch', 'korlapTable');
    
    // Initial searchable bind
    <% if (filterKorlap) { %>
      makeListSearchable('detailPmlSearch', 'detailPmlList', '.detail-item');
    <% } %>

    // AJAX Drilldown logic for Korlap
    const detailContainer = document.getElementById('korlapDetailContainer');
    const table = document.getElementById('korlapTable');

    if (table && detailContainer) {
      // Intercept row clicks
      table.querySelector('tbody').addEventListener('click', (e) => {
        const link = e.target.closest('td.td-primary a');
        if (!link) return;

        e.preventDefault();
        const url = link.getAttribute('href');
        const row = link.closest('tr');

        // Update active row visual indicator
        table.querySelectorAll('tbody tr').forEach(r => {
          r.classList.remove('active');
          r.removeAttribute('style');
        });
        row.classList.add('active');
        row.style.background = 'var(--bg-card-hover)';
        row.style.fontWeight = '500';

        // Opacity transition
        detailContainer.style.opacity = '0.5';

        fetch(url)
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newDetail = doc.getElementById('korlapDetailContainer');
            if (newDetail) {
              detailContainer.innerHTML = newDetail.innerHTML;
              detailContainer.style.opacity = '1';

              // Update URL path without refresh
              window.history.pushState(null, '', url);

              // Re-bind list search utility
              makeListSearchable('detailPmlSearch', 'detailPmlList', '.detail-item');

              // Re-bind close handler
              bindCloseDetail();
              if (window.initProgressBars) window.initProgressBars(detailContainer);
            }
          })
          .catch(err => {
            console.error(err);
            detailContainer.style.opacity = '1';
          });
      });
    }

    // AJAX Tutup Detail handler
    function bindCloseDetail() {
      const closeBtn = detailContainer.querySelector('.btn-secondary');
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = closeBtn.getAttribute('href');

          // Reset active rows
          if (table) {
            table.querySelectorAll('tbody tr').forEach(r => {
              r.classList.remove('active');
              r.removeAttribute('style');
            });
          }

          detailContainer.style.opacity = '0.5';
          fetch(url)
            .then(res => res.text())
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const newDetail = doc.getElementById('korlapDetailContainer');
              if (newDetail) {
                detailContainer.innerHTML = newDetail.innerHTML;
                detailContainer.style.opacity = '1';
                window.history.pushState(null, '', url);
                if (window.initProgressBars) window.initProgressBars(detailContainer);
              }
            })
            .catch(err => {
              console.error(err);
              detailContainer.style.opacity = '1';
            });
        });
      }
    }

    bindCloseDetail();
  });
</script>
