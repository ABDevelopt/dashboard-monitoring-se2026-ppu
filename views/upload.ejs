<div class="fade-in">
  <div class="card">
    <div class="card-header">
      <div class="card-title">
        <span><i class="bi bi-upload"></i> Upload File Rekap Baru</span>
      </div>
    </div>
    
    <form action="/admin/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
      <div class="mb-4">
        <label for="tanggal" style="display: block; font-size: 13px; margin-bottom: 6px; color: var(--text-secondary);"><i class="bi bi-calendar3"></i> Tanggal Data Rekap</label>
        <input type="date" id="tanggal" name="tanggal" required style="width: 100%; max-width: 300px; padding: 10px; font-size: 13px;" value="<%= new Date().toISOString().slice(0, 10) %>">
        <p style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">Pilih tanggal pelaksanaan sensus yang diwakili oleh data ini (biasanya tanggal hari ini atau kemarin).</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr)); gap: 16px; margin-bottom: 20px;">
        <div>
          <label for="excelFile" style="display: block; font-size: 13px; margin-bottom: 6px; color: var(--text-secondary);"><i class="bi bi-file-earmark-excel-fill text-cyan"></i> 1. File Rekap Progres Pencacahan (Utama - Opsional)</label>
          <div class="upload-zone" id="uploadZone" style="height: 150px; padding: 15px;">
            <div class="upload-zone-icon" style="font-size: 28px; margin-bottom: 6px;"><i class="bi bi-cloud-arrow-up"></i></div>
            <div class="upload-zone-title" style="font-size: 13px; font-weight: 600;">Pilih File Excel Progres Utama</div>
            <div class="upload-zone-sub" style="font-size: 11px;">atau seret ke sini (.xlsx, .xls)</div>
            <input type="file" id="excelFile" name="excelFile" accept=".xlsx, .xls" multiple style="display: none;">
          </div>
        </div>

        <div>
          <label for="statusFile" style="display: block; font-size: 13px; margin-bottom: 6px; color: var(--text-secondary);"><i class="bi bi-file-earmark-excel-fill text-purple"></i> 2. File Rekap Status Assignment FASIH (Opsional)</label>
          <div class="upload-zone" id="uploadZoneStatus" style="height: 150px; padding: 15px; border-color: rgba(139, 92, 246, 0.4);">
            <div class="upload-zone-icon" style="font-size: 28px; margin-bottom: 6px; color: var(--accent-purple);"><i class="bi bi-cloud-arrow-up"></i></div>
            <div class="upload-zone-title" style="font-size: 13px; font-weight: 600; color: var(--accent-purple);">Pilih File Excel Status FASIH</div>
            <div class="upload-zone-sub" style="font-size: 11px;">atau seret ke sini (.xlsx, .xls)</div>
            <input type="file" id="statusFile" name="statusFile" accept=".xlsx, .xls" multiple style="display: none;">
          </div>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end;">
        <button type="submit" class="btn btn-primary"><i class="bi bi-lightning-charge-fill"></i> Mulai Proses Upload</button>
      </div>
    </form>
  </div>

  <div class="card mt-4">
    <div class="card-header">
      <div class="card-title">
        <span><i class="bi bi-folder-symlink"></i> Impor File dari Folder Workspace</span>
      </div>
      <span class="badge badge-gray"><%= workspaceFiles.length %> File</span>
    </div>
    <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 12px; padding: 0 4px;">
      Daftar file Excel (.xlsx/.xls) yang terdeteksi langsung di dalam folder root workspace aplikasi server. Anda dapat langsung memproses file tanpa perlu menguploadnya secara manual melalui browser.
    </p>

    <% if (workspaceFiles && workspaceFiles.length > 0) { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="width: 40px;" class="text-center">No</th>
              <th>Nama File</th>
              <th>Ukuran</th>
              <th>Terakhir Diubah</th>
              <th style="width: 150px;">Tanggal Data</th>
              <th style="width: 280px;" class="text-center">Aksi Impor Langsung</th>
            </tr>
          </thead>
          <tbody>
            <% workspaceFiles.forEach((file, index) => { %>
              <% 
                let detected = new Date().toISOString().slice(0, 10);
                const ymd = file.filename.match(/(?<!\d)(20\d{2})[-/._]?(0[1-9]|1[0-2])[-/._]?(0[1-9]|[12]\d|3[01])(?!\d)/);
                if (ymd) {
                  detected = `${ymd[1]}-${ymd[2]}-${ymd[3]}`;
                } else {
                  const dmy = file.filename.match(/(?<!\d)(0[1-9]|[12]\d|3[01])[-/._]?(0[1-9]|1[0-2])[-/._]?(20\d{2})(?!\d)/);
                  if (dmy) {
                    detected = `${dmy[3]}-${dmy[2]}-${dmy[1]}`;
                  }
                }
              %>
              <tr>
                <td class="text-center" style="font-weight: 600; background: var(--bg-subtle);"><%= index + 1 %></td>
                <td class="td-primary" style="font-weight: 500; word-break: break-all;"><%= file.filename %></td>
                <td><%= (file.size / 1024 / 1024).toFixed(2) %> MB</td>
                <td style="font-size: 11px; color: var(--text-secondary);"><%= new Date(file.mtime).toLocaleString('id-ID') %></td>
                <td>
                  <input type="date" id="date-<%= index %>" value="<%= detected %>" style="width: 100%; padding: 4px 6px; font-size: 12px; border-radius: 4px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-primary);">
                </td>
                <td class="text-center" style="display: flex; gap: 6px; justify-content: center; align-items: center; border: none;">
                  <button onclick="submitLocalImport('<%= file.filename %>', 'date-<%= index %>', 'excel')" class="btn btn-secondary btn-xs" title="Impor sebagai File Progres Utama"><i class="bi bi-play-fill text-cyan"></i> Progres Utama</button>
                  <button onclick="submitLocalImport('<%= file.filename %>', 'date-<%= index %>', 'status')" class="btn btn-secondary btn-xs" title="Impor sebagai File Status FASIH" style="color: var(--accent-purple); border-color: rgba(139, 92, 246, 0.3);"><i class="bi bi-phone-fill text-purple"></i> Status FASIH</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state" style="padding: 20px;">
        <div class="empty-state-icon" style="font-size: 32px; margin-bottom: 8px;"><i class="bi bi-folder-x"></i></div>
        <div class="empty-state-text" style="font-size: 12px; color: var(--text-muted);">Tidak ditemukan file Excel (.xlsx/.xls) di folder root workspace.</div>
      </div>
    <% } %>
  </div>

  <div class="card mt-4">
    <div class="card-header">
      <div class="card-title">
        <span><i class="bi bi-clock-history"></i> Riwayat Upload & Histori Data</span>
      </div>
      <span class="badge badge-blue"><%= uploads.length %> Upload</span>
    </div>

      <div class="search-wrap mb-4">
        <input type="search" id="uploadsSearch" placeholder="Cari nama file/tanggal..." aria-label="Cari nama file atau tanggal upload" style="width: 100%; max-width: 280px;">
      </div>

    <% if (uploads && uploads.length > 0) { %>
      <div class="table-wrap">
        <table id="uploadsTable">
          <thead>
            <tr>
              <th class="text-center" style="font-weight: 600; width: 40px;">No</th>
              <th class="hide-md">ID</th>
              <th>Nama File</th>
              <th>Tanggal Data</th>
              <th class="text-right">SubSLS Terisi</th>
              <th class="hide-md">Waktu Upload</th>

              <th style="width: 140px;" class="text-center">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% uploads.forEach((u, index) => { %>
              <tr>
                <td class="text-center" style="font-weight: 600; background: var(--bg-subtle);\"><%= index + 1 %></td>
                <td class="td-code hide-md"><%= u.id %></td>
                <td class="td-primary">
                  <div><%= u.filename %></div>
                  <% if (u.status_filename) { %>
                    <div style="font-size: 11px; color: var(--accent-purple); margin-top: 4px; font-weight: 500;">
                      <i class="bi bi-phone"></i> Status: <%= u.status_filename %>
                    </div>
                  <% } %>
                </td>
                <td><span class="badge badge-gray"><%= u.tanggal %></span></td>
                <td class="text-right fw-bold td-primary"><%= u.total_subsls_terisi.toLocaleString('id-ID') %></td>
                <td class="hide-md"><%= new Date(u.created_at).toLocaleString('id-ID') %></td>

                <td class="text-center" style="display: flex; gap: 4px; justify-content: center; align-items: center;">
                  <a href="/admin/upload/download/<%= u.id %>" class="btn btn-secondary" style="padding: 4px 8px;" title="Download File Excel Progres" aria-label="Unduh Excel Progres <%= u.filename %>"><i class="bi bi-download"></i></a>
                  <% if (u.status_filename) { %>
                    <a href="/admin/upload/download-status/<%= u.id %>" class="btn btn-secondary" style="padding: 4px 8px; color: var(--accent-purple); border-color: rgba(139, 92, 246, 0.3);" title="Download File Status FASIH" aria-label="Unduh Status FASIH <%= u.status_filename %>"><i class="bi bi-phone"></i> <i class="bi bi-download"></i></a>
                  <% } %>
                  <form action="/admin/upload/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Yakin ingin menghapus data rekap ini?');" style="margin: 0;">
                    <button type="submit" class="btn btn-secondary text-red" style="padding: 4px 8px;" title="Hapus" aria-label="Hapus Rekap Progres ID <%= u.id %>"><i class="bi bi-trash"></i></button>

                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-folder-x"></i></div>
        <div class="empty-state-title">Belum Ada Data Sensus</div>
        <div class="empty-state-text">Silakan upload file Excel rekap harian pertama Anda untuk mengaktifkan dashboard monitoring.</div>
      </div>
    <% } %>
  </div>
</div>

<script>
  function extractDateFromFilename(filename) {
    if (!filename) return null;
    const name = filename.toLowerCase();

    // Pattern 1: YYYY-MM-DD
    const ymd = name.match(/(?<!\d)(20\d{2})[-/._](0[1-9]|1[0-2])[-/._](0[1-9]|[12]\d|3[01])(?!\d)/);
    if (ymd) {
      return `${ymd[1]}-${ymd[2]}-${ymd[3]}`;
    }

    // Pattern 2: DD-MM-YYYY
    const dmy = name.match(/(?<!\d)(0[1-9]|[12]\d|3[01])[-/._](0[1-9]|1[0-2])[-/._](20\d{2})(?!\d)/);
    if (dmy) {
      return `${dmy[3]}-${dmy[2]}-${dmy[1]}`;
    }

    // Pattern 3: Textual Month (e.g. "19 juni" or "19 juni 2026")
    const months = {
      jan: '01', januari: '01', january: '01',
      feb: '02', februari: '02', february: '02',
      mar: '03', maret: '03', march: '03',
      apr: '04', april: '04',
      mei: '05', may: '05',
      jun: '06', juni: '06', june: '06',
      jul: '07', juli: '07', july: '07',
      agu: '08', agustus: '08', august: '08',
      sep: '09', september: '09',
      okt: '10', oktober: '10', october: '10',
      nov: '11', november: '11',
      des: '12', desember: '12', december: '12'
    };

    const monthKeys = Object.keys(months).sort((a,b) => b.length - a.length);
    const monthRegex = monthKeys.join('|');
    const txtDatePattern = new RegExp(`(?<!\\d)(0?[1-9]|[12]\\d|3[01])[-_\\s]+(${monthRegex})([-_\\s]+(20\\d{2}))?(?!\\d)`, 'i');
    const txtMatch = name.match(txtDatePattern);
    if (txtMatch) {
      const day = txtMatch[1].padStart(2, '0');
      const month = months[txtMatch[2].toLowerCase()];
      const year = txtMatch[4] || new Date().getFullYear().toString();
      return `${year}-${month}-${day}`;
    }

    return null;
  }

  document.addEventListener('DOMContentLoaded', () => {
    initUploadZone('uploadZone', 'excelFile');
    initUploadZone('uploadZoneStatus', 'statusFile');
    makeTableSortable('uploadsTable');
    makeTableSearchable('uploadsSearch', 'uploadsTable');

    const excelInput = document.getElementById('excelFile');
    const statusInput = document.getElementById('statusFile');
    const tanggalInput = document.getElementById('tanggal');

    function handleFileSelect(file) {
      if (!file) return;
      const detectedDate = extractDateFromFilename(file.name);
      if (detectedDate) {
        tanggalInput.value = detectedDate;
      }
    }

    excelInput.addEventListener('change', () => {
      if (excelInput.files[0]) handleFileSelect(excelInput.files[0]);
    });
    statusInput.addEventListener('change', () => {
      if (statusInput.files[0]) handleFileSelect(statusInput.files[0]);
    });

    document.getElementById('uploadForm').addEventListener('submit', (e) => {
      const excel = document.getElementById('excelFile');
      const status = document.getElementById('statusFile');
      if (!excel.files[0] && !status.files[0]) {
        e.preventDefault();
        alert('Silakan pilih setidaknya satu file Excel (File Progres Utama atau File Status FASIH) untuk diupload.');
      }
    });
  });

  function submitLocalImport(filename, dateInputId, type) {
    const dateInput = document.getElementById(dateInputId);
    if (!dateInput || !dateInput.value) {
      alert('Silakan pilih tanggal data terlebih dahulu.');
      return;
    }

    if (!confirm(`Konfirmasi impor file "${filename}" sebagai ${type === 'excel' ? 'File Progres Utama' : 'File Status FASIH'} untuk tanggal ${dateInput.value}?`)) {
      return;
    }

    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/upload/import-local';

    const fnField = document.createElement('input');
    fnField.type = 'hidden';
    fnField.name = 'filename';
    fnField.value = filename;
    form.appendChild(fnField);

    const dateField = document.createElement('input');
    dateField.type = 'hidden';
    dateField.name = 'tanggal';
    dateField.value = dateInput.value;
    form.appendChild(dateField);

    const typeField = document.createElement('input');
    typeField.type = 'hidden';
    typeField.name = 'type';
    typeField.value = type;
    form.appendChild(typeField);

    document.body.appendChild(form);
    form.submit();
  }
</script>
