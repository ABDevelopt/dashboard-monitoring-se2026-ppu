<div class="fade-in" style="max-width: 400px; margin: 60px auto;">
  <div class="card" style="text-align: center; padding: 32px 24px;">
    <img src="/logo-vertical.png" alt="Logo SE2026" class="logo-light" loading="eager" style="width: 140px; margin-bottom: 24px; object-fit: contain;">
    <img src="/logo-vertical-dark.png" alt="Logo SE2026" class="logo-dark" fetchpriority="high" loading="eager" style="width: 140px; margin-bottom: 24px; object-fit: contain;">
    <h2 style="font-size: 20px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Login Admin</h2>
    <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 24px;">Masukkan password administrator untuk mengelola data sensus.</p>

    <form action="/admin/login" method="POST">
      <div style="margin-bottom: 16px; text-align: left;">
        <label for="password" style="display: block; font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px;">Password</label>
        <input type="password" id="password" name="password" required style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 14px; background: var(--bg-body); color: var(--text-primary);" placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 12px; font-size: 14px;"><i class="bi bi-box-arrow-in-right"></i> Masuk ke Dashboard Admin</button>
    </form>
    
    <div style="margin-top: 24px;">
      <a href="/" style="font-size: 13px; color: var(--text-muted); text-decoration: none;"><i class="bi bi-arrow-left"></i> Kembali ke Halaman Publik</a>
    </div>
  </div>
</div>
