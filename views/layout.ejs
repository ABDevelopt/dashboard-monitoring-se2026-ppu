<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Dashboard SE2026 PPU</title>
  <meta name="description" content="Dashboard Monitoring Sensus Ekonomi 2026 Kabupaten Penajam Paser Utara">
  <link rel="icon" type="image/png" href="/logo-mark.png">
  <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<script>
  // Apply saved theme immediately to prevent flashing
  if (localStorage.getItem('theme') === 'light') {
    document.body.classList.add('light-mode');
  }
</script>

<!-- SIDEBAR OVERLAY -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <button class="btn-close-sidebar" id="sidebarClose"><i class="bi bi-x-lg"></i></button>
  <div class="sidebar-logo" style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: 24px 16px; border-bottom: 1px solid var(--border);">
    <img src="/logo-vertical.png" alt="Logo SE2026" style="width: auto; max-width: 140px; max-height: 90px; object-fit: contain; margin-bottom: 8px;">
    <p style="font-size: 11px; color: var(--text-muted); font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-top: 4px;">Penajam Paser Utara</p>
  </div>

  <% if (latestUpload) { %>
  <div class="sidebar-upload-info">
    <strong><i class="bi bi-calendar3"></i> Data Terakhir</strong>
    <%= latestUpload.tanggal %> · <%= latestUpload.filename.length > 28 ? latestUpload.filename.slice(0,25)+'...' : latestUpload.filename %>
  </div>
  <% } %>

  <nav class="sidebar-nav">
    <div class="nav-section">Ringkasan</div>
    <a href="/" class="nav-item <%= activePage === 'overview' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-house-door"></i></span> Overview
    </a>
    <a href="/map" class="nav-item <%= activePage === 'map' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-map"></i></span> Peta Progres
    </a>
    <a href="/early-warning" class="nav-item <%= activePage === 'earlywarning' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-exclamation-octagon"></i></span> Early Warning
    </a>
    <a href="/leaderboard" class="nav-item <%= activePage === 'leaderboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-trophy"></i></span> Performa Terbaik
    </a>
    <a href="/performa-terendah" class="nav-item <%= activePage === 'performa-terendah' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-graph-down"></i></span> Performa Terendah
    </a>

    <div class="nav-section">Drilldown</div>
    <a href="/kecamatan" class="nav-item <%= activePage === 'kecamatan' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-geo-alt"></i></span> Per Kecamatan
    </a>
    <a href="/korlap" class="nav-item <%= activePage === 'korlap' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-person-workspace"></i></span> Per Korlap
    </a>
    <a href="/pml" class="nav-item <%= activePage === 'pml' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-clipboard2-data"></i></span> Per PML
    </a>
    <a href="/pcl" class="nav-item <%= activePage === 'pcl' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-person-gear"></i></span> Per PCL
    </a>
    <a href="/subsls" class="nav-item <%= activePage === 'subsls' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-box-seam"></i></span> Per SubSLS
    </a>

    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <div class="nav-section">Admin</div>
    <a href="/admin/upload" class="nav-item <%= activePage === 'upload' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-upload"></i></span> Upload Data
    </a>
    <a href="/admin/master" class="nav-item <%= activePage === 'master' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-database-fill-gear"></i></span> Kelola Master Data
    </a>
    <a href="/admin/logout" class="nav-item">
      <span class="nav-icon"><i class="bi bi-box-arrow-right"></i></span> Logout Admin
    </a>
    <% } %>

    <div class="nav-section">Export</div>
    <a href="/subsls/export" class="nav-item">
      <span class="nav-icon"><i class="bi bi-download"></i></span> Export CSV
    </a>
  </nav>

  <div class="sidebar-footer">
    SE2026 · PPU · v1.0.0<br>
    <span style="color: var(--text-muted)">© BPS Penajam Paser Utara</span>
  </div>
</aside>

<!-- MAIN WRAPPER -->
<div class="main-wrapper">
  <!-- TOPBAR -->
  <header class="topbar">
    <button class="btn-toggle-sidebar" id="sidebarToggle"><i class="bi bi-list"></i></button>
    <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; overflow: hidden;">
      <img src="/logo-horizontal.png" alt="Logo SE2026" style="height: 30px; max-width: 110px; object-fit: contain; flex-shrink: 0;">
      <div style="border-left: 1px solid var(--border); padding-left: 12px; min-height: 28px; display: flex; flex-direction: column; justify-content: center; min-width: 0; overflow: hidden;">
        <div class="topbar-title" style="line-height: 1.2;"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></div>
        <div class="topbar-subtitle" style="font-size: 11px; margin-top: 2px; color: var(--text-muted);">
          Penajam Paser Utara
          <% if (typeof latestUpload !== 'undefined' && latestUpload && latestUpload.created_at) { %>
            <span style="opacity: 0.6; margin: 0 4px;">|</span>
            <span title="Waktu update data terakhir" style="color: var(--accent-blue); font-weight: 500;">
              <i class="bi bi-clock-history"></i> Update: <%= new Date(latestUpload.created_at + 'Z').toLocaleString('id-ID', {day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %>
            </span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-secondary" id="themeToggle" title="Ubah Tema" style="padding: 8px 12px; min-width: auto;">
        <i class="bi bi-moon-fill" id="themeIcon"></i>
      </button>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin/upload" class="btn btn-primary"><i class="bi bi-upload"></i> Upload Data</a>
      <% } %>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="page-content">
    <!-- Flash Messages -->
    <% if (success && success.length) { %>
    <div class="flash-messages">
      <% success.forEach(msg => { %>
      <div class="alert alert-success"><i class="bi bi-check-circle-fill"></i> <%= msg %></div>
      <% }) %>
    </div>
    <% } %>
    <% if (error && error.length) { %>
    <div class="flash-messages">
      <% error.forEach(msg => { %>
      <div class="alert alert-error"><i class="bi bi-x-circle-fill"></i> <%= msg %></div>
      <% }) %>
    </div>
    <% } %>

    <%- body %>
  </main>
</div>

<script src="/js/charts.js?v=<%= appVersion %>"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('sidebar');
    const toggleBtn = document.getElementById('sidebarToggle');
    const closeBtn = document.getElementById('sidebarClose');
    const overlay = document.getElementById('sidebarOverlay');

    if (toggleBtn && sidebar && overlay) {
      toggleBtn.addEventListener('click', () => {
        sidebar.classList.add('active');
        overlay.classList.add('active');
      });
      
      const closeSidebar = () => {
        sidebar.classList.remove('active');
        overlay.classList.remove('active');
      };

      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
      overlay.addEventListener('click', closeSidebar);
    }

    // Theme Toggle Logic
    const themeToggleBtn = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    
    // Set initial icon based on applied theme
    if (document.body.classList.contains('light-mode')) {
      if (themeIcon) {
        themeIcon.classList.remove('bi-moon-fill');
        themeIcon.classList.add('bi-sun-fill');
      }
    }

    if (themeToggleBtn && themeIcon) {
      themeToggleBtn.addEventListener('click', () => {
        document.body.classList.toggle('light-mode');
        const isLight = document.body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        
        if (isLight) {
          themeIcon.classList.remove('bi-moon-fill');
          themeIcon.classList.add('bi-sun-fill');
        } else {
          themeIcon.classList.remove('bi-sun-fill');
          themeIcon.classList.add('bi-moon-fill');
        }
        
        // Dispatch event for charts to adapt
        window.dispatchEvent(new Event('themechange'));
      });
    }
  });
</script>
<%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
