<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Dashboard SE2026 PPU</title>
  <meta name="description" content="Dashboard Monitoring Sensus Ekonomi 2026 Kabupaten Penajam Paser Utara">
  <link rel="icon" type="image/png" href="/logo-mark.png">
  <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<script>
  // Apply saved theme immediately to prevent flashing
  if (localStorage.getItem('theme') === 'light') {
    document.body.classList.add('light-mode');
  }
</script>

<!-- SIDEBAR OVERLAY -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar" aria-label="Sidebar Menu">
  <button class="btn-close-sidebar" id="sidebarClose" aria-label="Tutup Sidebar"><i class="bi bi-x-lg"></i></button>
  <div class="sidebar-logo" style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: 24px 16px; border-bottom: 1px solid var(--border);">
    <img src="/logo-vertical.png" alt="Logo SE2026" style="width: auto; max-width: 140px; max-height: 90px; object-fit: contain; margin-bottom: 8px;">
    <p style="font-size: 11px; color: var(--text-muted); font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-top: 4px;">Penajam Paser Utara</p>
  </div>

  <% if (latestUpload) { %>
  <div class="sidebar-upload-info">
    <strong><i class="bi bi-calendar3"></i> Data Terakhir</strong>
    <%= latestUpload.tanggal %> · <%= latestUpload.filename.length > 28 ? latestUpload.filename.slice(0,25)+'...' : latestUpload.filename %>
  </div>
  <% } %>

  <nav class="sidebar-nav">
    <div class="nav-section">Ringkasan</div>
    <a href="/" class="nav-item <%= activePage === 'overview' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-house-door"></i></span> Overview
    </a>
    <a href="/map" class="nav-item <%= activePage === 'map' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-map"></i></span> Peta Progres
    </a>
    <a href="/early-warning" class="nav-item <%= activePage === 'earlywarning' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-exclamation-octagon"></i></span> Early Warning
    </a>
    <a href="/leaderboard" class="nav-item <%= activePage === 'leaderboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-trophy"></i></span> Performa Terbaik
    </a>
    <a href="/performa-terendah" class="nav-item <%= activePage === 'performa-terendah' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-graph-down"></i></span> Performa Terendah
    </a>
    <a href="/deteksi-anomali" class="nav-item <%= activePage === 'deteksi-anomali' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-shield-exclamation"></i></span> Deteksi Awal Anomali <span class="badge badge-yellow" style="font-size: 8px; padding: 2px 6px; margin-left: auto;">Soon</span>
    </a>

    <div class="nav-section">Drilldown</div>
    <a href="/kecamatan" class="nav-item <%= activePage === 'kecamatan' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-geo-alt"></i></span> Per Kecamatan
    </a>
    <a href="/korlap" class="nav-item <%= activePage === 'korlap' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-person-workspace"></i></span> Per Korlap
    </a>
    <a href="/pml" class="nav-item <%= activePage === 'pml' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-clipboard2-data"></i></span> Per PML
    </a>
    <a href="/pcl" class="nav-item <%= activePage === 'pcl' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-person-gear"></i></span> Per PCL
    </a>
    <a href="/subsls" class="nav-item <%= activePage === 'subsls' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-box-seam"></i></span> Per SubSLS
    </a>

    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <div class="nav-section">Admin</div>
    <a href="/admin/upload" class="nav-item <%= activePage === 'upload' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-upload"></i></span> Upload Data
    </a>
    <a href="/admin/master" class="nav-item <%= activePage === 'master' ? 'active' : '' %>">
      <span class="nav-icon"><i class="bi bi-database-fill-gear"></i></span> Kelola Master Data
    </a>
    <a href="/admin/logout" class="nav-item">
      <span class="nav-icon"><i class="bi bi-box-arrow-right"></i></span> Logout Admin
    </a>
    <% } %>

    <div class="nav-section">Export</div>
    <a href="/subsls/export" class="nav-item">
      <span class="nav-icon"><i class="bi bi-download"></i></span> Export CSV
    </a>
  </nav>

  <div class="sidebar-footer">
    SE2026 · PPU · v1.0.0<br>
    <span style="color: var(--text-muted)">© BPS Penajam Paser Utara</span>
  </div>
</aside>

<!-- MAIN WRAPPER -->
<div class="main-wrapper">
  <!-- TOPBAR -->
  <header class="topbar">
    <button class="btn-toggle-sidebar" id="sidebarToggle" aria-label="Buka Sidebar" aria-expanded="false"><i class="bi bi-list"></i></button>
    <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; overflow: hidden;">
      <img src="/logo-horizontal.png" alt="Logo SE2026" style="height: 30px; max-width: 110px; object-fit: contain; flex-shrink: 0;">
      <div style="border-left: 1px solid var(--border); padding-left: 12px; min-height: 28px; display: flex; flex-direction: column; justify-content: center; min-width: 0; overflow: hidden;">
        <div class="topbar-title" style="line-height: 1.2;"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></div>
        <div class="topbar-subtitle" style="font-size: 11px; margin-top: 2px; color: var(--text-muted);">
          Penajam Paser Utara
          <% if (typeof latestUpload !== 'undefined' && latestUpload && latestUpload.created_at) { %>
            <span style="opacity: 0.6; margin: 0 4px;">|</span>
            <span title="Waktu update data terakhir" style="color: var(--accent-blue); font-weight: 500;">
              <i class="bi bi-clock-history"></i> Update: <%= new Date(latestUpload.created_at + 'Z').toLocaleString('id-ID', {day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %>
            </span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-secondary" id="themeToggle" title="Ubah Tema" aria-label="Ubah Tema" style="padding: 8px 12px; min-width: auto;">
        <i class="bi bi-moon-fill" id="themeIcon"></i>
      </button>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin/upload" class="btn btn-primary"><i class="bi bi-upload"></i> Upload Data</a>
      <% } %>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="page-content">
    <!-- Flash Messages -->
    <% if (success && success.length) { %>
    <div class="flash-messages">
      <% success.forEach(msg => { %>
      <div class="alert alert-success"><i class="bi bi-check-circle-fill"></i> <%= msg %></div>
      <% }) %>
    </div>
    <% } %>
    <% if (error && error.length) { %>
    <div class="flash-messages">
      <% error.forEach(msg => { %>
      <div class="alert alert-error"><i class="bi bi-x-circle-fill"></i> <%= msg %></div>
      <% }) %>
    </div>
    <% } %>

    <%- body %>
  </main>
</div>

<!-- GLOBAL DETAIL MODAL -->
<div class="custom-modal-backdrop" id="globalDetailModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.65); z-index: 3000; align-items: center; justify-content: center; backdrop-filter: blur(6px); padding: 20px;">
  <div class="card" id="globalDetailModalCard" style="width: 100%; max-width: 520px; max-height: 90vh; margin: 0; display: flex; flex-direction: column; overflow: hidden; animation: slideIn 0.25s ease; border-radius: 16px;">
    <div class="card-header" style="padding: 20px 20px 0 20px; border-bottom: none; flex-shrink: 0; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
      <div>
        <div class="card-title" id="globalDetailModalTitle" style="font-size: 15px; font-weight: 700; line-height: 1.3;"><i class="bi bi-person-bounding-box"></i> Rincian Tugas SLS</div>
        <div id="globalDetailModalSubtitle" style="font-size: 12px; color: var(--text-muted); margin-top: 4px;"></div>
      </div>
      <button class="btn btn-secondary" id="btnCloseGlobalDetailModal" aria-label="Tutup" style="min-width: auto; padding: 6px 10px; flex-shrink: 0; border-radius: 8px;"><i class="bi bi-x-lg"></i> Tutup</button>
    </div>
    <div class="card-body" id="globalDetailModalBody" style="flex: 1; overflow-y: auto; padding: 16px 20px 20px 20px; display: flex; flex-direction: column; gap: 16px;">
      <!-- Content injected by JS -->
    </div>
  </div>
</div>

<script src="/js/charts.js?v=<%= appVersion %>"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('sidebar');
    const toggleBtn = document.getElementById('sidebarToggle');
    const closeBtn = document.getElementById('sidebarClose');
    const overlay = document.getElementById('sidebarOverlay');

    // Load collapsed state from localStorage on startup (desktop only)
    if (window.innerWidth > 768) {
      const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      if (isCollapsed) {
        document.body.classList.add('sidebar-collapsed');
        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
      }
    }

    if (toggleBtn && sidebar && overlay) {
      toggleBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (window.innerWidth > 768) {
          // Desktop collapse logic
          document.body.classList.toggle('sidebar-collapsed');
          const isCollapsed = document.body.classList.contains('sidebar-collapsed');
          localStorage.setItem('sidebar-collapsed', isCollapsed);
          toggleBtn.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
        } else {
          // Mobile slide-out overlay logic
          sidebar.classList.add('active');
          overlay.classList.add('active');
          toggleBtn.setAttribute('aria-expanded', 'true');
        }
      });
      
      const closeSidebar = () => {
        sidebar.classList.remove('active');
        overlay.classList.remove('active');
        toggleBtn.setAttribute('aria-expanded', 'false');
      };

      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
      overlay.addEventListener('click', closeSidebar);
    }

    // Theme Toggle Logic
    const themeToggleBtn = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    
    // Set initial icon based on applied theme
    if (document.body.classList.contains('light-mode')) {
      if (themeIcon) {
        themeIcon.classList.remove('bi-moon-fill');
        themeIcon.classList.add('bi-sun-fill');
      }
    }

    if (themeToggleBtn && themeIcon) {
      themeToggleBtn.addEventListener('click', () => {
        document.body.classList.toggle('light-mode');
        const isLight = document.body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        
        if (isLight) {
          themeIcon.classList.remove('bi-moon-fill');
          themeIcon.classList.add('bi-sun-fill');
        } else {
          themeIcon.classList.remove('bi-sun-fill');
          themeIcon.classList.add('bi-moon-fill');
        }
        
        // Dispatch event for charts to adapt
        window.dispatchEvent(new Event('themechange'));
      });
    }

    // Dynamic Expand Table Feature
    const toggleCardExpand = (card, btn, closeOverlayBtn) => {
      const isExpanded = card.classList.contains('card-expanded');

      if (isExpanded) {
        // ---- COLLAPSING ----
        card.classList.remove('card-expanded');
        document.body.classList.remove('has-expanded-card');
        btn.innerHTML = '<i class="bi bi-arrows-angle-expand"></i> <span>Expand</span>';
        btn.classList.remove('btn-danger');
        btn.classList.add('btn-secondary');
        if (closeOverlayBtn) closeOverlayBtn.style.display = 'none';
        
        window.lastExpandedTableId = null;

        // Restore filter form and search wrap if they were moved
        const expandedRow = card.querySelector('.expanded-filter-row');
        if (expandedRow) {
          if (window._expandedFilterData) {
            const data = window._expandedFilterData;
            
            // Remove created search label
            if (data.createdSearchLabel) {
              data.createdSearchLabel.remove();
            }

            // Restore search-wrap
            if (data.searchWrap && data.searchWrapParent) {
              if (data.searchWrapNextSibling) {
                data.searchWrapParent.insertBefore(data.searchWrap, data.searchWrapNextSibling);
              } else {
                data.searchWrapParent.appendChild(data.searchWrap);
              }
            }

            // Restore filterForm
            if (data.filterForm && data.filterFormParent) {
              if (data.filterFormNextSibling) {
                data.filterFormParent.insertBefore(data.filterForm, data.filterFormNextSibling);
              } else {
                data.filterFormParent.appendChild(data.filterForm);
              }
            }

            // Restore resetBtn
            if (data.resetBtn && data.resetBtnParent) {
              if (data.resetBtnNextSibling) {
                data.resetBtnParent.insertBefore(data.resetBtn, data.resetBtnNextSibling);
              } else {
                data.resetBtnParent.appendChild(data.resetBtn);
              }
              data.resetBtn.classList.remove('btn-reset-expanded');
            }

            window._expandedFilterData = null;
          }
          expandedRow.remove();
        }
      } else {
        // ---- EXPANDING ----
        card.classList.add('card-expanded');
        document.body.classList.add('has-expanded-card');
        btn.innerHTML = '<i class="bi bi-fullscreen-exit"></i> <span>Collapse</span>';
        btn.classList.remove('btn-secondary');
        btn.classList.add('btn-danger');
        if (closeOverlayBtn) closeOverlayBtn.style.display = 'flex';

        const table = card.querySelector('table');
        if (table) {
          window.lastExpandedTableId = table.id;
        }

        // Check for search wrap and filter form
        const searchWrap = card.querySelector('.search-wrap');
        const filterForm = document.getElementById('filterForm');

        if (searchWrap && filterForm) {
          // Find the reset button in the filter card
          const filterCard = filterForm.closest('.card');
          const resetBtn = filterCard ? filterCard.querySelector('a.btn-secondary') : null;

          // Create the flex row
          const expandedRow = document.createElement('div');
          expandedRow.className = 'expanded-filter-row';

          let createdSearchLabel = null;
          let searchLabel = searchWrap.querySelector('label');
          if (!searchLabel) {
            searchLabel = document.createElement('label');
            const searchInput = searchWrap.querySelector('input');
            if (searchInput) {
              searchLabel.htmlFor = searchInput.id;
            }
            searchLabel.textContent = 'Cari Petugas';
            searchLabel.style.display = 'block';
            searchLabel.style.fontSize = '11px';
            searchLabel.style.marginBottom = '4px';
            searchLabel.style.color = 'var(--text-muted)';
            searchWrap.insertBefore(searchLabel, searchWrap.firstChild);
            createdSearchLabel = searchLabel;
          }

          // Store original positions for restoration
          window._expandedFilterData = {
            searchWrap: searchWrap,
            searchWrapParent: searchWrap.parentNode,
            searchWrapNextSibling: searchWrap.nextSibling,
            filterForm: filterForm,
            filterFormParent: filterForm.parentNode,
            filterFormNextSibling: filterForm.nextSibling,
            resetBtn: resetBtn,
            resetBtnParent: resetBtn ? resetBtn.parentNode : null,
            resetBtnNextSibling: resetBtn ? resetBtn.nextSibling : null,
            createdSearchLabel: createdSearchLabel
          };

          // Insert the expanded row before where the searchWrap was
          searchWrap.parentNode.insertBefore(expandedRow, searchWrap);

          // Move searchWrap into the expanded row
          expandedRow.appendChild(searchWrap);

          // Move filterForm into the expanded row
          expandedRow.appendChild(filterForm);

          // Move resetBtn into the expanded row if it exists
          if (resetBtn) {
            expandedRow.appendChild(resetBtn);
            resetBtn.classList.add('btn-reset-expanded');
          }
        }
      }
      window.dispatchEvent(new Event('resize'));
    };

    window.initExpandButtons = (container = document) => {
      container.querySelectorAll('.card').forEach(card => {
        const tableWrap = card.querySelector('.table-wrap');
        if (!tableWrap) return; // Only apply to cards with tables
        if (card.querySelector('#kecOverviewTable')) return; // Exclude overview table from expand feature

        const header = card.querySelector('.card-header');
        if (header) {
          if (header.querySelector('.btn-expand-table')) return;

          let actionsWrap = header.querySelector('.card-actions');
          if (!actionsWrap) {
            actionsWrap = document.createElement('div');
            actionsWrap.className = 'card-actions';
            actionsWrap.style.display = 'flex';
            actionsWrap.style.gap = '8px';
            actionsWrap.style.alignItems = 'center';
            actionsWrap.style.marginLeft = 'auto';

            // Move any children other than the title wrapper (usually first child) to actions wrapper
            const children = Array.from(header.children);
            if (children.length > 1) {
              for (let i = 1; i < children.length; i++) {
                actionsWrap.appendChild(children[i]);
              }
            }
            header.appendChild(actionsWrap);
          }

          // Create close button for expanded mode
          let closeOverlayBtn = card.querySelector('.btn-close-expand-overlay');
          if (!closeOverlayBtn) {
            closeOverlayBtn = document.createElement('button');
            closeOverlayBtn.type = 'button';
            closeOverlayBtn.className = 'btn-close-expand-overlay';
            closeOverlayBtn.setAttribute('aria-label', 'Tutup Layar Penuh');
            closeOverlayBtn.innerHTML = '<i class="bi bi-x-lg"></i>';
            card.appendChild(closeOverlayBtn);
          }

          const expandBtn = document.createElement('button');
          expandBtn.type = 'button';
          expandBtn.className = 'btn btn-secondary btn-sm btn-expand-table';
          expandBtn.style.padding = '4px 8px';
          expandBtn.style.fontSize = '12px';
          expandBtn.style.display = 'inline-flex';
          expandBtn.style.alignItems = 'center';
          expandBtn.style.gap = '4px';
          expandBtn.innerHTML = '<i class="bi bi-arrows-angle-expand"></i> <span>Expand</span>';

          const toggleHandler = (e) => {
            e.preventDefault();
            toggleCardExpand(card, expandBtn, closeOverlayBtn);
          };

          expandBtn.addEventListener('click', toggleHandler);
          closeOverlayBtn.addEventListener('click', toggleHandler);

          actionsWrap.appendChild(expandBtn);

          // Auto-restore expanded state if needed
          const table = card.querySelector('table');
          if (table && document.body.classList.contains('has-expanded-card') && window.lastExpandedTableId === table.id) {
            setTimeout(() => {
              toggleCardExpand(card, expandBtn, closeOverlayBtn);
            }, 50);
          }
        }
      });
    };

    window.initExpandButtons(document);


    // ============================================================
    // Modal Detail Renderers — Summary Card Style
    // ============================================================

    function makeProgressBar(value, total, color) {
      const pct = total > 0 ? Math.min(100, (value / total) * 100) : 0;
      const pctText = total > 0 ? ((value / total) * 100).toFixed(1) : '0.0';
      return `
        <div style="display:flex; align-items:center; gap:10px; margin-top:6px;">
          <div style="flex:1; background:var(--bg-tertiary,rgba(255,255,255,0.08)); border-radius:999px; height:10px; overflow:hidden;">
            <div style="width:${pct}%; height:100%; background:${color}; border-radius:999px; transition:width 0.6s ease;"></div>
          </div>
          <span style="font-size:12px; font-weight:600; color:var(--text-primary); min-width:56px; text-align:right;">${value.toLocaleString('id-ID')} / ${total.toLocaleString('id-ID')}</span>
          <span style="font-size:11px; color:var(--text-muted); min-width:46px;">(${pctText}%)</span>
        </div>
      `;
    }

    function makeFasihCards(draft, submit, approve, reject) {
      const cards = [
        { label: 'Draft',   value: draft,   color: '#6b7280', icon: 'bi-pencil' },
        { label: 'Submit',  value: submit,  color: '#3b82f6', icon: 'bi-send'   },
        { label: 'Approve', value: approve, color: '#22c55e', icon: 'bi-check-circle' },
        { label: 'Reject',  value: reject,  color: '#ef4444', icon: 'bi-x-circle' },
      ];
      return `<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-top:8px;">
        ${cards.map(c => `
          <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:10px; padding:10px 8px; text-align:center;">
            <i class="bi ${c.icon}" style="font-size:16px; color:${c.color};"></i>
            <div style="font-size:18px; font-weight:700; color:var(--text-primary); margin-top:4px;">${c.value.toLocaleString('id-ID')}</div>
            <div style="font-size:10px; color:var(--text-muted); margin-top:2px;">${c.label}</div>
          </div>
        `).join('')}
      </div>`;
    }

    function makeSectionHeader(label) {
      return `<div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--accent-blue); margin-bottom:2px; display:flex; align-items:center; gap:6px;"><span style="display:inline-block; width:3px; height:14px; background:var(--accent-blue); border-radius:2px;"></span>${label}</div>`;
    }

    const renderKorlapDetails = (rows, name) => {
      // Aggregate totals from all PML rows under this Korlap
      const totalSubSLS = rows.reduce((s, r) => s + (r.total_subsls || 0), 0);
      const totalSelesai = rows.reduce((s, r) => s + (r.selesai || 0), 0);
      const totalMuatan = rows.reduce((s, r) => s + (r.total_muatan || 0), 0);
      const totalUsaha = rows.reduce((s, r) => s + (r.usaha_total || 0), 0);
      const totalFasihTarget = rows.reduce((s, r) => s + (r.target_fasih_total || 0), 0);
      const totalDraft = rows.reduce((s, r) => s + (r.draft_total || 0), 0);
      const totalSubmit = rows.reduce((s, r) => s + (r.submitted_total || 0), 0);
      const totalApprove = rows.reduce((s, r) => s + (r.approved_total || 0), 0);
      const totalReject = rows.reduce((s, r) => s + (r.rejected_total || 0), 0);
      const totalFasihAll = totalDraft + totalSubmit + totalApprove + totalReject;

      // Get first row for metadata (PML name for korlap, korlap for all)
      const firstPml = rows.length > 0 ? rows[0].pml : '-';
      const korlapName = rows.length > 0 ? rows[0].korlap : name;

      // Update subtitle in modal header
      const subtitle = document.getElementById('globalDetailModalSubtitle');
      if (subtitle) subtitle.textContent = `Korlap: ${korlapName} · ${rows.length} PML bawahan`;

      return `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres Muatan')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalSubSLS} SubSLS total · ${totalSelesai} selesai</span>
          </div>
          ${makeProgressBar(totalUsaha, totalMuatan, 'var(--accent-blue)')}
        </div>
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres FASIH (Submit + Approve + Reject)')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalFasihAll.toLocaleString('id-ID')} / ${totalFasihTarget.toLocaleString('id-ID')} entri</span>
          </div>
          ${makeProgressBar(totalFasihAll, totalFasihTarget, '#22c55e')}
          ${makeFasihCards(totalDraft, totalSubmit, totalApprove, totalReject)}
        </div>
        ${rows.length > 0 ? `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Rincian Per PML')}
          <div style="margin-top:8px; display:flex; flex-direction:column; gap:6px;">
            ${rows.map(r => {
              const pct = r.total_muatan > 0 ? ((r.usaha_total / r.total_muatan)*100).toFixed(1) : '0.0';
              return `<div style="display:flex; align-items:center; justify-content:space-between; padding:6px 0; border-bottom:1px solid var(--border);">
                <span style="font-size:12px; font-weight:500;">${r.pml}</span>
                <span style="font-size:11px; color:var(--text-muted); font-family:monospace;">${r.usaha_total}/${r.total_muatan} (${pct}%)</span>
              </div>`;
            }).join('')}
          </div>
        </div>` : ''}
      `;
    };

    const renderPmlDetails = (rows, name) => {
      // Aggregate totals from all PCL rows under this PML
      const totalSubSLS = rows.reduce((s, r) => s + (r.total_subsls || 0), 0);
      const totalSelesai = rows.reduce((s, r) => s + (r.selesai || 0), 0);
      const totalMuatan = rows.reduce((s, r) => s + (r.total_muatan || 0), 0);
      const totalUsaha = rows.reduce((s, r) => s + (r.usaha_total || 0), 0);
      const totalFasihTarget = rows.reduce((s, r) => s + (r.target_fasih_total || 0), 0);
      const totalDraft = rows.reduce((s, r) => s + (r.draft_total || 0), 0);
      const totalSubmit = rows.reduce((s, r) => s + (r.submitted_total || 0), 0);
      const totalApprove = rows.reduce((s, r) => s + (r.approved_total || 0), 0);
      const totalReject = rows.reduce((s, r) => s + (r.rejected_total || 0), 0);
      const totalFasihAll = totalDraft + totalSubmit + totalApprove + totalReject;

      const korlapName = rows.length > 0 ? rows[0].korlap : '-';

      const subtitle = document.getElementById('globalDetailModalSubtitle');
      if (subtitle) subtitle.textContent = `Korlap: ${korlapName} · PML: ${name} · ${rows.length} PCL bawahan`;

      return `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres Muatan')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalSubSLS} SubSLS total · ${totalSelesai} selesai</span>
          </div>
          ${makeProgressBar(totalUsaha, totalMuatan, 'var(--accent-blue)')}
        </div>
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres FASIH (Submit + Approve + Reject)')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalFasihAll.toLocaleString('id-ID')} / ${totalFasihTarget.toLocaleString('id-ID')} entri</span>
          </div>
          ${makeProgressBar(totalFasihAll, totalFasihTarget, '#22c55e')}
          ${makeFasihCards(totalDraft, totalSubmit, totalApprove, totalReject)}
        </div>
        ${rows.length > 0 ? `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Rincian Per PCL')}
          <div style="margin-top:8px; display:flex; flex-direction:column; gap:6px;">
            ${rows.map(r => {
              const pct = r.total_muatan > 0 ? ((r.usaha_total / r.total_muatan)*100).toFixed(1) : '0.0';
              return `<div style="display:flex; align-items:center; justify-content:space-between; padding:6px 0; border-bottom:1px solid var(--border);">
                <div>
                  <span style="font-size:12px; font-weight:500;">${r.pcl}</span>
                  <span style="font-size:10px; color:var(--text-muted); margin-left:6px;">${r.kecamatan}</span>
                </div>
                <span style="font-size:11px; color:var(--text-muted); font-family:monospace;">${r.usaha_total}/${r.total_muatan} (${pct}%)</span>
              </div>`;
            }).join('')}
          </div>
        </div>` : ''}
      `;
    };

    const renderPclDetails = (rows, name) => {
      // Aggregate totals from all SLS rows for this PCL
      const totalSubSLS = rows.length;
      const totalSelesai = rows.filter(r => r.sudah_diisi).length;
      const totalMuatan = rows.reduce((s, r) => s + (r.muatan || 0), 0);
      const totalUsaha = rows.reduce((s, r) => s + (r.usaha_total || 0), 0);
      const totalFasihTarget = rows.reduce((s, r) => s + (r.target_fasih || 0), 0);
      const totalDraft = rows.reduce((s, r) => s + (r.draft || 0), 0);
      const totalSubmit = rows.reduce((s, r) => s + (r.submitted_by_pcl || 0), 0);
      const totalApprove = rows.reduce((s, r) => s + (r.approved || 0), 0);
      const totalReject = rows.reduce((s, r) => s + (r.rejected || 0), 0);
      const totalFasihAll = totalDraft + totalSubmit + totalApprove + totalReject;

      const pmlName = rows.length > 0 ? rows[0].pml : '-';
      const korlapName = rows.length > 0 ? rows[0].korlap : '-';

      const subtitle = document.getElementById('globalDetailModalSubtitle');
      if (subtitle) subtitle.textContent = `PML: ${pmlName} · Korlap: ${korlapName}`;

      return `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres Muatan')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalSelesai} / ${totalSubSLS} SubSLS selesai</span>
          </div>
          ${makeProgressBar(totalUsaha, totalMuatan, 'var(--accent-blue)')}
        </div>
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader('Progres FASIH (Submit + Approve + Reject)')}
          <div style="display:flex; align-items:baseline; gap:6px; margin-top:4px;">
            <span style="font-size:13px; color:var(--text-muted);">${totalFasihAll.toLocaleString('id-ID')} / ${totalFasihTarget.toLocaleString('id-ID')} entri</span>
          </div>
          ${makeProgressBar(totalFasihAll, totalFasihTarget, '#22c55e')}
          ${makeFasihCards(totalDraft, totalSubmit, totalApprove, totalReject)}
        </div>
        ${rows.length > 0 ? `
        <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:12px; padding:14px 16px;">
          ${makeSectionHeader(`Daftar SubSLS (${totalSubSLS} SLS)`)}
          <div style="overflow-y:auto; max-height:200px; margin-top:8px;">
            <table style="width:100%; font-size:11px; border-collapse:collapse;">
              <thead><tr style="color:var(--text-muted); border-bottom:1px solid var(--border);">
                <th style="padding:4px 6px; text-align:left; font-weight:600;">SLS</th>
                <th style="padding:4px 6px; text-align:right; font-weight:600;">Muatan</th>
                <th style="padding:4px 6px; text-align:right; font-weight:600;">FASIH</th>
                <th style="padding:4px 6px; text-align:center; font-weight:600;">Status</th>
              </tr></thead>
              <tbody>
                ${rows.map((r, i) => `
                  <tr style="${i%2===1?'background:var(--bg-tertiary,rgba(255,255,255,0.03));':''}">
                    <td style="padding:4px 6px;">${r.nama_sls}<br><span style="font-size:9px; color:var(--text-muted); font-family:monospace;">${r.kode}</span></td>
                    <td style="padding:4px 6px; text-align:right; font-family:monospace;">${r.usaha_total}/${r.muatan}</td>
                    <td style="padding:4px 6px; text-align:right; font-family:monospace;">${r.approved}/${r.target_fasih}</td>
                    <td style="padding:4px 6px; text-align:center;"><span style="font-size:9px; padding:2px 6px; border-radius:999px; background:${r.sudah_diisi ? 'rgba(34,197,94,0.15)' : 'rgba(107,114,128,0.15)'}; color:${r.sudah_diisi ? '#22c55e' : '#9ca3af'};">${r.sudah_diisi ? 'Selesai' : 'Progres'}</span></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>` : ''}
      `;
    };

    // Intercept click on PML/PCL/Korlap links — works inside expanded table or any table on page
    function openDetailModal(type, name) {
      const modal = document.getElementById('globalDetailModal');
      const modalTitle = document.getElementById('globalDetailModalTitle');
      const modalSubtitle = document.getElementById('globalDetailModalSubtitle');
      const modalBody = document.getElementById('globalDetailModalBody');

      const typeLabel = type === 'korlap' ? 'Korlap' : type === 'pml' ? 'PML' : 'PCL';
      modalTitle.innerHTML = `<i class="bi bi-person-bounding-box"></i> Rincian Tugas SLS: ${name}`;
      if (modalSubtitle) modalSubtitle.textContent = 'Memuat data...';
      modalBody.innerHTML = `
        <div style="display:flex; justify-content:center; align-items:center; padding:40px; gap:12px; color:var(--text-muted);">
          <div style="border:3px solid var(--border); border-top:3px solid var(--accent-blue); border-radius:50%; width:24px; height:24px; animation:gdm-spin 0.8s linear infinite;"></div>
          <span>Memuat rincian data...</span>
        </div>
        <style>@keyframes gdm-spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}</style>
      `;
      modal.style.display = 'flex';

      fetch(`/api/detail/${type}?name=${encodeURIComponent(name)}`)
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            modalBody.innerHTML = `<div class="alert alert-error">${data.error}</div>`;
            return;
          }
          if (data.length === 0) {
            modalBody.innerHTML = `<div style="padding:40px; text-align:center; color:var(--text-muted);"><i class="bi bi-inbox" style="font-size:32px;"></i><br><br>Tidak ada data yang ditemukan untuk <strong>${name}</strong>.</div>`;
            return;
          }
          if (type === 'korlap') {
            modalBody.innerHTML = renderKorlapDetails(data, name);
          } else if (type === 'pml') {
            modalBody.innerHTML = renderPmlDetails(data, name);
          } else if (type === 'pcl') {
            modalBody.innerHTML = renderPclDetails(data, name);
          }
        })
        .catch(err => {
          console.error(err);
          modalBody.innerHTML = `<div class="alert alert-error">Gagal memuat data: ${err.message}</div>`;
        });
    }

    document.addEventListener('click', (e) => {
      const a = e.target.closest('a');
      if (!a) return;

      // Works inside expanded table cards
      const card = a.closest('.card.card-expanded');
      if (!card) return;

      const href = a.getAttribute('href');
      if (!href) return;

      let type = '';
      let name = '';

      // Use URL parsing for robust multi-param extraction
      try {
        const url = new URL(href, window.location.origin);
        const path = url.pathname;
        if (path === '/korlap' && url.searchParams.has('korlap')) {
          type = 'korlap';
          name = url.searchParams.get('korlap');
        } else if (path === '/pml' && url.searchParams.has('pml')) {
          type = 'pml';
          name = url.searchParams.get('pml');
        } else if (path === '/pcl' && url.searchParams.has('pcl')) {
          type = 'pcl';
          name = url.searchParams.get('pcl');
        }
      } catch (_) {
        // Fallback: ignore malformed URLs
      }

      if (type && name) {
        e.preventDefault();
        openDetailModal(type, name);
      }
    });

    // Close Modal Events
    const detailModal = document.getElementById('globalDetailModal');
    const closeDetailModalBtn = document.getElementById('btnCloseGlobalDetailModal');
    if (detailModal && closeDetailModalBtn) {
      const closeDetailModal = () => {
        detailModal.style.display = 'none';
      };
      closeDetailModalBtn.addEventListener('click', closeDetailModal);
      detailModal.addEventListener('click', (e) => {
        if (e.target === detailModal) closeDetailModal();
      });
    }

    // Close expanded table on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const modal = document.getElementById('globalDetailModal');
        if (modal && modal.style.display === 'flex') {
          modal.style.display = 'none';
          e.stopPropagation();
          e.preventDefault();
          return;
        }

        const expandedCard = document.querySelector('.card.card-expanded');
        if (expandedCard) {
          const btn = expandedCard.querySelector('.btn-expand-table');
          const closeOverlayBtn = expandedCard.querySelector('.btn-close-expand-overlay');
          if (btn) {
            toggleCardExpand(expandedCard, btn, closeOverlayBtn);
          }
        }
      }
    }, true);
  });
</script>
<%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
