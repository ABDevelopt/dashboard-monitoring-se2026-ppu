<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
  .map-container-wrap {
    display: flex;
    gap: 20px;
    height: calc(100vh - var(--header-height) - 75px);
    min-height: 520px;
    margin-top: 15px;
  }
  
  .map-sidebar-panel {
    width: 340px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    overflow-y: auto;
    padding-right: 4px;
    flex-shrink: 0;
  }

  .map-canvas-container {
    flex: 1;
    position: relative;
    height: 100%;
  }

  #map {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    box-shadow: var(--shadow);
    z-index: 10;
  }

  .map-legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    margin-bottom: 6px;
  }

  .map-legend-color {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .loading-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(21, 21, 27, 0.7);
    z-index: 99;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: var(--radius);
    transition: opacity 0.3s ease;
    pointer-events: none;
    opacity: 1;
    color: var(--text-primary);
  }

  body.light-mode .loading-overlay {
    background: rgba(245, 239, 230, 0.7);
  }

  .spinner {
    border: 4px solid rgba(255,255,255,0.1);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border-left-color: var(--accent-blue);
    animation: spin 1s linear infinite;
    margin-bottom: 12px;
  }

  body.light-mode .spinner {
    border-color: rgba(60, 51, 46, 0.1);
    border-left-color: var(--accent-blue);
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .info-table {
    width: 100%;
    margin-top: 10px;
    border-collapse: collapse;
    font-size: 12px;
  }

  .info-table td {
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .info-table td.label {
    font-weight: 500;
    color: var(--text-primary);
    width: 45%;
  }

  .info-table td.value {
    text-align: right;
    font-weight: 600;
  }

  .leaflet-popup-content-wrapper {
    background: var(--bg-card) !important;
    color: var(--text-primary) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-sm) !important;
    font-family: 'Inter', system-ui, sans-serif !important;
    box-shadow: var(--shadow-lg) !important;
  }

  .leaflet-popup-tip {
    background: var(--bg-card) !important;
    border-left: 1px solid var(--border) !important;
    border-bottom: 1px solid var(--border) !important;
  }

  .leaflet-container a.leaflet-popup-close-button {
    color: var(--text-secondary) !important;
  }

  .leaflet-bar {
    border: 1px solid var(--border) !important;
    box-shadow: var(--shadow) !important;
    border-radius: var(--radius-sm) !important;
    overflow: hidden;
  }

  .leaflet-bar a {
    background-color: var(--bg-card) !important;
    color: var(--text-primary) !important;
    border-bottom: 1px solid var(--border) !important;
  }

  .leaflet-bar a:hover {
    background-color: var(--bg-card-hover) !important;
    color: var(--accent-blue) !important;
  }

  .map-layer-selector {
    display: flex;
    background: var(--bg-summary);
    border-radius: var(--radius-sm);
    padding: 3px;
    margin-top: 8px;
    border: 1px solid var(--border);
  }

  .map-layer-btn {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    padding: 8px 12px;
    font-size: 12px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: var(--transition);
  }

  .map-layer-btn.active {
    background: var(--bg-card);
    color: var(--accent-blue);
    box-shadow: var(--shadow);
  }

  .map-card-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .map-card-stat:last-child {
    border-bottom: none;
  }
  .map-card-label {
    font-size: 12px;
    color: var(--text-secondary);
  }
  .map-card-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  @media (max-width: 992px) {
    .map-container-wrap {
      flex-direction: column;
      height: auto;
    }
    .map-sidebar-panel {
      width: 100%;
      height: auto;
      overflow-y: visible;
    }
    .map-canvas-container {
      height: 480px;
    }
  }
</style>

<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>
    <div class="map-container-wrap">
      
      <!-- SIDEBAR PANEL -->
      <div class="map-sidebar-panel">
        
        <!-- CONTROL CARD -->
        <div class="card" style="margin-bottom: 0;">
          <div class="card-header" style="margin-bottom: 10px; padding-bottom: 0;">
            <div class="card-title"><i class="bi bi-sliders"></i> Kontrol Wilayah</div>
          </div>
          
          <div class="form-group" style="margin-bottom: 12px;">
            <label for="kecFilter" style="font-size: 12px; font-weight: 500; margin-bottom: 6px; display: block; color: var(--text-secondary);">Kecamatan</label>
            <select id="kecFilter" style="width: 100%; padding: 8px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-card); color: var(--text-primary); cursor: pointer; transition: var(--transition);">
              <option value="">-- Tampilkan Semua --</option>
              <option value="BABULU">Kec. Babulu</option>
              <option value="WARU">Kec. Waru</option>
              <option value="PENAJAM">Kec. Penajam</option>
              <option value="SEPAKU">Kec. Sepaku</option>
            </select>
          </div>

          <div class="form-group">
            <label style="font-size: 12px; font-weight: 500; margin-bottom: 6px; display: block; color: var(--text-secondary);">Tingkat Wilayah</label>
            <div class="map-layer-selector">
              <button id="btnLayerDesa" class="map-layer-btn active">Batas Desa</button>
              <button id="btnLayerSls" class="map-layer-btn">Batas SLS</button>
            </div>
          </div>
        </div>

        <!-- STATS CARD -->
        <div class="card" style="margin-bottom: 0;">
          <div class="card-header" style="margin-bottom: 10px; padding-bottom: 0;">
            <div class="card-title"><i class="bi bi-card-list"></i> Informasi Wilayah</div>
          </div>
          <div id="mapSummaryStats">
            <div style="font-size: 12px; color: var(--text-muted); text-align: center; padding: 20px 0;">
              <i class="bi bi-geo-alt" style="font-size: 24px; color: var(--text-muted); display: block; margin-bottom: 8px;"></i>
              Klik suatu wilayah pada peta untuk memuat data progres kinerja di sini.
            </div>
          </div>
        </div>

        <!-- LEGEND CARD -->
        <div class="card" style="margin-bottom: 0;">
          <div class="card-header" style="margin-bottom: 10px; padding-bottom: 0;">
            <div class="card-title"><i class="bi bi-info-circle"></i> Legenda Warna</div>
          </div>
          
          <div id="legendDesa">
            <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px;">Persentase Progres SLS Selesai:</div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #10b981;"></div><span>100% Selesai</span></div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #0284c7;"></div><span>75% - 99% Selesai</span></div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #eab308;"></div><span>25% - 74% Selesai</span></div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #f97316;"></div><span>1% - 24% Selesai</span></div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #ef4444;"></div><span>0% Selesai / Belum Ada Progres</span></div>
          </div>

          <div id="legendSls" style="display: none;">
            <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px;">Status SLS/SubSLS:</div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #10b981;"></div><span>Selesai Pencacahan</span></div>
            <div class="map-legend-item"><div class="map-legend-color" style="background: #ef4444;"></div><span>Belum Selesai</span></div>
          </div>
        </div>

      </div>

      <!-- MAP CANVAS -->
      <div class="map-canvas-container">
        <div id="mapLoading" class="loading-overlay">
          <div class="spinner"></div>
          <div id="loadingStatusText" style="font-size: 13px; font-weight: 500;">Memuat Peta dan Data Batas Wilayah...</div>
        </div>
        <div id="map"></div>
      </div>

    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Initial setup
        const centerCoords = [-1.30, 116.65];
        const defaultZoom = 10;
        
        const map = L.map('map', {
          zoomControl: true,
          maxZoom: 18,
          minZoom: 9
        }).setView(centerCoords, defaultZoom);

        // Basemaps (Light Mode / Dark Mode switcher)
        const lightBasemap = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
          subdomains: 'abcd'
        });

        const darkBasemap = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
          subdomains: 'abcd'
        });

        // Set current basemap based on body theme class
        function updateBasemap() {
          const isLight = document.body.classList.contains('light-mode');
          if (isLight) {
            if (map.hasLayer(darkBasemap)) map.removeLayer(darkBasemap);
            lightBasemap.addTo(map);
          } else {
            if (map.hasLayer(lightBasemap)) map.removeLayer(lightBasemap);
            darkBasemap.addTo(map);
          }
        }
        updateBasemap();

        // Listen for theme toggle events
        window.addEventListener('themechange', () => {
          updateBasemap();
          // Force update styles of map layers if loaded
          if (desaLayer) desaLayer.setStyle(desaStyle);
          if (slsLayer) slsLayer.setStyle(slsStyle);
        });

        // Data holders
        let desaGeoJson = null;
        let slsGeoJson = null;
        let desaStats = [];
        let slsStats = [];
        
        let desaLayer = null;
        let slsLayer = null;
        let activeLayerName = 'desa'; // 'desa' or 'sls'
        let currentFilteredKec = '';

        // UI Selectors
        const loadingOverlay = document.getElementById('mapLoading');
        const loadingText = document.getElementById('loadingStatusText');
        const kecFilter = document.getElementById('kecFilter');
        const btnLayerDesa = document.getElementById('btnLayerDesa');
        const btnLayerSls = document.getElementById('btnLayerSls');
        const legendDesa = document.getElementById('legendDesa');
        const legendSls = document.getElementById('legendSls');
        const sidebarStats = document.getElementById('mapSummaryStats');

        // Styles
        function getBorderColor() {
          return document.body.classList.contains('light-mode') ? '#ffffff' : '#1b1b24';
        }

        function getHoverBorderColor() {
          return 'var(--accent-cyan)';
        }

        // Color coding function for Desa
        function getDesaColor(iddesa) {
          const stat = desaStats.find(s => s.iddesa === iddesa);
          if (!stat) return '#94a3b8'; // gray for no data
          const pct = stat.total_subsls ? (stat.selesai / stat.total_subsls) * 100 : 0;
          if (pct === 100) return '#10b981'; // Green
          if (pct >= 75) return '#0284c7';  // Blue
          if (pct >= 25) return '#eab308';  // Yellow
          if (pct > 0) return '#f97316';    // Orange
          return '#ef4444';                 // Red
        }

        // Color coding function for SLS
        function getSlsColor(kode) {
          const stat = slsStats.find(s => s.kode === kode);
          if (!stat) return '#94a3b8'; // gray
          return stat.selesai === 1 ? '#10b981' : '#ef4444';
        }

        // Styles for layers
        function desaStyle(feature) {
          const isSelectedKec = !currentFilteredKec || feature.properties.nmkec === currentFilteredKec;
          return {
            fillColor: getDesaColor(feature.properties.iddesa),
            weight: 1.5,
            opacity: isSelectedKec ? 1 : 0.08,
            color: getBorderColor(),
            fillOpacity: isSelectedKec ? 0.65 : 0.02
          };
        }

        function slsStyle(feature) {
          const isSelectedKec = !currentFilteredKec || feature.properties.nmkec === currentFilteredKec;
          return {
            fillColor: getSlsColor(feature.properties.kode),
            weight: 1.2,
            opacity: isSelectedKec ? 1 : 0.08,
            color: getBorderColor(),
            fillOpacity: isSelectedKec ? 0.6 : 0.02
          };
        }

        // Highlight features on hover
        function highlightFeature(e) {
          const layer = e.target;
          layer.setStyle({
            weight: 3,
            color: getHoverBorderColor(),
            fillOpacity: 0.8
          });
          if (!L.Browser.ie && !L.Browser.opera && !L.Browser.edge) {
            layer.bringToFront();
          }
        }

        function resetHighlightDesa(e) {
          desaLayer.resetStyle(e.target);
        }

        function resetHighlightSls(e) {
          slsLayer.resetStyle(e.target);
        }

        // Fit map bounds to filtered subdistrict
        function fitBoundsToKecamatan(kecName) {
          if (!kecName) {
            map.setView(centerCoords, defaultZoom);
            return;
          }

          const bounds = L.latLngBounds();
          const targetLayer = activeLayerName === 'desa' ? desaLayer : slsLayer;
          
          if (targetLayer) {
            targetLayer.eachLayer(layer => {
              if (layer.feature.properties.nmkec === kecName) {
                if (layer.getBounds) {
                  bounds.extend(layer.getBounds());
                } else if (layer.getLatLng) {
                  bounds.extend(layer.getLatLng());
                }
              }
            });
            
            if (bounds.isValid()) {
              map.fitBounds(bounds, { padding: [30, 30] });
            }
          }
        }

        // Show details in Sidebar
        function showDesaDetails(properties) {
          const stat = desaStats.find(s => s.iddesa === properties.iddesa);
          const total = stat ? stat.total_subsls : 0;
          const selesai = stat ? stat.selesai : 0;
          const pct = total ? ((selesai / total) * 100).toFixed(1) : '0.0';
          const totalMuatan = stat ? stat.total_muatan : 0;
          const usaha = stat ? stat.usaha_total : 0;
          const keluarga = stat ? stat.keluarga_total : 0;

          sidebarStats.innerHTML = `
            <div style="font-size: 13px; font-weight: 600; margin-bottom: 4px; color: var(--accent-blue);"><i class="bi bi-geo-alt-fill"></i> Desa/Kel. ${properties.nmdesa}</div>
            <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 12px;">Kecamatan ${properties.nmkec}</div>
            
            <div class="map-card-stat">
              <span class="map-card-label">Jumlah SubSLS</span>
              <span class="map-card-value">${total} SLS</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Selesai Pencacahan</span>
              <span class="map-card-value">${selesai} SLS</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Progres Capaian</span>
              <span class="map-card-value" style="color: ${selesai === total ? 'var(--accent-green)' : 'inherit'}">${pct}%</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Muatan Target</span>
              <span class="map-card-value">${totalMuatan.toLocaleString('id-ID')}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Total Usaha Terdata</span>
              <span class="map-card-value">${usaha.toLocaleString('id-ID')}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Total Keluarga Terdata</span>
              <span class="map-card-value">${keluarga.toLocaleString('id-ID')}</span>
            </div>

            <button class="btn btn-secondary btn-xs" id="btnFocusDesa" style="width: 100%; margin-top: 14px; display: flex; justify-content: center; gap: 6px;">
              <i class="bi bi-search"></i> Zoom & Tampilkan Batas SLS
            </button>
          `;

          // Focus Desa Button Listener
          document.getElementById('btnFocusDesa').addEventListener('click', () => {
            fitBoundsToDesa(properties.iddesa);
          });
        }

        function fitBoundsToDesa(iddesa) {
          let bounds = null;
          desaLayer.eachLayer(layer => {
            if (layer.feature.properties.iddesa === iddesa) {
              bounds = layer.getBounds();
            }
          });
          
          if (bounds) {
            map.fitBounds(bounds, { padding: [40, 40] });
            // Switch to SLS level
            switchToSlsLayer();
          }
        }

        function showSlsDetails(properties) {
          const stat = slsStats.find(s => s.kode === properties.kode);
          const isSelesai = stat ? stat.selesai === 1 : false;
          const muatan = stat ? stat.muatan : 0;
          const usaha = stat ? stat.usaha_total : 0;
          const keluarga = stat ? stat.keluarga_total : 0;
          const pcl = stat ? stat.pcl : 'Belum Ditentukan';
          const pml = stat ? stat.pml : 'Belum Ditentukan';
          const korlap = stat ? stat.korlap : 'Belum Ditentukan';

          sidebarStats.innerHTML = `
            <div style="font-size: 13px; font-weight: 600; margin-bottom: 4px; color: var(--accent-blue);"><i class="bi bi-box-seam"></i> SLS: ${properties.nmsls}</div>
            <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 12px;">Desa ${properties.nmdesa}, Kec. ${properties.nmkec}</div>
            
            <div class="map-card-stat">
              <span class="map-card-label">Kode SLS</span>
              <span class="map-card-value" style="font-family: monospace; font-size: 11px;">${properties.kode}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Status Pencacahan</span>
              <span class="map-card-value">${isSelesai ? '<span class="badge badge-green btn-xs">Selesai</span>' : '<span class="badge badge-red btn-xs">Belum Selesai</span>'}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Petugas PCL</span>
              <span class="map-card-value">${pcl}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Pengawas PML</span>
              <span class="map-card-value">${pml}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Atasan Korlap</span>
              <span class="map-card-value">${korlap}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Target Muatan</span>
              <span class="map-card-value">${muatan}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Usaha Terdata</span>
              <span class="map-card-value">${usaha.toLocaleString('id-ID')}</span>
            </div>
            <div class="map-card-stat">
              <span class="map-card-label">Keluarga Terdata</span>
              <span class="map-card-value">${keluarga.toLocaleString('id-ID')}</span>
            </div>
          `;
        }

        // Initialize Map GeoJSON layers
        function setupDesaLayer() {
          desaLayer = L.geoJSON(desaGeoJson, {
            style: desaStyle,
            onEachFeature: (feature, layer) => {
              layer.on({
                mouseover: highlightFeature,
                mouseout: resetHighlightDesa,
                click: (e) => {
                  showDesaDetails(feature.properties);
                  
                  // Open popup
                  const stat = desaStats.find(s => s.iddesa === feature.properties.iddesa);
                  const total = stat ? stat.total_subsls : 0;
                  const selesai = stat ? stat.selesai : 0;
                  const pct = total ? ((selesai / total) * 100).toFixed(1) : '0';
                  
                  const popupHtml = `
                    <div style="font-family: 'Inter', sans-serif; min-width: 160px;">
                      <strong style="font-size: 13px; color: var(--text-primary);">Desa ${feature.properties.nmdesa}</strong><br>
                      <span style="font-size: 11px; color: var(--text-secondary);">Kec. ${feature.properties.nmkec}</span>
                      <table class="info-table">
                        <tr><td class="label">Progres</td><td class="value">${selesai} / ${total} SLS</td></tr>
                        <tr><td class="label">Persentase</td><td class="value">${pct}%</td></tr>
                      </table>
                    </div>
                  `;
                  layer.bindPopup(popupHtml).openPopup();
                }
              });
            }
          });
        }

        function setupSlsLayer() {
          slsLayer = L.geoJSON(slsGeoJson, {
            style: slsStyle,
            onEachFeature: (feature, layer) => {
              layer.on({
                mouseover: highlightFeature,
                mouseout: resetHighlightSls,
                click: (e) => {
                  showSlsDetails(feature.properties);
                  
                  const stat = slsStats.find(s => s.kode === feature.properties.kode);
                  const status = stat && stat.selesai === 1 ? 'Selesai' : 'Belum Selesai';
                  
                  const popupHtml = `
                    <div style="font-family: 'Inter', sans-serif; min-width: 180px;">
                      <strong style="font-size: 13px; color: var(--text-primary);">${feature.properties.nmsls}</strong><br>
                      <span style="font-size: 11px; color: var(--text-secondary);">${feature.properties.nmdesa}, ${feature.properties.nmkec}</span>
                      <table class="info-table">
                        <tr><td class="label">PCL</td><td class="value">${stat ? stat.pcl : '-'}</td></tr>
                        <tr><td class="label">Status</td><td class="value" style="color: ${status === 'Selesai' ? 'var(--accent-green)' : 'var(--accent-red)'}">${status}</td></tr>
                        <tr><td class="label">Usaha</td><td class="value">${stat ? stat.usaha_total : 0}</td></tr>
                      </table>
                    </div>
                  `;
                  layer.bindPopup(popupHtml).openPopup();
                }
              });
            }
          });
        }

        // Asynchronous bootstrap sequence
        async function bootstrap() {
          try {
            // Step 1: load real-time stats and Desa geojson in parallel
            const [statsRes, desaGeoRes] = await Promise.all([
              fetch('/api/map-stats'),
              fetch('/data/desa_boundaries.geojson')
            ]);
            
            const stats = await statsRes.json();
            desaStats = stats.desaStats;
            slsStats = stats.slsStats;
            desaGeoJson = await desaGeoRes.json();

            // Setup Desa boundary mapping layer
            setupDesaLayer();
            desaLayer.addTo(map);

            // Hide initial loading screen
            loadingOverlay.style.opacity = '0';
            setTimeout(() => { loadingOverlay.style.display = 'none'; }, 300);

            // Lazy load high-detail SLS boundaries in background
            lazyLoadSlsGeoJSON();

          } catch (err) {
            console.error('Error bootstrapping map:', err);
            loadingText.innerHTML = '<span style="color: var(--accent-red);"><i class="bi bi-exclamation-triangle"></i> Gagal Memuat Data Spasial. Coba refresh halaman.</span>';
          }
        }

        async function lazyLoadSlsGeoJSON() {
          try {
            const res = await fetch('/data/sls_boundaries.geojson');
            slsGeoJson = await res.json();
            setupSlsLayer();
            console.log('SLS Boundaries lazy loaded successfully!');
          } catch (err) {
            console.error('Error lazy loading SLS geojson:', err);
          }
        }

        // Layer Toggling Logic
        function switchToDesaLayer() {
          activeLayerName = 'desa';
          btnLayerSls.classList.remove('active');
          btnLayerDesa.classList.add('active');
          legendSls.style.display = 'none';
          legendDesa.style.display = 'block';

          if (slsLayer && map.hasLayer(slsLayer)) map.removeLayer(slsLayer);
          if (desaLayer) {
            desaLayer.addTo(map);
            desaLayer.setStyle(desaStyle);
          }
        }

        function switchToSlsLayer() {
          if (!slsGeoJson) {
            alert('Data batas SLS sedang diunduh di latar belakang. Silakan tunggu beberapa detik...');
            return;
          }
          activeLayerName = 'sls';
          btnLayerDesa.classList.remove('active');
          btnLayerSls.classList.add('active');
          legendDesa.style.display = 'none';
          legendSls.style.display = 'block';

          if (desaLayer && map.hasLayer(desaLayer)) map.removeLayer(desaLayer);
          if (slsLayer) {
            slsLayer.addTo(map);
            slsLayer.setStyle(slsStyle);
          }
        }

        btnLayerDesa.addEventListener('click', switchToDesaLayer);
        btnLayerSls.addEventListener('click', switchToSlsLayer);

        // Filter Dropdown Listener
        kecFilter.addEventListener('change', (e) => {
          currentFilteredKec = e.target.value;
          
          if (desaLayer) desaLayer.setStyle(desaStyle);
          if (slsLayer) slsLayer.setStyle(slsStyle);

          fitBoundsToKecamatan(currentFilteredKec);
        });

        // Initialize!
        bootstrap();
      });
    </script>
  <% } %>
</div>
