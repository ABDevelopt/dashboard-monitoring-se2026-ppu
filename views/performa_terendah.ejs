<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>
    
    <!-- FILTER BAR -->
    <div class="card" style="margin-bottom: 20px;">
      <div class="card-header" style="margin-bottom: 8px; padding-bottom: 8px;">
        <div class="card-title"><i class="bi bi-search"></i> Filter Pencarian Performa Terendah</div>
        <a href="/performa-terendah" class="btn btn-secondary btn-xs"><i class="bi bi-arrow-repeat"></i> Reset Filter</a>
      </div>
      
      <form action="/performa-terendah" method="GET" id="filterForm">
        <div class="filter-form-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 180px), 1fr)); gap: 10px;">
          
          <div>
            <label style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Kecamatan</label>
            <select name="kec" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua Kecamatan --</option>
              <% kecList.forEach(k => { %>
                <option value="<%= k.kecamatan %>" <%= filterKec === k.kecamatan ? 'selected' : '' %>><%= k.kecamatan %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Koordinator Lapangan</label>
            <select name="korlap" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua Korlap --</option>
              <% korlapList.forEach(k => { %>
                <option value="<%= k.korlap %>" <%= filterKorlap === k.korlap ? 'selected' : '' %>><%= k.korlap %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">PML (Pengawas)</label>
            <select name="pml" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua PML --</option>
              <% pmlList.forEach(p => { %>
                <option value="<%= p.pml %>" <%= filterPml === p.pml ? 'selected' : '' %>><%= p.pml %></option>
              <% }) %>
            </select>
          </div>
          
        </div>
      </form>
    </div>

    <!-- GRID DUA KOLOM UNTUK PCL DAN PML -->
    <div class="drilldown-grid">
      
      <!-- KOLOM KIRI: BOTTOM 5 PCL -->
      <div>
        <div class="card" style="margin-bottom: 20px;">
          <div class="card-header">
            <div class="card-title"><i class="bi bi-arrow-down-circle-fill" style="color: var(--accent-red);"></i> 5 PCL Performa Terendah</div>
            <span class="badge badge-red">Pencacah Lapangan</span>
          </div>
          
          <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 16px;">
            Peringkat PCL ditentukan berdasarkan gabungan total muatan usaha (usaha ditemukan + baru) dan keluarga (keluarga ditemukan + baru) yang dicatat (diurutkan dari yang paling sedikit).
          </p>

          <% if (performers.bottomPcl && performers.bottomPcl.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <% performers.bottomPcl.forEach((item, index) => { %>
                <% 
                  let borderClass = 'border: 1px solid var(--border);';
                  let statusIcon = '<i class="bi bi-arrow-down-circle"></i>';
                  let iconColor = 'var(--accent-red)';
                  
                  if (index === 0) { 
                    borderClass = 'border: 1px solid #ef4444; background: rgba(239,68,68,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-triangle-fill"></i>';
                  } else if (index === 1) { 
                    borderClass = 'border: 1px solid #f97316; background: rgba(249,115,22,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-circle-fill"></i>';
                    iconColor = '#f97316';
                  } else if (index === 2) { 
                    borderClass = 'border: 1px solid #eab308; background: rgba(234,179,8,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-circle-fill"></i>';
                    iconColor = '#eab308';
                  }
                %>
                
                <div class="warning-card danger" style="<%= borderClass %> margin-bottom: 0;">
                  <div class="warning-icon" style="font-size: 26px; color: <%= iconColor %>;"><%- statusIcon %></div>
                  <div class="warning-body" style="width: 100%;">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                      <span class="warning-name">Posisi <%= index + 1 %>: <%= item.pcl %></span>
                      <span class="badge badge-red"><%= (item.usaha_total + item.keluarga_total).toLocaleString('id-ID') %> (Usaha + Kel)</span>
                    </div>
                    <div class="warning-meta">
                      Kec. <strong><%= item.kecamatan %></strong> · PML: <strong><%= item.pml %></strong> · Korlap: <strong><%= item.korlap %></strong>
                    </div>
                    <div class="warning-stats">
                      <span class="warning-stat"><i class="bi bi-building text-green"></i> Usaha: <strong><%= item.usaha_total %></strong></span>
                      <span class="warning-stat"><i class="bi bi-people text-cyan"></i> Keluarga: <strong><%= item.keluarga_total %></strong></span>
                      <span class="warning-stat">Progres: <strong><%= item.pct %>%</strong></span>
                    </div>
                    <div class="fasih-grid-container">
                      <div class="fasih-grid-header">
                        <span class="fasih-grid-title"><i class="bi bi-phone"></i> FASIH</span>
                        <span class="badge badge-blue">Target: <%= item.target_fasih_total %></span>
                      </div>
                      <div class="fasih-grid">
                        <div class="fasih-grid-item fasih-item-draft">
                          <div class="fasih-grid-item-label">Draft</div>
                          <div class="fasih-grid-item-value"><%= item.draft_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-submit">
                          <div class="fasih-grid-item-label">Submit</div>
                          <div class="fasih-grid-item-value"><%= item.submitted_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-approve">
                          <div class="fasih-grid-item-label">Approve</div>
                          <div class="fasih-grid-item-value"><%= item.approved_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-reject">
                          <div class="fasih-grid-item-label">Reject</div>
                          <div class="fasih-grid-item-value"><%= item.rejected_total %></div>
                        </div>
                      </div>
                    </div>
                    <div class="progress-bar-wrap" style="height: 6px; margin-top: 10px;">
                      <div class="progress-bar red" data-width="<%= item.pct %>" style="width: 0%;"></div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="no-data">Belum ada data performa PCL.</div>
          <% } %>
        </div>
      </div>

      <!-- KOLOM KANAN: BOTTOM 5 PML -->
      <div>
        <div class="card" style="margin-bottom: 20px;">
          <div class="card-header">
            <div class="card-title"><i class="bi bi-arrow-down-circle-fill" style="color: var(--accent-red);"></i> 5 PML Performa Terendah</div>
            <span class="badge badge-red">Pengawas Lapangan</span>
          </div>

          <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 16px;">
            Peringkat PML ditentukan berdasarkan gabungan total muatan usaha dan keluarga yang dicatat oleh tim PCL di bawah pengawasannya (diurutkan dari yang paling sedikit).
          </p>

          <% if (performers.bottomPml && performers.bottomPml.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <% performers.bottomPml.forEach((item, index) => { %>
                <% 
                  let borderClass = 'border: 1px solid var(--border);';
                  let statusIcon = '<i class="bi bi-arrow-down-circle"></i>';
                  let iconColor = 'var(--accent-red)';
                  
                  if (index === 0) { 
                    borderClass = 'border: 1px solid #ef4444; background: rgba(239,68,68,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-triangle-fill"></i>';
                  } else if (index === 1) { 
                    borderClass = 'border: 1px solid #f97316; background: rgba(249,115,22,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-circle-fill"></i>';
                    iconColor = '#f97316';
                  } else if (index === 2) { 
                    borderClass = 'border: 1px solid #eab308; background: rgba(234,179,8,0.03);'; 
                    statusIcon = '<i class="bi bi-exclamation-circle-fill"></i>';
                    iconColor = '#eab308';
                  }
                %>
                
                <div class="warning-card danger" style="<%= borderClass %> margin-bottom: 0;">
                  <div class="warning-icon" style="font-size: 26px; color: <%= iconColor %>;"><%- statusIcon %></div>
                  <div class="warning-body" style="width: 100%;">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                      <span class="warning-name">Posisi <%= index + 1 %>: <%= item.pml %></span>
                      <span class="badge badge-red"><%= (item.usaha_total + item.keluarga_total).toLocaleString('id-ID') %> (Usaha + Kel)</span>
                    </div>
                    <div class="warning-meta">
                      Tim Korlap: <strong><%= item.korlap %></strong>
                    </div>
                    <div class="warning-stats">
                      <span class="warning-stat"><i class="bi bi-building text-green"></i> Usaha: <strong><%= item.usaha_total %></strong></span>
                      <span class="warning-stat"><i class="bi bi-people text-cyan"></i> Keluarga: <strong><%= item.keluarga_total %></strong></span>
                      <span class="warning-stat">Progres: <strong><%= item.pct %>%</strong></span>
                    </div>
                    <div class="fasih-grid-container">
                      <div class="fasih-grid-header">
                        <span class="fasih-grid-title"><i class="bi bi-phone"></i> FASIH</span>
                        <span class="badge badge-blue">Target: <%= item.target_fasih_total %></span>
                      </div>
                      <div class="fasih-grid">
                        <div class="fasih-grid-item fasih-item-draft">
                          <div class="fasih-grid-item-label">Draft</div>
                          <div class="fasih-grid-item-value"><%= item.draft_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-submit">
                          <div class="fasih-grid-item-label">Submit</div>
                          <div class="fasih-grid-item-value"><%= item.submitted_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-approve">
                          <div class="fasih-grid-item-label">Approve</div>
                          <div class="fasih-grid-item-value"><%= item.approved_total %></div>
                        </div>
                        <div class="fasih-grid-item fasih-item-reject">
                          <div class="fasih-grid-item-label">Reject</div>
                          <div class="fasih-grid-item-value"><%= item.rejected_total %></div>
                        </div>
                      </div>
                    </div>
                    <div class="progress-bar-wrap" style="height: 6px; margin-top: 10px;">
                      <div class="progress-bar red" data-width="<%= item.pct %>" style="width: 0%;"></div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="no-data">Belum ada data performa PML.</div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- BANNER PENJELASAN PENENTUAN PERFORMA -->
    <details class="card" style="margin-top: 20px; border-left: 4px solid var(--accent-red); background: rgba(239, 68, 68, 0.05); padding: 16px 20px; cursor: pointer;">
      <summary style="display: flex; gap: 14px; align-items: center; font-weight: 600; color: var(--text-primary); list-style: none; outline: none; user-select: none;">
        <style>
          details summary::-webkit-details-marker { display: none; }
          details[open] .bi-chevron-down { transform: rotate(180deg); }
          .bi-chevron-down { transition: transform 0.2s ease; }
        </style>
        <div style="font-size: 22px; color: var(--accent-red); display: flex; align-items: center; justify-content: center; height: 24px;"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div style="flex: 1; display: flex; justify-content: space-between; align-items: center; min-width: 0;">
          <span style="font-size: 14px; font-weight: 700; color: var(--text-primary);">Penjelasan Penentuan Performa Terendah</span>
          <span style="font-size: 12px; color: var(--text-secondary); font-weight: 500; display: flex; align-items: center; gap: 4px; flex-shrink: 0;">
            Klik untuk detail <i class="bi bi-chevron-down"></i>
          </span>
        </div>
      </summary>
      <div style="margin-top: 12px; padding-left: 36px; cursor: default;" onclick="event.stopPropagation()">
        <p style="margin: 0; font-size: 13px; color: var(--text-secondary); line-height: 1.5;">
          Urutan petugas dengan performa terendah dihitung dan diurutkan menggunakan kriteria berikut:
        </p>
        <ul style="margin: 8px 0 0 0; padding-left: 20px; font-size: 12px; color: var(--text-secondary); line-height: 1.6;">
          <li><strong>Metrik Utama:</strong> Diurutkan mulai dari total volume gabungan hasil pencacahan terkecil, yaitu: <code style="background: var(--bg-warning-stat); border: 1px solid var(--border); padding: 2px 4px; border-radius: 4px; font-family: monospace;">(Usaha Ditemukan + Usaha Baru) + (Keluarga Ditemukan + Keluarga Baru)</code>.</li>
          <li><strong>Konsolidasi Petugas:</strong> Pengelompokan data petugas bersifat <em>case-insensitive</em> (mengabaikan perbedaan huruf besar/kecil) untuk memastikan data petugas dengan variasi penulisan nama tetap teragregasi menjadi satu.</li>
          <li><strong>Aturan Pemecah Seri (Tie-Breaker):</strong> Jika dua atau lebih petugas memiliki total volume gabungan yang sama, posisi terendah (teratas pada daftar ini) ditentukan berturut-turut berdasarkan:
            <ol style="margin-top: 4px; padding-left: 16px; list-style-type: decimal;">
              <li>Jumlah volume usaha terkecil (usaha_total paling sedikit).</li>
              <li>Jumlah target/beban muatan awal <code style="background: var(--bg-warning-stat); border: 1px solid var(--border); padding: 2px 4px; border-radius: 4px; font-family: monospace;">total_muatan</code> terbesar (beban kerja terbesar dengan hasil pencacahan terkecil dianggap performa lebih rendah).</li>
            </ol>
          </li>
        </ul>
      </div>
    </details>

  <% } %>
</div>
