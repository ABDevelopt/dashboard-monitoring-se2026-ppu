<div class="fade-in">
  
  <!-- MASTER STATS GRID -->
  <div class="stats-grid">
    <div class="stat-card blue">
      <div class="stat-icon"><i class="bi bi-database"></i></div>
      <div class="stat-label">Total SLS Master</div>
      <div class="stat-value"><%= stats.total_subsls.toLocaleString('id-ID') %></div>
      <div class="stat-sub">Subelemen SLS Terdaftar</div>
    </div>
    <div class="stat-card cyan">
      <div class="stat-icon"><i class="bi bi-geo-alt"></i></div>
      <div class="stat-label">Kecamatan / Desa</div>
      <div class="stat-value"><%= stats.total_kec %> / <%= stats.total_desa %></div>
      <div class="stat-sub">Wilayah Terdaftar</div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
      <div class="stat-label">Korlap / PML / PCL</div>
      <div class="stat-value"><%= stats.total_korlap %> / <%= stats.total_pml %> / <%= stats.total_pcl %></div>
      <div class="stat-sub">Jumlah Petugas Lapangan</div>
    </div>
    <div class="stat-card yellow">
      <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
      <div class="stat-label">Total Target Muatan</div>
      <div class="stat-value"><%= (stats.total_muatan || 0).toLocaleString('id-ID') %></div>
      <div class="stat-sub">Muatan Assignment Sensus</div>
    </div>
  </div>

  <!-- MANAGE ROW: UPLOAD & ACTIONS -->
  <div class="overview-grid mt-4">
    <!-- UPLOAD MASTER DATA CARD -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-upload"></i> Upload Master Data Baru</div>
      </div>
      
      <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 16px;">
        Unggah file **JSON** (bawaan kelompok populasi) atau file **Excel (.xlsx/.xls)** untuk menimpa seluruh master data saat ini.
        Excel harus berisi header kolom: `kode`, `kecamatan`, `desa`, `nama_sls`, `korlap`, `pml`, `pcl`, `muatan` (target muatan).
      </p>

      <form action="/admin/master/upload" method="POST" enctype="multipart/form-data">
        <div class="upload-zone" id="masterUploadZone" style="padding: 30px 20px; border: 2px dashed var(--border); border-radius: var(--radius); text-align: center; cursor: pointer; transition: var(--transition);">
          <input type="file" name="masterFile" id="masterFileInput" accept=".json,.xlsx,.xls" style="display: none;" required>
          <div style="font-size: 32px; color: var(--accent-cyan); margin-bottom: 10px;"><i class="bi bi-cloud-arrow-up-fill"></i></div>
          <div class="upload-zone-text" style="font-size: 13px; font-weight: 600;">Pilih file JSON atau Excel master data</div>
          <div class="upload-zone-sub" style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">Format file: .json, .xlsx, .xls (Maks. 50MB)</div>
        </div>
        
        <div style="display: flex; gap: 8px; margin-top: 16px;">
          <button type="submit" class="btn btn-primary" style="flex: 1; justify-content: center;"><i class="bi bi-check-circle-fill"></i> Proses Impor Master</button>
        </div>
      </form>
    </div>

    <!-- UTILITIES / RESTORE DEFAULT CARD -->
    <div class="card" style="display: flex; flex-direction: column; justify-content: space-between;">
      <div>
        <div class="card-header">
          <div class="card-title"><i class="bi bi-arrow-counterclockwise"></i> Reset ke Master Data Default</div>
        </div>
        <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 20px; line-height: 1.5;">
          Gunakan tombol di bawah ini untuk mengembalikan tabel master data ke versi bawaan yang dimuat dari file `kelompok_populasi_pml_pcl_korlap_muatan.json`.
        </p>
        <div class="alert alert-error" style="background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.2); color: var(--accent-red); margin-bottom: 20px;">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span style="font-size: 11px; line-height: 1.3;">Aksi ini akan menghapus seluruh data master saat ini dan menggantinya dengan data default.</span>
        </div>
      </div>
      <form action="/master/reset" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin mengembalikan master data ke versi bawaan JSON? Seluruh perubahan manual akan terhapus.');">
        <button type="submit" class="btn btn-danger" style="width: 100%; justify-content: center;"><i class="bi bi-trash3-fill"></i> Reset ke Master Bawaan (JSON)</button>
      </form>
    </div>

  </div>

  <!-- TABLE OF SLS MASTER -->
  <div class="card mt-4">
    <div class="card-header">
      <div class="card-title"><i class="bi bi-table"></i> Daftar SLS Master Data</div>
      <button class="btn btn-success btn-sm" id="btnOpenAddModal"><i class="bi bi-plus-circle"></i> Tambah SLS Baru</button>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 16px;">
      <form action="/master" method="GET" style="display: flex; gap: 8px; flex: 1; min-width: 200px;">
        <input type="search" name="q" value="<%= q %>" placeholder="Cari Kode, SLS, Petugas, Wilayah..." aria-label="Cari Kode, SLS, Petugas, atau Wilayah" style="flex: 1; padding: 8px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); min-width: 0;">
        <button type="submit" class="btn btn-secondary" aria-label="Cari data SLS"><i class="bi bi-search"></i></button>
        <% if (q) { %>
          <a href="/master" class="btn btn-secondary" title="Reset Pencarian" aria-label="Reset pencarian dan tampilkan semua"><i class="bi bi-x-lg"></i></a>
        <% } %>
      </form>
      <div style="font-size: 12px; color: var(--text-secondary);">
        Menampilkan <%= data.length %> dari total <%= total %> SLS
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="hide-md">Kode SubSLS</th>
            <th>Kecamatan</th>
            <th>Desa/Kelurahan</th>
            <th>Nama SLS</th>
            <th class="hide-md">Korlap</th>
            <th class="hide-md">PML</th>
            <th class="hide-md">PCL</th>

            <th class="text-right">Target FASIH</th>
            <th class="text-right">Muatan</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach(row => { %>
              <tr>
                <td class="td-code hide-md"><%= row.kode %></td>
                <td><%= row.kecamatan %></td>
                <td><%= row.desa %></td>
                <td class="td-primary" style="font-weight: 500;"><%= row.nama_sls %></td>
                <td class="hide-md"><%= row.korlap %></td>
                <td class="hide-md"><%= row.pml %></td>
                <td class="hide-md"><%= row.pcl %></td>

                <td class="text-right bg-purple-soft" style="font-weight: 500;"><%= row.target_fasih %></td>
                <td class="text-right bg-cyan-soft fw-bold"><%= row.muatan %></td>
                <td class="text-center">
                  <div style="display: flex; justify-content: center; gap: 6px;">
                    <button class="btn btn-secondary btn-xs btn-edit-sls" 
                            data-kode="<%= row.kode %>" 
                            data-kecamatan="<%= row.kecamatan %>"
                            data-desa="<%= row.desa %>"
                            data-nama="<%= row.nama_sls %>"
                            data-korlap="<%= row.korlap %>"
                            data-pml="<%= row.pml %>"
                            data-pcl="<%= row.pcl %>"
                            data-targetfasih="<%= row.target_fasih %>"
                            data-muatan="<%= row.muatan %>"
                            data-kode2025="<%= row.kode_2025 %>"
                            title="Edit Record"
                            aria-label="Edit SLS <%= row.nama_sls %>"><i class="bi bi-pencil-fill"></i></button>
                    <% if (row.has_progress === 0) { %>
                      <form action="/master/delete/<%= row.kode %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus SLS master <%= row.kode %>?');" style="display: inline;">
                        <button type="submit" class="btn btn-danger btn-xs" title="Hapus" aria-label="Hapus SLS <%= row.nama_sls %>"><i class="bi bi-trash-fill"></i></button>
                      </form>
                    <% } else { %>
                      <button class="btn btn-secondary btn-xs" disabled style="opacity: 0.3; cursor: not-allowed;" title="Tidak dapat dihapus karena memiliki progres pencacahan" aria-label="Hapus SLS disabled (Memiliki Progres)"><i class="bi bi-trash-fill"></i></button>
                    <% } %>

                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="9" class="no-data" style="padding: 40px; text-align: center;">Tidak ada master data SLS yang cocok.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
      <div style="display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 20px;">
        <% if (page > 1) { %>
          <a href="/master?page=<%= page - 1 %>&q=<%= encodeURIComponent(q) %>" class="btn btn-secondary btn-sm"><i class="bi bi-chevron-left"></i> Sebelumnya</a>
        <% } %>
        <span style="font-size: 13px; color: var(--text-secondary);">Halaman <strong><%= page %></strong> dari <strong><%= totalPages %></strong></span>
        <% if (page < totalPages) { %>
          <a href="/master?page=<%= page + 1 %>&q=<%= encodeURIComponent(q) %>" class="btn btn-secondary btn-sm">Berikutnya <i class="bi bi-chevron-right"></i></a>
        <% } %>
      </div>
    <% } %>

  </div>

</div>

<!-- ADD MODAL -->
<div class="custom-modal-backdrop" id="addModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
  <div class="card" style="width: 100%; max-width: 500px; margin: 20px; animation: slideIn 0.2s ease;">
    <div class="card-header" style="margin-bottom: 12px; padding-bottom: 8px;">
      <div class="card-title"><i class="bi bi-plus-circle-fill" style="color: var(--accent-green);"></i> Tambah SLS Baru</div>
      <button class="btn btn-secondary btn-xs" id="btnCloseAddModal" aria-label="Tutup Dialog Tambah SLS" style="min-width: auto; padding: 4px 8px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <form action="/master/add" method="POST">
      <div style="display: flex; flex-direction: column; gap: 12px; max-height: 480px; overflow-y: auto; padding-right: 4px;">
        
        <div>
          <label for="addKode" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kode SubSLS (16 digit) *</label>
          <input type="text" id="addKode" name="kode" required pattern="[0-9]{16}" placeholder="Contoh: 6409010001000100" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
          <div>
            <label for="addKecamatan" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kecamatan *</label>
            <input type="text" id="addKecamatan" name="kecamatan" required placeholder="Contoh: Babulu" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="addDesa" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Desa / Kelurahan *</label>
            <input type="text" id="addDesa" name="desa" required placeholder="Contoh: Babulu Darat" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

        <div>
          <label for="addNamaSls" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama SLS / RT</label>
          <input type="text" id="addNamaSls" name="nama_sls" placeholder="Contoh: RT 001 DUSUN I" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 120px), 1fr)); gap: 10px;">
          <div>
            <label for="addTargetFasih" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Target FASIH</label>
            <input type="number" id="addTargetFasih" name="target_fasih" value="0" min="0" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="addMuatan" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Target Muatan</label>
            <input type="number" id="addMuatan" name="muatan" value="0" min="0" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="addKode2025" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kode SLS 2025</label>
            <input type="text" id="addKode2025" name="kode_2025" placeholder="Kosongkan jika sama" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

        <div>
          <label for="addKorlap" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Koordinator Lapangan (Korlap)</label>
          <input type="text" id="addKorlap" name="korlap" placeholder="Nama Koordinator Lapangan" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
          <div>
            <label for="addPml" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama PML (Pengawas)</label>
            <input type="text" id="addPml" name="pml" placeholder="Nama Pengawas PML" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="addPcl" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama PCL (Pencacah)</label>
            <input type="text" id="addPcl" name="pcl" placeholder="Nama Pencacah PCL" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

      </div>

      <div style="display: flex; gap: 8px; margin-top: 20px; border-top: 1px solid var(--border); padding-top: 12px;">
        <button type="button" class="btn btn-secondary" id="btnCancelAdd" style="flex: 1; justify-content: center;">Batal</button>
        <button type="submit" class="btn btn-primary" style="flex: 1; justify-content: center;">Simpan Record</button>
      </div>
    </form>
  </div>
</div>

<!-- EDIT MODAL -->
<div class="custom-modal-backdrop" id="editModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
  <div class="card" style="width: 100%; max-width: 500px; margin: 20px; animation: slideIn 0.2s ease;">
    <div class="card-header" style="margin-bottom: 12px; padding-bottom: 8px;">
      <div class="card-title"><i class="bi bi-pencil-square" style="color: var(--accent-cyan);"></i> Edit Record SLS Master</div>
      <button class="btn btn-secondary btn-xs" id="btnCloseEditModal" aria-label="Tutup Dialog Edit SLS" style="min-width: auto; padding: 4px 8px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <form action="/master/edit" method="POST">
      <input type="hidden" name="kode" id="editKode">
      
      <div style="display: flex; flex-direction: column; gap: 12px; max-height: 480px; overflow-y: auto; padding-right: 4px;">
        
        <div>
          <label for="editKodeDisplay" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kode SLS (Terunci)</label>
          <input type="text" id="editKodeDisplay" disabled style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: rgba(0,0,0,0.05); color: var(--text-muted);">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
          <div>
            <label for="editKecamatan" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kecamatan *</label>
            <input type="text" name="kecamatan" id="editKecamatan" required style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="editDesa" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Desa / Kelurahan *</label>
            <input type="text" name="desa" id="editDesa" required style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

        <div>
          <label for="editNama" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama SLS / RT</label>
          <input type="text" name="nama_sls" id="editNama" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 120px), 1fr)); gap: 10px;">
          <div>
            <label for="editTargetFasih" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Target FASIH</label>
            <input type="number" name="target_fasih" id="editTargetFasih" min="0" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label placeholder="" for="editMuatan" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Target Muatan</label>
            <input type="number" name="muatan" id="editMuatan" min="0" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="editKode2025" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Kode SLS 2025</label>
            <input type="text" name="kode_2025" id="editKode2025" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

        <div>
          <label for="editKorlap" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Koordinator Lapangan (Korlap)</label>
          <input type="text" name="korlap" id="editKorlap" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
          <div>
            <label for="editPml" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama PML (Pengawas)</label>
            <input type="text" name="pml" id="editPml" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
          <div>
            <label for="editPcl" style="display: block; font-size: 11px; margin-bottom: 4px; color: var(--text-muted); text-transform: uppercase;">Nama PCL (Pencacah)</label>
            <input type="text" name="pcl" id="editPcl" style="width: 100%; padding: 8px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary);">
          </div>
        </div>

      </div>

      <div style="display: flex; gap: 8px; margin-top: 20px; border-top: 1px solid var(--border); padding-top: 12px;">
        <button type="button" class="btn btn-secondary" id="btnCancelEdit" style="flex: 1; justify-content: center;">Batal</button>
        <button type="submit" class="btn btn-primary" style="flex: 1; justify-content: center;">Simpan Perubahan</button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // File upload area logic
    const zone = document.getElementById('masterUploadZone');
    const input = document.getElementById('masterFileInput');
    if (zone && input) {
      zone.addEventListener('click', () => input.click());
      zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'var(--accent-cyan)'; zone.style.background = 'rgba(var(--accent-rgb), 0.02)'; });
      zone.addEventListener('dragleave', () => { zone.style.borderColor = 'var(--border)'; zone.style.background = 'transparent'; });
      zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.style.borderColor = 'var(--border)';
        zone.style.background = 'transparent';
        const files = e.dataTransfer.files;
        if (files[0]) {
          input.files = files;
          zone.querySelector('.upload-zone-sub').textContent = `${files[0].name} (${(files[0].size/1024/1024).toFixed(2)} MB)`;
        }
      });
      input.addEventListener('change', () => {
        if (input.files[0]) {
          zone.querySelector('.upload-zone-sub').textContent = `${input.files[0].name}`;
        }
      });
    }

    // Modal Add record logic
    const addModal = document.getElementById('addModal');
    const openAddBtn = document.getElementById('btnOpenAddModal');
    const closeAddBtn = document.getElementById('btnCloseAddModal');
    const cancelAddBtn = document.getElementById('btnCancelAdd');

    if (openAddBtn && addModal) {
      openAddBtn.addEventListener('click', () => addModal.style.display = 'flex');
      const hideAddModal = () => addModal.style.display = 'none';
      if (closeAddBtn) closeAddBtn.addEventListener('click', hideAddModal);
      if (cancelAddBtn) cancelAddBtn.addEventListener('click', hideAddModal);
    }

    // Modal Edit record logic
    const editModal = document.getElementById('editModal');
    const closeEditBtn = document.getElementById('btnCloseEditModal');
    const cancelEditBtn = document.getElementById('btnCancelEdit');

    const editFormFields = {
      kode: document.getElementById('editKode'),
      kodeDisplay: document.getElementById('editKodeDisplay'),
      kecamatan: document.getElementById('editKecamatan'),
      desa: document.getElementById('editDesa'),
      nama: document.getElementById('editNama'),
      korlap: document.getElementById('editKorlap'),
      pml: document.getElementById('editPml'),
      pcl: document.getElementById('editPcl'),
      targetFasih: document.getElementById('editTargetFasih'),
      muatan: document.getElementById('editMuatan'),
      kode2025: document.getElementById('editKode2025')
    };

    document.querySelectorAll('.btn-edit-sls').forEach(btn => {
      btn.addEventListener('click', () => {
        const dataset = btn.dataset;
        editFormFields.kode.value = dataset.kode;
        editFormFields.kodeDisplay.value = dataset.kode;
        editFormFields.kecamatan.value = dataset.kecamatan;
        editFormFields.desa.value = dataset.desa;
        editFormFields.nama.value = dataset.nama;
        editFormFields.korlap.value = dataset.korlap;
        editFormFields.pml.value = dataset.pml;
        editFormFields.pcl.value = dataset.pcl;
        editFormFields.targetFasih.value = dataset.targetfasih;
        editFormFields.muatan.value = dataset.muatan;
        editFormFields.kode2025.value = dataset.kode2025;

        editModal.style.display = 'flex';
      });
    });

    if (editModal) {
      const hideEditModal = () => editModal.style.display = 'none';
      if (closeEditBtn) closeEditBtn.addEventListener('click', hideEditModal);
      if (cancelEditBtn) cancelEditBtn.addEventListener('click', hideEditModal);
    }

  });
</script>
