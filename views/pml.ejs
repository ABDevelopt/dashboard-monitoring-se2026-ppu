<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>

    <!-- TWO-COLUMN GRID FOR DRILLDOWN -->
    <div class="drilldown-grid mt-4">
      
      <!-- PML LIST TABLE -->
      <div class="card" style="margin-bottom: 0;">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-clipboard2-data"></i> Progres Kinerja per PML (Pengawas)</div>
          <span class="badge badge-blue"><%= pmlStats.length %> PML</span>
        </div>

        <div class="search-wrap mb-4" style="max-width: 300px;">
          <input type="search" id="pmlSearch" placeholder="Cari nama PML...">
        </div>

        <% if (pmlStats && pmlStats.length > 0) { %>
          <div class="table-wrap" style="max-height: 600px; overflow-y: auto;">
            <table id="pmlTable">
              <thead>
                <tr>
                  <th>Nama PML</th>
                  <th>Korlap</th>
                  <th class="text-right">Jumlah PCL</th>
                  <th class="text-right">SubSLS</th>
                  <th class="text-right">Selesai</th>
                  <th class="text-right">Progres %</th>
                  <th class="text-right">Total Usaha</th>
                  <th class="text-right">Total Keluarga</th>
                </tr>
              </thead>
              <tbody>
                  <% let completionPct = p.total_muatan ? ((p.usaha_total / p.total_muatan) * 100).toFixed(2) : '0.00'; %>
                  <tr class="<%= filterPml === p.pml ? 'active' : '' %>" style="<%= filterPml === p.pml ? 'background: var(--bg-card-hover); font-weight: 500;' : '' %>">
                    <td class="td-primary">
                      <a href="/pml?pml=<%= encodeURIComponent(p.pml) %>" style="color: inherit; text-decoration: none; display: block;">
                        <i class="bi bi-clipboard2-data"></i> <%= p.pml %>
                      </a>
                    </td>
                    <td><%= p.korlap %></td>
                    <td class="text-right" data-sort="<%= p.jumlah_pcl %>"><%= p.jumlah_pcl %> PCL</td>
                    <td class="text-right" data-sort="<%= p.total_subsls %>"><%= p.total_subsls %></td>
                    <td class="text-right fw-bold" data-sort="<%= p.selesai %>" style="<%= p.selesai === 0 ? 'color: var(--accent-red)' : '' %>"><%= p.selesai %></td>
                    <td class="text-right" data-sort="<%= parseFloat(completionPct) %>">
                      <% if (parseFloat(completionPct) >= 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (parseFloat(completionPct) <= 0) { %>
                        <span class="badge badge-red">0%</span>
                      <% } else if (parseFloat(completionPct) < 25) { %>
                        <span class="badge badge-yellow"><%= completionPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= completionPct %>%</span>
                      <% } %>
                    </td>
                    <td class="text-right fw-bold td-primary" data-sort="<%= p.usaha_total %>"><%= p.usaha_total.toLocaleString('id-ID') %></td>
                    <td class="text-right fw-bold" data-sort="<%= p.keluarga_total %>"><%= p.keluarga_total.toLocaleString('id-ID') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="no-data">Tidak ada PML yang cocok.</div>
        <% } %>
      </div>

      <!-- PML'S PCL TEAM DETAILS -->
      <div id="pmlDetailContainer">
        <% if (filterPml) { %>
          <div class="card" style="margin-bottom: 0; position: sticky; top: 80px;">
            <div class="card-header">
              <div class="card-title"><i class="bi bi-people"></i> Anggota Tim PCL: <%= filterPml %></div>
              <a href="/pml" class="btn btn-secondary btn-xs"><i class="bi bi-x-lg"></i> Tutup</a>
            </div>

            <% if (detailPcl && detailPcl.length > 0) { %>
              <div class="mb-4">
                <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;">
                  Korlap Atasan: <strong><%= detailPcl[0].korlap %></strong>
                </div>
                <% 
                  let totalBeban = detailPcl.reduce((acc, c) => acc + c.total_muatan, 0);
                  let totalUsaha = detailPcl.reduce((acc, c) => acc + c.usaha_total, 0);
                  let totalPct = totalBeban ? ((totalUsaha / totalBeban) * 100).toFixed(2) : '0.00';
                %>
                <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px;">
                  <span>Progres Tim PML</span>
                  <span class="fw-bold"><%= totalUsaha.toLocaleString('id-ID') %> / <%= totalBeban.toLocaleString('id-ID') %> muatan (<%= totalPct %>%)</span>
                </div>
                <div class="progress-bar-wrap">
                  <div class="progress-bar <%= parseFloat(totalPct) >= 100 ? 'green' : (parseFloat(totalPct) < 25 ? 'red' : 'blue') %>" data-width="<%= totalPct %>" style="width: 0%;"></div>
                </div>
              </div>

              <div class="search-wrap mb-4" style="max-width: 100%; margin-bottom: 12px;">
                <input type="search" id="detailPclSearch" placeholder="Cari nama PCL dalam tim...">
              </div>

              <div id="detailPclList" style="max-height: 420px; overflow-y: auto; padding-right: 4px;">
                <% detailPcl.forEach(item => { %>
                  <div class="detail-item">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                      <span class="fw-bold" style="color: var(--text-primary);"><i class="bi bi-person"></i> <%= item.pcl %></span>
                      <% if (parseFloat(item.pct) >= 100) { %>
                        <span class="badge badge-green btn-xs">100%</span>
                      <% } else if (parseFloat(item.pct) <= 0) { %>
                        <span class="badge badge-red btn-xs">0%</span>
                      <% } else { %>
                        <span class="badge badge-blue btn-xs"><%= parseFloat(item.pct).toFixed(2) %>%</span>
                      <% } %>
                    </div>
                    <div style="font-size: 12px; color: var(--text-secondary);">
                      Wilayah Kerja: Kec. <strong><%= item.kecamatan %></strong>
                    </div>
                    <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">
                      SubSLS: <strong><%= item.selesai %> / <%= item.total_subsls %></strong> Selesai
                    </div>
                    <div style="display: flex; gap: 8px; margin-top: 6px; font-size: 11px;">
                      <span style="background: rgba(16,185,129,0.1); padding: 2px 8px; border-radius: 4px; color: var(--accent-green);"><i class="bi bi-building"></i> <%= item.usaha_total %> Usaha</span>
                      <span style="background: rgba(6,182,212,0.1); padding: 2px 8px; border-radius: 4px; color: var(--accent-cyan);"><i class="bi bi-people"></i> <%= item.keluarga_total %> Keluarga</span>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="no-data">Tidak ada detail PCL.</div>
            <% } %>
          </div>
        <% } else { %>
          <div class="card empty-state text-center" style="height: 100%; min-height: 300px; display: flex; flex-direction: column; justify-content: center; border-style: dashed;">
            <div class="empty-state-icon"><i class="bi bi-arrow-left-circle"></i></div>
            <div class="empty-state-title">Pilih PML</div>
            <div class="empty-state-text">Klik nama PML di tabel sebelah kiri untuk melihat rincian PCL yang diawasi beserta progres kinerja per PCL.</div>
          </div>
        <% } %>
      </div>

    </div>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    makeTableSortable('pmlTable');
    makeTableSearchable('pmlSearch', 'pmlTable');
    
    // Initial searchable bind
    <% if (filterPml) { %>
      makeListSearchable('detailPclSearch', 'detailPclList', '.detail-item');
    <% } %>

    // AJAX Drilldown logic for PML
    const detailContainer = document.getElementById('pmlDetailContainer');
    const table = document.getElementById('pmlTable');

    if (table && detailContainer) {
      // Intercept row clicks
      table.querySelector('tbody').addEventListener('click', (e) => {
        const link = e.target.closest('td.td-primary a');
        if (!link) return;

        e.preventDefault();
        const url = link.getAttribute('href');
        const row = link.closest('tr');

        // Update active row visual indicator
        table.querySelectorAll('tbody tr').forEach(r => {
          r.classList.remove('active');
          r.removeAttribute('style');
        });
        row.classList.add('active');
        row.style.background = 'var(--bg-card-hover)';
        row.style.fontWeight = '500';

        // Opacity transition
        detailContainer.style.opacity = '0.5';

        fetch(url)
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newDetail = doc.getElementById('pmlDetailContainer');
            if (newDetail) {
              detailContainer.innerHTML = newDetail.innerHTML;
              detailContainer.style.opacity = '1';

              // Update URL path without refresh
              window.history.pushState(null, '', url);

              // Re-bind list search utility
              makeListSearchable('detailPclSearch', 'detailPclList', '.detail-item');

              // Re-bind close handler
              bindCloseDetail();
            }
          })
          .catch(err => {
            console.error(err);
            detailContainer.style.opacity = '1';
          });
      });
    }

    // AJAX Tutup Detail handler
    function bindCloseDetail() {
      const closeBtn = detailContainer.querySelector('.btn-secondary');
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = closeBtn.getAttribute('href');

          // Reset active rows
          if (table) {
            table.querySelectorAll('tbody tr').forEach(r => {
              r.classList.remove('active');
              r.removeAttribute('style');
            });
          }

          detailContainer.style.opacity = '0.5';
          fetch(url)
            .then(res => res.text())
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const newDetail = doc.getElementById('pmlDetailContainer');
              if (newDetail) {
                detailContainer.innerHTML = newDetail.innerHTML;
                detailContainer.style.opacity = '1';
                window.history.pushState(null, '', url);
              }
            })
            .catch(err => {
              console.error(err);
              detailContainer.style.opacity = '1';
            });
        });
      }
    }

    bindCloseDetail();
  });
</script>
