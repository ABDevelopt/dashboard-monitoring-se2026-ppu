<script>
function setActiveTab(tab) {
  // 1. Update UI tabs styling
  const tabBtnTerbaik = document.getElementById('tabBtnTerbaik');
  const tabBtnTerendah = document.getElementById('tabBtnTerendah');
  const tabContentTerbaik = document.getElementById('tabContentTerbaik');
  const tabContentTerendah = document.getElementById('tabContentTerendah');
  const activeTabInput = document.getElementById('activeTabInput');

  if (tab === 'terbaik') {
    tabBtnTerbaik.className = 'btn btn-primary btn-sm';
    tabBtnTerendah.className = 'btn btn-secondary btn-sm';
    tabContentTerbaik.style.display = 'block';
    tabContentTerendah.style.display = 'none';
  } else {
    tabBtnTerbaik.className = 'btn btn-secondary btn-sm';
    tabBtnTerendah.className = 'btn btn-primary btn-sm';
    tabContentTerbaik.style.display = 'none';
    tabContentTerendah.style.display = 'block';
  }

  // 2. Set hidden input value
  if (activeTabInput) {
    activeTabInput.value = tab;
  }

  // 3. Update URL without refreshing the page
  const currentUrl = new URL(window.location.href);
  currentUrl.searchParams.set('tab', tab);
  window.history.replaceState({}, '', currentUrl.toString());

  // 4. Trigger progress bars initialization in the visible tab
  if (window.initProgressBars) {
    window.initProgressBars(tab === 'terbaik' ? tabContentTerbaik : tabContentTerendah);
  }
}

document.addEventListener('DOMContentLoaded', () => {
  // Set default active tab based on variable
  setActiveTab('<%= activeTab %>');
});
</script>
