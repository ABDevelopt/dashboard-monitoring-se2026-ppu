<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>

    <!-- FILTER BAR -->
    <div class="card" style="margin-bottom: 20px;">
      <div class="card-header" style="margin-bottom: 8px; padding-bottom: 8px;">
        <div class="card-title"><i class="bi bi-search"></i> Filter Performa Petugas</div>
        <a href="/performa" class="btn btn-secondary btn-xs"><i class="bi bi-arrow-repeat"></i> Reset</a>
      </div>
      <form action="/performa" method="GET" id="filterForm">
        <div class="filter-form-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 180px), 1fr)); gap: 10px;">
          <div>
            <label for="performaKec" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Kecamatan</label>
            <select id="performaKec" name="kec" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua --</option>
              <% kecList.forEach(k => { %>
                <option value="<%= k.kecamatan %>" <%= filterKec === k.kecamatan ? 'selected' : '' %>><%= k.kecamatan %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label for="performaKorlap" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Koordinator Lapangan</label>
            <select id="performaKorlap" name="korlap" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua --</option>
              <% korlapList.forEach(k => { %>
                <option value="<%= k.korlap %>" <%= filterKorlap === k.korlap ? 'selected' : '' %>><%= k.korlap %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label for="performaPml" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">PML (Pengawas)</label>
            <select id="performaPml" name="pml" onchange="this.form.submit();" style="width:100%;">
              <option value="">-- Semua --</option>
              <% pmlList.forEach(p => { %>
                <option value="<%= p.pml %>" <%= filterPml === p.pml ? 'selected' : '' %>><%= p.pml %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </form>
    </div>

    <!-- TABEL PCL -->
    <div class="card">
      <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 12px; margin-bottom: 0;">
        <div class="card-title"><i class="bi bi-speedometer2"></i> Performa Petugas Pencacah Lapangan (PCL)</div>
        <span class="badge badge-green" style="font-size: 11px;"><%= performers.topPcl ? performers.topPcl.length : 0 %> PCL</span>
      </div>
      <p style="font-size: 11px; color: var(--text-muted); padding: 10px 16px 0; margin: 0;">
        Progres dihitung dari: <strong>(Submitted + Approved + Rejected) / Target Assignment FASIH</strong> &mdash; tanpa menghitung status Open dan Draft.
        Klik header kolom untuk mengurutkan.
      </p>
      <div class="table-wrap" style="overflow-x: auto;">
        <table id="performa-pcl-table" class="sortable-table" style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--border);">
              <th class="text-center" style="padding: 10px 8px; width: 44px;">No</th>
              <th style="padding: 10px 8px; min-width: 140px;">Nama PCL</th>
              <th style="padding: 10px 8px; min-width: 100px;">Kecamatan</th>
              <th style="padding: 10px 8px; min-width: 120px;">PML</th>
              <th style="padding: 10px 8px; min-width: 110px;">Korlap</th>
              <th class="text-right bg-yellow-soft" style="padding: 10px 8px; width: 72px;">Draft</th>
              <th class="text-right bg-blue-soft" style="padding: 10px 8px; width: 72px;">Submit</th>
              <th class="text-right bg-red-soft" style="padding: 10px 8px; width: 72px;">Reject</th>
              <th class="text-right bg-green-soft" style="padding: 10px 8px; width: 72px;">Approve</th>
              <th class="text-right bg-purple-soft" style="padding: 10px 8px; width: 72px;">Target</th>
              <th class="text-right bg-purple-soft" style="padding: 10px 8px; width: 82px;">Progres %</th>
              <th class="text-right bg-blue-soft" style="padding: 10px 8px; width: 80px;">Laju/Hari</th>
              <th class="text-center bg-blue-soft" style="padding: 10px 8px; width: 130px;">Perkiraan Selesai</th>
            </tr>
          </thead>
          <tbody>
            <% if (performers.topPcl && performers.topPcl.length > 0) { %>
              <% performers.topPcl.forEach((item, index) => { %>
                <%
                  // Progres: semua status kecuali open & draft
                  let fasihSelesai = (item.submitted_total || 0) + (item.approved_total || 0) + (item.rejected_total || 0);
                  let pct = item.target_fasih_total > 0 ? Math.min(100, parseFloat((100 * fasihSelesai / item.target_fasih_total).toFixed(2))) : 0;

                  // Laju & Perkiraan
                  let totalProgress = (item.draft_total || 0) + fasihSelesai;
                  let runrate = diffDays > 0 ? parseFloat((fasihSelesai / diffDays).toFixed(2)) : 0;
                  let remainingFasih = (item.target_fasih_total || 0) - fasihSelesai;

                  let statusBadge = '';
                  let statusText = '';
                  let statusSortVal = 999;

                  if (remainingFasih <= 0) {
                    statusBadge = 'badge-green';
                    statusText = 'Selesai';
                    statusSortVal = 0;
                  } else if (runrate <= 0) {
                    statusBadge = 'badge-red';
                    statusText = 'Stagnan';
                    statusSortVal = 9999;
                  } else {
                    let daysNeeded = Math.ceil(remainingFasih / runrate);
                    statusSortVal = daysNeeded;
                    if (daysNeeded <= daysRemaining) {
                      statusBadge = 'badge-blue';
                      statusText = `Mampu (${daysNeeded} hr)`;
                    } else {
                      statusBadge = 'badge-red';
                      statusText = `Tdk Mampu (+${daysNeeded - daysRemaining} hr)`;
                    }
                  }
                %>
                <tr style="border-bottom: 1px solid var(--border);">
                  <td class="text-center" data-sort="<%= index + 1 %>" style="padding: 10px 8px; font-size: 12px; color: var(--text-muted);">
                    <%= index + 1 %>
                  </td>
                  <td data-sort="<%= item.pcl %>" style="padding: 10px 8px; font-weight: 600; font-size: 13px;">
                    <%= item.pcl %>
                  </td>
                  <td data-sort="<%= item.kecamatan %>" style="padding: 10px 8px; font-size: 12px;">
                    <%= item.kecamatan %>
                  </td>
                  <td data-sort="<%= item.pml %>" style="padding: 10px 8px; font-size: 12px;">
                    <%= item.pml %>
                  </td>
                  <td data-sort="<%= item.korlap %>" style="padding: 10px 8px; font-size: 12px;">
                    <%= item.korlap %>
                  </td>
                  <td class="text-right bg-yellow-soft" data-sort="<%= item.draft_total || 0 %>" style="padding: 10px 8px;">
                    <%= (item.draft_total || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="text-right bg-blue-soft" data-sort="<%= item.submitted_total || 0 %>" style="padding: 10px 8px;">
                    <%= (item.submitted_total || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="text-right bg-red-soft" data-sort="<%= item.rejected_total || 0 %>" style="padding: 10px 8px; font-weight: 600;">
                    <%= (item.rejected_total || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="text-right bg-green-soft" data-sort="<%= item.approved_total || 0 %>" style="padding: 10px 8px; font-weight: 600;">
                    <%= (item.approved_total || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="text-right bg-purple-soft" data-sort="<%= item.target_fasih_total || 0 %>" style="padding: 10px 8px;">
                    <%= (item.target_fasih_total || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="text-right bg-purple-soft" data-sort="<%= pct %>" style="padding: 10px 8px;">
                    <% if (pct >= 100) { %>
                      <span class="badge badge-green" style="font-size: 11px;"><%= pct %>%</span>
                    <% } else if (pct >= 50) { %>
                      <span class="badge badge-blue" style="font-size: 11px;"><%= pct %>%</span>
                    <% } else { %>
                      <span class="badge badge-red" style="font-size: 11px;"><%= pct %>%</span>
                    <% } %>
                  </td>
                  <td class="text-right bg-blue-soft" data-sort="<%= runrate %>" style="padding: 10px 8px; font-weight: 500;">
                    <%= runrate.toFixed(2) %>
                  </td>
                  <td class="text-center bg-blue-soft" data-sort="<%= statusSortVal %>" style="padding: 10px 8px;">
                    <span class="badge <%= statusBadge %>" style="font-size: 10px; padding: 3px 8px;"><%= statusText %></span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="13" class="text-center" style="padding: 24px; color: var(--text-muted);">
                  <i class="bi bi-inbox" style="font-size: 24px; display: block; margin-bottom: 8px;"></i>
                  Tidak ada data PCL ditemukan.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  if (typeof makeTableSortable === 'function') {
    makeTableSortable('performa-pcl-table');
  }
});
</script>
