<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>
    <div id="ajax-container">
    
    <!-- FILTER BAR -->
    <div class="card">
      <div class="card-header" style="margin-bottom: 8px; padding-bottom: 8px;">
        <div class="card-title"><i class="bi bi-search"></i> Filter Pencarian SubSLS</div>
        <a href="/subsls" class="btn btn-secondary btn-xs"><i class="bi bi-arrow-repeat"></i> Reset Filter</a>
      </div>
      
      <form action="/subsls" method="GET" id="filterForm">
        <div class="filter-form-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 180px), 1fr)); gap: 10px;">
          
          <div>
            <label for="filterKec" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Kecamatan</label>
            <select id="filterKec" name="kec"  style="width:100%;">
              <option value="">-- Semua Kecamatan --</option>
              <% kecList.forEach(k => { %>
                <option value="<%= k.kecamatan %>" <%= filterKec === k.kecamatan ? 'selected' : '' %>><%= k.kecamatan %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filterDesa" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Desa/Kelurahan</label>
            <select id="filterDesa" name="desa"  style="width:100%;" <%= !filterKec ? 'disabled' : '' %>>
              <option value="">-- Semua Desa --</option>
              <% desaList.forEach(d => { %>
                <option value="<%= d.desa %>" <%= filterDesa === d.desa ? 'selected' : '' %>><%= d.desa %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filterKorlap" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">Koordinator Lapangan</label>
            <select id="filterKorlap" name="korlap"  style="width:100%;">
              <option value="">-- Semua Korlap --</option>
              <% korlapList.forEach(k => { %>
                <option value="<%= k.korlap %>" <%= filterKorlap === k.korlap ? 'selected' : '' %>><%= k.korlap %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filterPml" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">PML (Pengawas)</label>
            <select id="filterPml" name="pml"  style="width:100%;">
              <option value="">-- Semua PML --</option>
              <% pmlList.forEach(p => { %>
                <option value="<%= p.pml %>" <%= filterPml === p.pml ? 'selected' : '' %>><%= p.pml %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="filterPcl" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">PCL (Pencacah)</label>
            <select id="filterPcl" name="pcl"  style="width:100%;">
              <option value="">-- Semua PCL --</option>
              <% pclList.forEach(p => { %>
                <option value="<%= p.pcl %>" <%= filterPcl === p.pcl ? 'selected' : '' %>><%= p.pcl %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label id="statusLabel" for="filterStatus" style="display:block; font-size:11px; margin-bottom:4px; color:var(--text-muted);">
              Status Progres
              <span title="Kriteria Selesai: SubSLS memiliki target muatan > 0 DAN jumlah (Usaha Ditemukan + Baru) >= Muatan" style="cursor: help; margin-left: 4px;"><i class="bi bi-info-circle"></i></span>
            </label>
            <select id="filterStatus" name="status" style="width:100%;">
              <option value="">-- Semua Status --</option>
              <option value="selesai" <%= filterStatus === 'selesai' ? 'selected' : '' %>>Selesai Pencacahan</option>
              <option value="belum" <%= filterStatus === 'belum' ? 'selected' : '' %>>Belum Selesai</option>
            </select>
          </div>

        </div>
      </form>
    </div>

    <!-- MAIN DATA TABLE -->
    <div class="card mt-4" id="subslsTableContainer">
      <div class="card-header">
        <div class="card-title">
          <span><i class="bi bi-box-seam"></i> Daftar Rincian SubSLS (Blok Sensus)</span>
        </div>
        <div>
          <span style="font-size:12px; margin-right:12px; color:var(--text-secondary);">
            Menampilkan <%= data.length %> dari <%= total.toLocaleString('id-ID') %> SubSLS
          </span>
          <a href="/subsls/export" class="btn btn-success btn-sm"><i class="bi bi-download"></i> Export ke CSV</a>
        </div>
      </div>

      <div class="search-wrap mb-4" style="max-width: 300px;">
        <input type="search" id="localSearch" placeholder="Cari di halaman ini..." aria-label="Cari SLS di halaman ini">
      </div>

      <% if (data && data.length > 0) { %>
        <div class="table-wrap">
          <table id="subslsTable">
            <thead>
              <tr>
                <th rowspan="2" class="hide-md">Kode SLS</th>
                <th rowspan="2">Nama SLS</th>

                <th rowspan="2">Wilayah</th>
                <th rowspan="2">Petugas (PCL/PML/Korlap)</th>
                <th rowspan="2" class="text-center">Status</th>
                <th colspan="3" class="text-center bg-purple-soft" style="border-bottom: 1px solid var(--border);">Assignment FASIH</th>
                <th colspan="4" class="text-center bg-cyan-soft" style="border-bottom: 1px solid var(--border);">Beban Muatan</th>
              </tr>
              <tr>
                <th class="text-right bg-purple-soft">App</th>
                <th class="text-right bg-purple-soft">Tgt</th>
                <th class="text-center bg-purple-soft">Detail Status (D/S/A/R)</th>
                
                <th class="text-right bg-cyan-soft">Usaha Total</th>
                <th class="text-right bg-cyan-soft">Usaha Baru</th>
                <th class="text-right bg-cyan-soft">Target Muatan</th>
                <th class="text-right bg-cyan-soft">Keluarga Total</th>
              </tr>
            </thead>
            <tbody>
              <% data.forEach(row => { %>
                <tr>
                  <td class="td-code hide-md"><%= row.kode %></td>
                  <td class="td-primary" style="font-weight: 600;"><%= row.nama_sls %></td>
                  <td>
                    <div style="font-weight: 600; font-size: 12px;"><%= row.kecamatan %></div>
                    <div style="font-size: 11px; color: var(--text-muted);"><%= row.desa %></div>
                  </td>
                  <td>
                    <div style="font-weight: 500; font-size: 12px;" class="td-primary"><%= row.pcl %></div>
                    <div style="font-size: 11px; color: var(--text-muted);" class="hide-md">PML: <%= row.pml %> · Krl: <%= row.korlap %></div>

                  </td>
                  <td class="text-center" data-sort="<%= row.sudah_diisi %>">
                    <% if (row.sudah_diisi) { %>
                      <span class="badge badge-green">Selesai</span>
                    <% } else { %>
                      <span class="badge badge-red">Belum</span>
                    <% } %>
                  </td>
                  
                  <td class="text-right bg-purple-soft fw-bold" data-sort="<%= row.approved %>"><%= (row.approved || 0).toLocaleString('id-ID') %></td>
                  <td class="text-right bg-purple-soft" data-sort="<%= row.target_fasih %>"><%= (row.target_fasih || 0).toLocaleString('id-ID') %></td>
                  <td class="text-center bg-purple-soft" style="font-size: 10px;" data-sort="<%= row.draft + row.submitted_by_pcl + row.approved + row.rejected %>">
                    D:<%= row.draft %> · S:<%= row.submitted_by_pcl %> · A:<%= row.approved %> · R:<span class="text-red fw-bold"><%= row.rejected %></span>
                  </td>
                  
                  <td class="text-right fw-bold bg-cyan-soft" data-sort="<%= row.usaha_total %>"><%= (row.usaha_total || 0).toLocaleString('id-ID') %></td>
                  <td class="text-right bg-cyan-soft text-green" data-sort="<%= row.usaha_baru %>">+<%= (row.usaha_baru || 0).toLocaleString('id-ID') %></td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= row.muatan %>"><%= row.muatan.toLocaleString('id-ID') %></td>
                  <td class="text-right bg-cyan-soft" data-sort="<%= row.keluarga_total %>"><%= (row.keluarga_total || 0).toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <div>
              Halaman <strong><%= page %></strong> dari <strong><%= totalPages %></strong> (Total <%= total.toLocaleString('id-ID') %> record)
            </div>
            <div class="pagination-pages">
              <!-- First Page -->
              <% if (page > 1) { %>
                <a href="/subsls?page=1&kec=<%= filterKec %>&desa=<%= filterDesa %>&korlap=<%= filterKorlap %>&pml=<%= filterPml %>&pcl=<%= filterPcl %>&status=<%= filterStatus %>" class="page-btn"><i class="bi bi-chevron-double-left"></i> Pertama</a>
                <a href="/subsls?page=<%= page - 1 %>&kec=<%= filterKec %>&desa=<%= filterDesa %>&korlap=<%= filterKorlap %>&pml=<%= filterPml %>&pcl=<%= filterPcl %>&status=<%= filterStatus %>" class="page-btn"><i class="bi bi-chevron-left"></i> Seb.</a>
              <% } %>

              <!-- Page range -->
              <% 
                let startPage = Math.max(1, page - 2);
                let endPage = Math.min(totalPages, page + 2);
                for (let i = startPage; i <= endPage; i++) {
              %>
                <a href="/subsls?page=<%= i %>&kec=<%= filterKec %>&desa=<%= filterDesa %>&korlap=<%= filterKorlap %>&pml=<%= filterPml %>&pcl=<%= filterPcl %>&status=<%= filterStatus %>" class="page-btn <%= page === i ? 'active' : '' %>"><%= i %></a>
              <% } %>

              <!-- Next page -->
              <% if (page < totalPages) { %>
                <a href="/subsls?page=<%= page + 1 %>&kec=<%= filterKec %>&desa=<%= filterDesa %>&korlap=<%= filterKorlap %>&pml=<%= filterPml %>&pcl=<%= filterPcl %>&status=<%= filterStatus %>" class="page-btn">Ber. <i class="bi bi-chevron-right"></i></a>
                <a href="/subsls?page=<%= totalPages %>&kec=<%= filterKec %>&desa=<%= filterDesa %>&korlap=<%= filterKorlap %>&pml=<%= filterPml %>&pcl=<%= filterPcl %>&status=<%= filterStatus %>" class="page-btn">Terakhir <i class="bi bi-chevron-double-right"></i></a>
              <% } %>
            </div>
          </div>
        <% } %>

      <% } else { %>
        <div class="no-data">
          <i class="bi bi-slash-circle-fill text-red" style="font-size: 18px; margin-right: 6px;"></i> Tidak ditemukan data SubSLS yang sesuai dengan kriteria filter Anda.
        </div>
      <% } %>
    </div>
  <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('ajax-container');
  if (!container) return;

  function attachListeners() {
    // 1. Re-initialize sorting and searching on the table
    makeTableSortable('subslsTable');
    makeTableSearchable('localSearch', 'subslsTable');

    // 2. Intercept pagination links for partial table refresh
    const paginationLinks = document.querySelectorAll('.pagination-pages a.page-btn');
    paginationLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const urlObj = new URL(link.href, window.location.origin);
        fetchAndReplace(urlObj.search, false); // false = only refresh table container
      });
    });

    // 3. Filter form change listeners
    const filterForm = document.getElementById('filterForm');
    if (filterForm) {
      const selects = filterForm.querySelectorAll('select');
      selects.forEach(sel => {
        sel.addEventListener('change', () => {
          const isKecChange = sel.name === 'kec';
          const queryString = new URLSearchParams(new FormData(filterForm)).toString();
          fetchAndReplace(queryString, isKecChange); // if kec changes, refresh whole container to update desa options
        });
      });
      
      const resetBtn = document.querySelector('a[href="/subsls"]');
      if (resetBtn) {
        resetBtn.addEventListener('click', (e) => {
          e.preventDefault();
          fetchAndReplace('', true); // reset, refresh whole container
        });
      }
    }
  }

  function fetchAndReplace(queryString, refreshAll) {
    const url = '/subsls' + (queryString ? (queryString.startsWith('?') ? queryString : '?' + queryString) : '');
    
    // Choose target container (ajax-container for full page reload, subslsTableContainer for partial table update)
    const targetId = refreshAll ? 'ajax-container' : 'subslsTableContainer';
    const targetElement = document.getElementById(targetId);
    if (!targetElement) return;

    targetElement.style.opacity = '0.5';
    targetElement.style.pointerEvents = 'none';
    
    fetch(url)
      .then(res => res.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const newElement = doc.getElementById(targetId);
        if (newElement) {
          targetElement.innerHTML = newElement.innerHTML;
          history.pushState(null, '', url);
          attachListeners();
        }
      })
      .catch(err => console.error(err))
      .finally(() => {
        if (targetElement) {
          targetElement.style.opacity = '1';
          targetElement.style.pointerEvents = 'auto';
        }
      });
  }

  attachListeners();
  
  window.addEventListener('popstate', () => {
    fetchAndReplace(window.location.search, true);
  });
});
</script>
