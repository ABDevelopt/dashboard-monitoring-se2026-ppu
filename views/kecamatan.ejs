<%
  let activeTargetPct = 25;
  let targetMonthName = 'Juni';
  const currentMonth = new Date().getMonth(); // 5 = Juni, 6 = Juli
  if (currentMonth === 6) { // Juli
    activeTargetPct = 50;
    targetMonthName = 'Juli';
  }
%>
<div class="fade-in">
  <% if (!uploadId) { %>
    <div class="card empty-state text-center">
      <div class="empty-state-icon"><i class="bi bi-bar-chart-steps"></i></div>
      <div class="empty-state-title">Belum Ada Data Terupload</div>
      <div class="empty-state-text">Silakan upload data terlebih dahulu di menu <a href="/upload">Upload Data</a>.</div>
    </div>
  <% } else { %>

    <!-- KECAMATAN CARDS GRID -->
    <div class="kec-grid">
      <% kecStats.forEach(k => { %>
        <% let pctVal = k.total_muatan ? (( (k.usaha_total + k.keluarga_total) / k.total_muatan ) * 100).toFixed(2) : '0.00'; %>
        <a href="/kecamatan?kec=<%= encodeURIComponent(k.kecamatan) %>" class="kec-card <%= filterKec === k.kecamatan ? 'active' : '' %>">
          <div class="kec-name"><i class="bi bi-geo-alt"></i> Kec. <%= k.kecamatan %></div>
          <div class="kec-pct"><%= pctVal %>%</div>
          
          <div class="progress-bar-target-wrap" style="position: relative; height: 6px; margin-top: 16px; margin-bottom: 8px;">
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: var(--bg-progress-wrap); border-radius: 99px; overflow: hidden;">
              <div class="progress-bar <%= parseFloat(pctVal) >= 100 ? 'green' : (parseFloat(pctVal) < activeTargetPct ? 'red' : 'blue') %>" data-width="<%= pctVal %>" style="width: 0%; height: 100%; border-radius: 99px;"></div>
            </div>
            
            <!-- Marker 25% (Juni) -->
            <div style="position: absolute; left: 25%; top: -3px; height: 12px; border-left: 1px dashed <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; opacity: <%= activeTargetPct === 25 ? '1' : '0.5' %>; z-index: 2; pointer-events: none;">
              <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-size: 7px; font-weight: 800; color: <%= activeTargetPct === 25 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Jun: 25%</span>
            </div>

            <!-- Marker 50% (Juli) -->
            <div style="position: absolute; left: 50%; top: -3px; height: 12px; border-left: 1px dashed <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; opacity: <%= activeTargetPct === 50 ? '1' : '0.5' %>; z-index: 2; pointer-events: none;">
              <span style="position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-size: 7px; font-weight: 800; color: <%= activeTargetPct === 50 ? 'var(--accent-cyan)' : 'var(--text-muted)' %>; white-space: nowrap;">Jul: 50%</span>
            </div>
          </div>
          
          <div class="kec-detail">
            <!-- SubSLS: <strong><%= k.selesai %> / <%= k.total_subsls %></strong> Selesai<br> -->
            Total Muatan: <strong><%= k.total_muatan.toLocaleString('id-ID') %></strong><br>
            Total Usaha: <strong><%= k.usaha_total.toLocaleString('id-ID') %></strong><br>
            Total Keluarga: <strong><%= k.keluarga_total.toLocaleString('id-ID') %></strong>
          </div>
        </a>
      <% }) %>
    </div>

    <!-- DETAIL TABLE OF DESAS FOR CHOSEN KECAMATAN -->
    <div id="kecDetailContainer">
      <% if (filterKec) { %>
      <div class="card mt-4">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-houses"></i> Rincian Progres Per Desa/Kelurahan di Kecamatan <%= filterKec %></div>
          <a href="/kecamatan" class="btn btn-secondary btn-xs"><i class="bi bi-x-lg"></i> Tutup Rincian</a>
        </div>

        <div class="search-wrap mb-4">
          <input type="search" id="desaSearch" placeholder="Cari nama desa/kelurahan..." aria-label="Cari nama desa atau kelurahan" style="width: 100%; max-width: 300px;">
        </div>

        <% if (desaStats && desaStats.length > 0) { %>
          <div class="table-wrap">
            <table id="desaTable">
              <thead class="hide-sm">
                <tr>
                  <th rowspan="2" class="text-center" style="font-weight: 600; width: 40px;">No</th>
                  <th rowspan="2">Nama Desa/Kelurahan</th>
                  <!-- <th colspan="2" class="text-center" style="border-bottom: 1px solid var(--border);">SubSLS</th> -->
                  <th colspan="6" class="text-center bg-purple-soft" style="border-bottom: 1px solid var(--border);">Assignment FASIH</th>
                  <th colspan="4" class="text-center bg-cyan-soft muatan-col" style="border-bottom: 1px solid var(--border);">Beban Muatan</th>
                </tr>
                <tr>
                  <th class="text-right bg-yellow-soft">Draft</th>
                  <th class="text-right bg-blue-soft">Submitted</th>
                  <th class="text-right bg-red-soft">Rejected</th>
                  <th class="text-right bg-green-soft">Approved</th>
                  <th class="text-right bg-purple-soft">Target</th>
                  <th class="text-right bg-purple-soft">Progres %</th>
                  
                  <th class="text-right bg-cyan-soft muatan-col">Usaha Total</th>
                  <th class="text-right bg-cyan-soft muatan-col">Target Muatan</th>
                  <th class="text-right bg-cyan-soft muatan-col">Progres %</th>
                  <th class="text-right bg-cyan-soft muatan-col">Keluarga Total</th>
                </tr>
              </thead>
              <thead class="show-sm-table-header">
                <tr>
                  <th class="text-center" style="width: 40px;">No</th>
                  <th>Desa/Kelurahan</th>
                  <!-- <th class="text-right">Total SLS</th> -->
                  <!-- <th class="text-right">Selesai</th> -->
                  <th class="text-right bg-purple-soft" data-column-idx="7">FASIH %</th>
                  <th class="text-right bg-cyan-soft muatan-col" data-column-idx="10">Muatan %</th>
                </tr>
              </thead>
              <tbody>
                <% desaStats.forEach((d, index) => { %>
                  <% let fasihPct = d.target_fasih_total ? ((( (d.submitted_total || 0) + (d.approved_total || 0) + (d.rejected_total || 0) ) / d.target_fasih_total) * 100).toFixed(2) : '0.00'; %>
                  <% let muatanPct = d.total_muatan ? (( (d.usaha_total + d.keluarga_total) / d.total_muatan ) * 100).toFixed(2) : '0.00'; %>
                  <tr>
                    <td class="text-center" style="font-weight: 600; background: var(--bg-subtle);"><%= index + 1 %></td>
                    <td class="td-primary"><a href="/subsls?kec=<%= encodeURIComponent(filterKec) %>&desa=<%= encodeURIComponent(d.desa) %>" style="color: inherit; text-decoration: none;"><i class="bi bi-pin-map"></i> <%= d.desa %></a></td>
                    <!-- <td class="text-right" data-sort="<%= d.total_subsls %>"><%= d.total_subsls %></td> -->
                    <!-- <td class="text-right fw-bold" data-sort="<%= d.selesai %>"><%= d.selesai %></td> -->
                    
                    <td class="text-right bg-yellow-soft hide-sm status-draft-text" data-sort="<%= d.draft_total %>"><%= (d.draft_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-blue-soft hide-sm status-submit-text" data-sort="<%= d.submitted_total %>"><%= (d.submitted_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-red-soft hide-sm status-reject-text" data-sort="<%= d.rejected_total %>" style="font-weight: 600;"><%= (d.rejected_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-green-soft hide-sm status-approve-text" data-sort="<%= d.approved_total %>" style="font-weight: 600;"><%= (d.approved_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-purple-soft hide-sm" data-sort="<%= d.target_fasih_total %>"><%= (d.target_fasih_total || 0).toLocaleString('id-ID') %></td>
                    <td class="text-right bg-purple-soft" data-sort="<%= parseFloat(fasihPct) %>">
                      <% if (parseFloat(fasihPct) >= 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (parseFloat(fasihPct) < 25) { %>
                        <span class="badge badge-red"><%= fasihPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= fasihPct %>%</span>
                      <% } %>
                    </td>
                    
                    <td class="text-right fw-bold bg-cyan-soft hide-sm muatan-col" data-sort="<%= d.usaha_total %>"><%= d.usaha_total.toLocaleString('id-ID') %></td>
                    <td class="text-right bg-cyan-soft hide-sm muatan-col" data-sort="<%= d.total_muatan %>"><%= d.total_muatan.toLocaleString('id-ID') %></td>
                    <td class="text-right bg-cyan-soft muatan-col" data-sort="<%= parseFloat(muatanPct) %>">
                      <% if (parseFloat(muatanPct) >= 100) { %>
                        <span class="badge badge-green">100%</span>
                      <% } else if (parseFloat(muatanPct) < activeTargetPct) { %>
                        <span class="badge badge-red"><%= muatanPct %>%</span>
                      <% } else { %>
                        <span class="badge badge-blue"><%= muatanPct %>%</span>
                      <% } %>
                    </td>
                    <td class="text-right bg-cyan-soft hide-sm muatan-col" data-sort="<%= d.keluarga_total %>"><%= d.keluarga_total.toLocaleString('id-ID') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="no-data">Tidak ada rincian data desa/kelurahan.</div>
        <% } %>
      </div>
    <% } else { %>
      <div class="card empty-state text-center" style="border-style: dashed; border-width: 2px;">
        <div class="empty-state-icon"><i class="bi bi-arrow-up-circle"></i></div>
        <div class="empty-state-title">Pilih Kecamatan</div>
        <div class="empty-state-text">Klik salah satu kartu kecamatan di atas untuk melihat rincian progres per desa/kelurahan.</div>
      </div>
    <% } %>
    </div>

  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    makeTableSortable('desaTable');
    makeTableSearchable('desaSearch', 'desaTable');

    const detailContainer = document.getElementById('kecDetailContainer');
    const cardsGrid = document.querySelector('.kec-grid');

    if (cardsGrid && detailContainer) {
      // Intercept card clicks
      cardsGrid.addEventListener('click', (e) => {
        const link = e.target.closest('a.kec-card');
        if (!link) return;

        e.preventDefault();
        const url = link.getAttribute('href');

        // Update active class on cards
        cardsGrid.querySelectorAll('a.kec-card').forEach(c => {
          c.classList.remove('active');
        });
        link.classList.add('active');

        // Opacity transition
        detailContainer.style.opacity = '0.5';

        fetch(url)
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newDetail = doc.getElementById('kecDetailContainer');
            if (newDetail) {
              detailContainer.innerHTML = newDetail.innerHTML;
              detailContainer.style.opacity = '1';

              // Update URL path without refresh
              window.history.pushState(null, '', url);

              // Re-bind sort and search utilities
              makeTableSortable('desaTable');
              makeTableSearchable('desaSearch', 'desaTable');

              // Re-bind close handler
              bindCloseDetail();
            }
          })
          .catch(err => {
            console.error(err);
            detailContainer.style.opacity = '1';
          });
      });
    }

    // AJAX Tutup Detail handler
    function bindCloseDetail() {
      const closeBtn = detailContainer.querySelector('.btn-secondary');
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = closeBtn.getAttribute('href');

          // Reset active cards
          if (cardsGrid) {
            cardsGrid.querySelectorAll('a.kec-card').forEach(c => {
              c.classList.remove('active');
            });
          }

          detailContainer.style.opacity = '0.5';
          fetch(url)
            .then(res => res.text())
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const newDetail = doc.getElementById('kecDetailContainer');
              if (newDetail) {
                detailContainer.innerHTML = newDetail.innerHTML;
                detailContainer.style.opacity = '1';
                window.history.pushState(null, '', url);
              }
            })
            .catch(err => {
              console.error(err);
              detailContainer.style.opacity = '1';
            });
        });
      }
    }

    bindCloseDetail();
  });
</script>
